{% comment %}
  Shared DaisyUI search bar for listing pages (apps, blog, help).
  Set these before including:
    {% assign searchId = 'appSearchInput' %}
    {% assign searchPlaceholder = 'Search apps...' %}
    {% assign searchLabel = 'Search apps' %}
{% endcomment %}
<div class="max-w-md mx-auto mb-10">
  <label class="input input-lg w-full rounded-xl border-stone-200 transition-colors focus-within:border-[var(--color-mocha)] focus-within:shadow-[0_0_0_3px_rgba(163,105,66,0.2)] focus-within:outline-none">
    <span class="sr-only">{{ searchLabel }}</span>
    <svg class="h-[1em] opacity-40" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" aria-hidden="true">
      <g stroke-linejoin="round" stroke-linecap="round" stroke-width="2.5" fill="none" stroke="currentColor">
        <circle cx="11" cy="11" r="8"></circle>
        <path d="m21 21-4.3-4.3"></path>
      </g>
    </svg>
    <input type="search" id="{{ searchId }}" placeholder="{{ searchPlaceholder }}" class="grow" aria-label="{{ searchLabel }}" />
  </label>
</div>
