<!-- Font preloads -->
<link rel="preload" href="/assets/fonts/Caveat-Regular.woff2" as="font" type="font/woff2" crossorigin>

<style>
    /* Cream page/footer background. Also defined in scripts.html, but tool pages
       include only this partial — without it the footer loses its cream backdrop. */
    .brand-color-background {
        background-color: #fef5ec;
    }

    /* Brand tokens — duplicated from coco.css @theme so pages that don't load
       engine.css (Tailwind Play CDN tool pages) still resolve var(--color-*). */
    :root {
        --color-cream: #fef5ec;
        --color-toffee: #c4813a;
        --color-mocha: #a36942;
        --color-caramel: #96603c;
        --color-espresso: #7a4e31;
        --color-cocoa: #3d2b1f;
        --color-coral: #fd6155;
        --color-coral-deep: #c4413a;
    }

    /* Caveat handwriting font — self-hosted */
    @font-face {
        font-family: 'Caveat';
        font-style: normal;
        font-display: swap;
        font-weight: 400;
        src: url('/assets/fonts/Caveat-Regular.woff2') format('woff2');
    }
    @font-face {
        font-family: 'Caveat';
        font-style: normal;
        font-display: swap;
        font-weight: 600;
        src: url('/assets/fonts/Caveat-SemiBold.woff2') format('woff2');
    }
    @font-face {
        font-family: 'Caveat';
        font-style: normal;
        font-display: swap;
        font-weight: 700;
        src: url('/assets/fonts/Caveat-Bold.woff2') format('woff2');
    }

    /* Brand display heading — receipt style: bold monospace caps with a soft
       coral offset shadow, matching the receipt generator's thermal look.
       Single source of truth: pages include this partial instead of redefining it. */
    .brand-heading {
        font-family: 'Courier New', Courier, monospace;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.02em;
        color: var(--color-cocoa);
        text-shadow: 1.5px 2.5px 0px rgba(253, 97, 85, 0.4);
    }
    @media (min-width: 640px) {
        .brand-heading {
            text-shadow: 2px 3px 0px rgba(253, 97, 85, 0.4);
        }
    }
    @media (min-width: 1024px) {
        .brand-heading {
            text-shadow: 3px 4px 0px rgba(253, 97, 85, 0.4);
        }
    }

    /* Receipt-style separator rows (dashes / asterisks framing headings) */
    .rc-frame {
        font-family: 'Courier New', Courier, monospace;
        letter-spacing: 0.45em;
        color: var(--color-coral-deep);
        opacity: 0.65;
        user-select: none;
        white-space: nowrap;
        overflow: hidden;
    }

    /* ====== Paper-strip site header (receipt aesthetic) ====== */
    .paper-header {
        position: relative;
        background: #fdfcf7;
        box-shadow: 0 4px 14px rgba(61, 43, 31, 0.1);
    }
    .paper-header::after {
        content: '';
        position: absolute;
        bottom: -8px;
        left: 0;
        right: 0;
        height: 8px;
        pointer-events: none;
        background:
            linear-gradient(135deg, transparent 33%, #fdfcf7 33%) 0 0 / 16px 8px repeat-x,
            linear-gradient(-135deg, transparent 33%, #fdfcf7 33%) 8px 0 / 16px 8px repeat-x;
    }
    .ph-link {
        display: block;
        font-family: 'Courier New', Courier, monospace;
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #44403c;
        padding: 0.55rem 0.7rem;
        transition: background 100ms linear, color 100ms linear;
    }
    .ph-link:hover,
    .ph-link:focus-visible {
        background: var(--color-cocoa);
        color: var(--color-cream);
        outline: none;
    }
    .ph-sep {
        font-family: 'Courier New', Courier, monospace;
        color: var(--color-coral-deep);
        opacity: 0.55;
        user-select: none;
    }
    .ph-chip {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        border: 2px solid rgba(61, 43, 31, 0.25);
        background: #ffffff;
        color: #44403c;
        cursor: pointer;
        transition: border-color 100ms linear, color 100ms linear;
    }
    .ph-chip:hover {
        border-color: var(--color-cocoa);
        color: var(--color-cocoa);
    }
    .ph-chip:focus-visible {
        outline: 2px solid var(--color-espresso);
        outline-offset: 2px;
    }
    .ph-menu {
        font-family: 'Courier New', Courier, monospace;
        font-weight: 700;
        font-size: 0.8rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: #44403c;
        border: 2px solid rgba(61, 43, 31, 0.25);
        background: #ffffff;
        padding: 0.5rem 0.9rem;
        cursor: pointer;
    }
    .ph-menu:hover {
        border-color: var(--color-cocoa);
        color: var(--color-cocoa);
    }
    .ph-menu:focus-visible {
        outline: 2px solid var(--color-espresso);
        outline-offset: 2px;
    }

    /* Sketch / doodle annotations */
    .sketch-note {
        font-family: 'Caveat', cursive;
        color: var(--color-caramel);
        position: absolute;
        pointer-events: none;
        white-space: nowrap;
        z-index: 10;
    }
    .sketch-note svg {
        position: absolute;
        overflow: visible;
    }
    .sketch-arrow {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .sketch-arrow-coral {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .sketch-circle {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-dasharray: 6 4;
        opacity: 0.6;
    }
    .sketch-underline {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 2.5;
        stroke-linecap: round;
        opacity: 0.5;
    }
    .sketch-bracket {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.4;
    }
    .sketch-heart {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.5;
    }
    .sketch-heart-filled {
        fill: var(--color-coral);
        stroke: none;
        opacity: 0.25;
    }
    .sketch-squiggle {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 1.5;
        stroke-linecap: round;
        opacity: 0.35;
    }
    .sketch-dots {
        fill: var(--color-mocha);
        opacity: 0.3;
    }
    .sketch-arrow-brown-light {
        fill: none;
        stroke: var(--color-toffee);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.5;
    }
    .sketch-cross {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 2;
        stroke-linecap: round;
        opacity: 0.3;
    }

    .sketch-zigzag {
        fill: none;
        stroke: var(--color-toffee);
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.3;
    }
    .sketch-sparkle {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 1.5;
        stroke-linecap: round;
        opacity: 0.4;
    }

    /* Swirl / spiral */
    .sketch-swirl {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 1.5;
        stroke-linecap: round;
        opacity: 0.3;
    }
    /* Checkmark / tick */
    .sketch-check {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 2.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.45;
    }
    /* Lightning bolt */
    .sketch-lightning {
        fill: none;
        stroke: var(--color-toffee);
        stroke-width: 2;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.35;
    }
    /* Leaf / nature */
    .sketch-leaf {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.3;
    }
    /* Loop arrow (curly) */
    .sketch-loop {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 1.8;
        stroke-linecap: round;
        stroke-linejoin: round;
        opacity: 0.35;
    }
    /* Dashed line */
    .sketch-dash {
        fill: none;
        stroke: var(--color-mocha);
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-dasharray: 8 5;
        opacity: 0.25;
    }
    /* Double underline */
    .sketch-double-underline {
        fill: none;
        stroke: var(--color-toffee);
        stroke-width: 1.5;
        stroke-linecap: round;
        opacity: 0.35;
    }
    /* Exclamation mark */
    .sketch-exclaim {
        fill: none;
        stroke: var(--color-coral);
        stroke-width: 2.5;
        stroke-linecap: round;
        opacity: 0.4;
    }

    /* Gentle float animation for select doodles */
    @keyframes sketch-float {
        0%, 100% { transform: translateY(0px) rotate(var(--sketch-rotate, 0deg)); }
        50% { transform: translateY(-4px) rotate(var(--sketch-rotate, 0deg)); }
    }
    .sketch-float {
        animation: sketch-float 4s ease-in-out infinite;
    }
    .sketch-float-slow {
        animation: sketch-float 6s ease-in-out infinite;
    }
    @keyframes sketch-wiggle {
        0%, 100% { transform: rotate(var(--sketch-rotate, 0deg)); }
        25% { transform: rotate(calc(var(--sketch-rotate, 0deg) + 3deg)); }
        75% { transform: rotate(calc(var(--sketch-rotate, 0deg) - 3deg)); }
    }
    .sketch-wiggle {
        animation: sketch-wiggle 3s ease-in-out infinite;
    }

    /* Hide doodles on very small screens */
    @media (max-width: 639px) {
        .sketch-note { display: none; }
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    const notes = document.querySelectorAll('.sketch-note');
    notes.forEach((el) => el.setAttribute('aria-hidden', 'true'));

    // Draw-in: sketch strokes hand-draw themselves when scrolled into view.
    // Progressive enhancement — without JS or with reduced motion, sketches
    // are simply visible. Dashed styles (sketch-circle, sketch-dash) are
    // skipped so their dash pattern survives.
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    if (!('IntersectionObserver' in window)) return;

    notes.forEach((note) => {
        note.querySelectorAll('path, circle, line, polyline').forEach((shape) => {
            if (typeof shape.getTotalLength !== 'function') return;
            const computed = getComputedStyle(shape);
            if (computed.strokeDasharray && computed.strokeDasharray !== 'none') return;
            if (computed.stroke === 'none') return;
            let len;
            try { len = shape.getTotalLength(); } catch (e) { return; }
            if (!len || !isFinite(len)) return;
            shape.style.strokeDasharray = len + ' ' + len;
            shape.style.strokeDashoffset = len;
            shape.style.transition = 'stroke-dashoffset 1.1s ease-out 0.15s';
        });
    });

    const io = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.querySelectorAll('path, circle, line, polyline').forEach((shape) => {
                shape.style.strokeDashoffset = '0';
            });
            io.unobserve(entry.target);
        });
    }, { threshold: 0.35 });

    notes.forEach((note) => io.observe(note));
});
</script>
