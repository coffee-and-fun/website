    <meta name="twitter:title" content="Markdown Editor — It's a markdown editor. Until it isn't." />
    <meta name="twitter:description" content="Privacy-first markdown editor with live preview, 8 themes, and a hidden chaos zone." />
    <meta name="twitter:image" content="/assets/images/social/pages/markdown-editor.png" />
    <meta name="twitter:image:alt" content="Markdown Editor app" />
