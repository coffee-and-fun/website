    {% bundledCss %}
    {% include scripts.html %}

    <style>
        body { background: #0f0a1a !important; color: #e2ddf5; }

        /* Matrix rain bg */
        #matrix-rain { position: fixed; inset: 0; z-index: 0; pointer-events: none; opacity: 0.08; }

        /* Glow orbs */
        .glow-orb { position: absolute; border-radius: 50%; filter: blur(120px); pointer-events: none; z-index: 0; }

        /* Accent text */
        .grad-pop { color: #c084fc; }
        .grad-green { color: #4ade80; }

        /* Chaos glow cards */
        .chaos-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            transition: all 0.3s;
        }
        .chaos-card:hover {
            transform: translateY(-4px);
            background: rgba(255,255,255,0.06);
            box-shadow: 0 0 60px -10px var(--glow, rgba(139,92,246,0.2));
        }

        /* Feature cards */
        .feature-dark {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.07);
            transition: all 0.3s;
        }
        .feature-dark:hover {
            background: rgba(255,255,255,0.07);
            border-color: rgba(139,92,246,0.2);
            transform: translateY(-4px);
        }

        /* Theme pills */
        .theme-pill {
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.08);
            transition: all 0.25s;
        }
        .theme-pill:hover { background: rgba(255,255,255,0.1); transform: translateY(-2px); }
        .theme-dot { width: 16px; height: 16px; border-radius: 50%; border: 2px solid rgba(255,255,255,0.1); flex-shrink: 0; }

        /* Platform cards */
        .platform-card {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.08);
            transition: all 0.25s;
        }
        .platform-card:hover {
            background: rgba(255,255,255,0.08);
            transform: translateY(-3px);
            box-shadow: 0 8px 32px rgba(0,0,0,0.3);
        }

        /* Video container */
        .video-wrap {
            border-radius: 20px; overflow: hidden;
            box-shadow: 0 40px 100px rgba(0,0,0,0.5), 0 0 0 1px rgba(255,255,255,0.06);
            aspect-ratio: 16 / 9; background: #1a1025;
        }
        .video-wrap video, .video-wrap iframe { width: 100%; height: 100%; object-fit: cover; display: block; }

        /* Privacy */
        .privacy-card {
            background: rgba(74,222,128,0.04);
            border: 1px solid rgba(74,222,128,0.1);
        }

        /* FAQ */
        .faq-section { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06); }

        /* Cat speech bubble — matches the app exactly */
        .cat-speech {
            position: absolute; bottom: 100%; left: 50%; transform: translateX(-50%);
            background: #1a1a2e; color: #fefae0;
            font-family: 'JetBrains Mono', 'Courier New', monospace;
            font-size: 10px; font-weight: 700;
            padding: 3px 7px; border-radius: 6px;
            white-space: nowrap; pointer-events: none;
            margin-bottom: 2px; border: 2px solid #8b7355;
            letter-spacing: 0.5px; opacity: 0; transition: opacity 0.2s;
        }

        /* Combo counter */
        .combo-counter {
            position: fixed; top: 12px; left: 50%; transform: translateX(-50%);
            font-family: 'Impact', 'Arial Black', sans-serif;
            font-size: 24px; font-weight: 900; letter-spacing: 2px;
            pointer-events: none; z-index: 10000;
            text-shadow: 0 0 10px currentColor, 0 0 20px currentColor;
            white-space: nowrap; opacity: 0; transition: all 0.15s ease-out;
        }

        /* Vaporwave CRT overlay */
        .vaporwave-crt {
            position: fixed; inset: 0; pointer-events: none; z-index: 9996;
            background: repeating-linear-gradient(0deg, rgba(0,0,0,0.03) 0px, rgba(0,0,0,0.03) 1px, transparent 1px, transparent 3px);
            opacity: 0; transition: opacity 1s ease;
        }

        /* Emoji rain particles */
        .emoji-drop {
            position: fixed; top: -40px; pointer-events: none; z-index: 9998;
            will-change: transform, opacity;
        }

        /* Reveal animation */
        .reveal { opacity: 0; transform: translateY(24px); transition: all 0.6s cubic-bezier(0.25, 0.1, 0.25, 1); }
        .reveal.visible { opacity: 1; transform: translateY(0); }

        /* Override header/footer for dark page */
        header, header nav, header a { color: rgba(255,255,255,0.7) !important; }
        header a:hover { color: #fff !important; }
        footer { border-color: rgba(255,255,255,0.06) !important; }
        footer, footer a, footer p, footer span { color: rgba(255,255,255,0.3) !important; }
        footer a:hover { color: rgba(255,255,255,0.7) !important; }

        @keyframes vaporwave-hue {
            0% { filter: hue-rotate(0deg); }
            50% { filter: hue-rotate(30deg); }
            100% { filter: hue-rotate(0deg); }
        }
    </style>
</head>

<body>
    {% assign showDonation = false %}
    {% assign showTriviaApp = false %}
    {% assign showKeyboardModal = false %}
    {% assign showInstantApp = false %}
    {% assign showSpoilers = false %}

    {% include header.liquid %}

    <!-- Matrix rain background -->
    <canvas id="matrix-rain"></canvas>

    <!-- Vaporwave CRT overlay (toggled by chaos zone) -->
    <div id="vaporwave-crt" class="vaporwave-crt"></div>

    <!-- Combo counter demo -->
    <div id="combo-counter" class="combo-counter"></div>

    <main id="main-content" class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 pb-8 pt-4">

        <!-- ════════════════════════════ HERO ════════════════════════════ -->
        <section class="pt-24 pb-20 sm:pt-32 sm:pb-28 text-center">
            <!-- Glow orbs -->
            <div class="glow-orb" style="width:600px;height:600px;background:rgba(139,92,246,0.12);top:-200px;left:-150px;"></div>
            <div class="glow-orb" style="width:400px;height:400px;background:rgba(236,72,153,0.08);bottom:-100px;right:-100px;"></div>
            <div class="glow-orb" style="width:300px;height:300px;background:rgba(34,211,238,0.06);top:40%;left:55%;"></div>

            <div class="relative z-10 max-w-3xl mx-auto">
                <img alt="Markdown Editor" src="/assets/images/apps/markdown.png"
                     class="h-24 w-24 mx-auto mb-6 rounded-2xl shadow-lg" decoding="async" loading="lazy" />

                <p class="inline-flex items-center gap-2 rounded-full px-4 py-1.5 text-sm font-semibold mb-8"
                   style="background:rgba(139,92,246,0.12);color:#c4b5fd;border:1px solid rgba(139,92,246,0.25);">
                    Free on All Browsers &middot; No Tracking &middot; Works Offline
                </p>

                <h1 class="text-5xl sm:text-6xl md:text-7xl font-black tracking-tight leading-[0.95] text-white mb-6">
                    It's a markdown editor.<br>
                    <span class="grad-pop">Until it isn't.</span>
                </h1>

                <p class="text-xl sm:text-2xl font-medium max-w-xl mx-auto mb-10" style="color:rgba(255,255,255,0.45);">
                    Write markdown, preview instantly, and unlock a hidden chaos zone with matrix rain, a pet cat, and vaporwave mode.
                </p>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
                    <a href="https://apps.apple.com/us/app/markdown-editor-for-safari/id6578456621"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-2 px-7 py-3.5 rounded-2xl text-white font-semibold transition-all hover:-translate-y-0.5"
                       style="background:#8b5cf6;box-shadow:0 4px 20px rgba(139,92,246,0.3);">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.81-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/></svg>
                        Download for Mac &amp; iPad
                    </a>
                    <a href="https://chromewebstore.google.com/detail/markdown-editor-for-chrom/dkpldbigkfcgpamifjimiejipmodkigk"
                       target="_blank" rel="noopener noreferrer"
                       class="inline-flex items-center gap-2 px-7 py-3.5 rounded-2xl text-white/80 font-semibold transition-all hover:-translate-y-0.5 hover:text-white"
                       style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.1);">
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C8.21 0 4.831 1.757 2.632 4.501l3.953 6.848A5.454 5.454 0 0 1 12 6.545h10.691A12 12 0 0 0 12 0zM1.931 5.47A11.943 11.943 0 0 0 0 12c0 6.012 4.42 10.991 10.189 11.864l3.953-6.847a5.45 5.45 0 0 1-6.865-2.29zm13.342 2.166a5.446 5.446 0 0 1 1.45 7.09l.002.001-3.952 6.848c.32.03.642.048.966.048 6.627 0 12-5.373 12-12 0-1.006-.127-1.983-.361-2.918H15.47zM12 16.364a4.364 4.364 0 1 1 0-8.728 4.364 4.364 0 0 1 0 8.728z"/></svg>
                        Download for Chrome
                    </a>
                </div>

                <!-- Video / Screenshot -->
                <div class="max-w-4xl mx-auto video-wrap">
                    <!-- Replace with: <video src="/assets/videos/markdown-demo.mp4" autoplay muted loop playsinline></video> -->
                    <img src="/assets/images/screenshots/markdown-editor-hero.png"
                         alt="Markdown Editor with dark theme and live preview"
                         class="w-full h-full object-cover" width="2432" height="1442" decoding="async" loading="lazy" />
                </div>
            </div>
        </section>

        <!-- ════════════════════════════ FEATURES ════════════════════════════ -->
        <section class="py-24 text-center">
            <p class="text-xs font-bold uppercase tracking-[3px] mb-3" style="color:#a78bfa;">Features</p>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 tracking-tight">Everything you need. <span class="grad-pop">Nothing you don't.</span></h2>
            <p class="text-lg mb-14" style="color:rgba(255,255,255,0.4);max-width:560px;margin-left:auto;margin-right:auto;">A clean, fast markdown editor that works offline and respects your privacy.</p>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
                <div class="reveal feature-dark rounded-2xl p-8 text-left">
                    <span class="text-3xl block mb-4">&#9889;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Real-Time Preview</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">See your markdown rendered instantly as you type. Split-pane view with synced scrolling.</p>
                </div>
                <div class="reveal feature-dark rounded-2xl p-8 text-left">
                    <span class="text-3xl block mb-4">&#128194;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Drag &amp; Drop</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Drop any .md file right into the editor. Import existing documents instantly.</p>
                </div>
                <div class="reveal feature-dark rounded-2xl p-8 text-left">
                    <span class="text-3xl block mb-4">&#128025;</span>
                    <h3 class="text-lg font-bold text-white mb-2">GitHub Flavored</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Full GFM support &mdash; tables, task lists, strikethrough, fenced code blocks, and more.</p>
                </div>
                <div class="reveal feature-dark rounded-2xl p-8 text-left">
                    <span class="text-3xl block mb-4">&#127912;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Syntax Highlighting</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Code highlighting for 20+ languages in both the editor and preview panes.</p>
                </div>
                <div class="reveal feature-dark rounded-2xl p-8 text-left">
                    <span class="text-3xl block mb-4">&#128244;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Works Offline</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">No internet? No problem. Everything runs locally in your browser.</p>
                </div>
                <div class="reveal feature-dark rounded-2xl p-8 text-left">
                    <span class="text-3xl block mb-4">&#128190;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Auto-Save &amp; Export</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Your work is saved automatically. Export as .md or .html whenever you're ready.</p>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════ CHAOS ZONE ════════════════════════════ -->
        <section class="py-24 text-center">
            <p class="text-xs font-bold uppercase tracking-[3px] mb-3" style="color:#a78bfa;">The Chaos Zone</p>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 tracking-tight">Hidden in the settings. <span class="grad-pop">Impossible to resist.</span></h2>
            <p class="text-lg mb-14" style="color:rgba(255,255,255,0.4);max-width:560px;margin-left:auto;margin-right:auto;">We put way too many fun features in a markdown editor. Toggle them on from the settings panel.</p>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 max-w-5xl mx-auto">
                <div class="reveal chaos-card rounded-2xl p-8 text-left" style="--glow:rgba(0,255,65,0.2);">
                    <span class="text-4xl block mb-4">&#127795;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Matrix Rain</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Green katakana characters cascade down your background. You're the One, Neo.</p>
                </div>
                <div class="reveal chaos-card rounded-2xl p-8 text-left" style="--glow:rgba(251,191,36,0.2);">
                    <span class="text-4xl block mb-4">&#128049;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Pet Cat</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">A pixel cat roams your editor. It walks, sleeps, does zoomies, and reacts when you click it.</p>
                </div>
                <div class="reveal chaos-card rounded-2xl p-8 text-left" style="--glow:rgba(232,121,249,0.2);">
                    <span class="text-4xl block mb-4">&#127796;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Vaporwave Mode</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">CRT scanlines, hue-shifting, and full A E S T H E T I C vibes for your writing session.</p>
                </div>
                <div class="reveal chaos-card rounded-2xl p-8 text-left" style="--glow:rgba(248,113,113,0.2);">
                    <span class="text-4xl block mb-4">&#128548;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Rage Quit Detector</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Delete a bunch of text and the editor notices. Red flash, screen shake, sad confetti.</p>
                </div>
                <div class="reveal chaos-card rounded-2xl p-8 text-left" style="--glow:rgba(253,224,71,0.2);">
                    <span class="text-4xl block mb-4">&#127878;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Confetti Mode</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Every keystroke launches confetti. Because you deserve to celebrate every word.</p>
                </div>
                <div class="reveal chaos-card rounded-2xl p-8 text-left" style="--glow:rgba(167,139,250,0.2);">
                    <span class="text-4xl block mb-4">&#128293;</span>
                    <h3 class="text-lg font-bold text-white mb-2">Combo Counter</h3>
                    <p class="text-sm" style="color:rgba(255,255,255,0.4);">Keep typing without stopping to build combos. Hit GODLIKE status. Lose your streak. Try again.</p>
                </div>
            </div>
        </section>

        <!-- ════════════════════════════ THEMES ════════════════════════════ -->
        <section class="py-24 text-center">
            <p class="text-xs font-bold uppercase tracking-[3px] mb-3" style="color:#a78bfa;">Themes</p>
            <h2 class="text-3xl sm:text-4xl font-extrabold text-white mb-4 tracking-tight">8 gorgeous themes. <span class="grad-pop">Find your vibe.</span></h2>
            <p class="text-lg mb-12" style="color:rgba(255,255,255,0.4);">From dark and moody to light and cozy. Switch instantly from the settings.</p>
            <div class="flex flex-wrap gap-3 justify-center max-w-3xl mx-auto">
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#1e1e2e;"></span> &#127769; Night</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#282a36;"></span> &#129451; Dracula</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#20161F;"></span> &#9749; Coffee</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#1d1729;"></span> &#127749; Sunset</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#1d232a;"></span> &#128161; Dim</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#2e3440;"></span> &#10052; Nord</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#faf7f5;border-color:rgba(255,255,255,0.2);"></span> &#129473; Cupcake</span>
                <span class="reveal theme-pill inline-flex items-center gap-2 rounded-full px-5 py-2.5 text-sm font-semibold" style="color:rgba(255,255,255,0.7);"><span class="theme-dot" style="background:#2d1b69;"></span> &#127925; Synthwave</span>
            </div>
        </section>

