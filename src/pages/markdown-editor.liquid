       ═══════════════════════════════════════════════════════════════ */
    (function() {
        var CAT_SPRITE_DATA = 'data:image/png;base64,';
        var CAT_FRAME_W = 96;
        var CAT_FRAME_H = 96;
        var CAT_ANIMS = {
            sit_up:     { y: 0,    frames: 4, speed: 150 },
            sit_down:   { y: 96,   frames: 4, speed: 150 },
            sit_1:      { y: 192,  frames: 8, speed: 250 },
            sit_2:      { y: 288,  frames: 8, speed: 250 },
            idle_1:     { y: 384,  frames: 8, speed: 200 },
            idle_2:     { y: 480,  frames: 8, speed: 200 },
            w_1:        { y: 576,  frames: 8, speed: 120 },
            w_2:        { y: 672,  frames: 8, speed: 120 },
            w_3:        { y: 768,  frames: 4, speed: 120 },
            stop:       { y: 864,  frames: 4, speed: 150 },
            run_1:      { y: 960,  frames: 2, speed: 80 },
            run_2:      { y: 1056, frames: 4, speed: 80 },
            dream:      { y: 1152, frames: 8, speed: 350 },
            rest:       { y: 1248, frames: 8, speed: 300 },
            aggression: { y: 1344, frames: 4, speed: 120 },
            creep_up:   { y: 1440, frames: 4, speed: 180 },
            j_1:        { y: 1536, frames: 8, speed: 100 },
            j_2:        { y: 1632, frames: 4, speed: 100 },
            j_3:        { y: 1728, frames: 4, speed: 100 },
            bow_1:      { y: 1824, frames: 4, speed: 200 },
            bow_2:      { y: 1920, frames: 4, speed: 200 },
            eat:        { y: 2016, frames: 4, speed: 200 },
            c_1:        { y: 2112, frames: 4, speed: 150 },
            c_2:        { y: 2208, frames: 4, speed: 150 },
            c_3:        { y: 2304, frames: 4, speed: 150 },
            ko:         { y: 2400, frames: 4, speed: 200 },
            dmg:        { y: 2496, frames: 2, speed: 100 },
            death_1:    { y: 2592, frames: 8, speed: 150 },
            death_2:    { y: 2688, frames: 4, speed: 150 },
            attack_1:   { y: 2784, frames: 4, speed: 100 },
            attack_2:   { y: 2880, frames: 4, speed: 100 },
            attack_3:   { y: 2976, frames: 4, speed: 100 },
            attack_4:   { y: 3072, frames: 4, speed: 100 },
            dig_forward:{ y: 3168, frames: 4, speed: 150 },
            dig_back:   { y: 3264, frames: 4, speed: 150 },
            pooping:    { y: 3360, frames: 4, speed: 250 },
            on_2_legs:  { y: 3456, frames: 4, speed: 180 },
            scratching: { y: 3552, frames: 4, speed: 150 }
        };
        var CAT_MEOWS = ['mew!','mrrow!','prrr~','mow!','nya~',':3','*purr*','meow!','*mrrp*','*hiss*','mrrp?','*yawn*'];

        var catEl, catCanvas, catCtx, catSpriteImg, catSpriteReady = false;
        var catAnim = 'idle_1', catFrameIndex = 0, catAnimTimer = null;
        var catX = -8, catDirection = 1, catBusy = false;
        var catEnergy = 70, catLastBehaviors = [];
        var catSpeechEl, catSpeechTimer, catLastSpeechTime = 0;
        var catBehaviorTimer;

        function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }
        function weightedPick(items) {
            var total = items.reduce(function(s,i){return s+i.weight;}, 0);
            var r = Math.random() * total;
            for (var i = 0; i < items.length; i++) { r -= items[i].weight; if (r <= 0) return items[i].value; }
            return items[items.length-1].value;
        }

        function loadCatSprite() {
            return new Promise(function(resolve) {
                catSpriteImg = new Image();
                catSpriteImg.onload = function() { catSpriteReady = true; resolve(); };
                catSpriteImg.onerror = function() { resolve(); };
                catSpriteImg.src = CAT_SPRITE_DATA;
            });
        }

        function drawCatFrame() {
            if (!catCtx || !catSpriteReady || !catSpriteImg) return;
            var anim = CAT_ANIMS[catAnim] || CAT_ANIMS.idle_1;
            var frameIdx = catFrameIndex % anim.frames;
            catCtx.clearRect(0, 0, CAT_FRAME_W, CAT_FRAME_H);
            catCtx.save();
            if (catDirection < 0) { catCtx.translate(CAT_FRAME_W, 0); catCtx.scale(-1, 1); }
            catCtx.drawImage(catSpriteImg, frameIdx * CAT_FRAME_W, anim.y, CAT_FRAME_W, CAT_FRAME_H, 0, 0, CAT_FRAME_W, CAT_FRAME_H);
            catCtx.restore();
        }

        function playCatAnim(name, loops) {
            loops = loops || 1;
            return new Promise(function(resolve) {
                catAnim = name; catFrameIndex = 0;
                if (catAnimTimer) clearInterval(catAnimTimer);
                var anim = CAT_ANIMS[name] || CAT_ANIMS.idle_1;
                var totalFrames = anim.frames * loops; var played = 0;
                drawCatFrame();
                catAnimTimer = setInterval(function() {
                    played++; catFrameIndex++; drawCatFrame();
                    if (played >= totalFrames) { clearInterval(catAnimTimer); catAnimTimer = null; resolve(); }
                }, anim.speed);
            });
        }

        function loopCatAnim(name) {
            catAnim = name; catFrameIndex = 0;
            if (catAnimTimer) clearInterval(catAnimTimer);
            var anim = CAT_ANIMS[name] || CAT_ANIMS.idle_1;
            drawCatFrame();
            catAnimTimer = setInterval(function() { catFrameIndex++; drawCatFrame(); }, anim.speed);
        }

        function showCatSpeech(text, force) {
            if (!catEl) return;
            var now = Date.now();
            if (!force && now - catLastSpeechTime < 2500) return;
            catLastSpeechTime = now;
            if (catSpeechEl) catSpeechEl.remove();
            catSpeechEl = document.createElement('div');
            catSpeechEl.className = 'cat-speech';
            catSpeechEl.textContent = text;
            catEl.appendChild(catSpeechEl);
            requestAnimationFrame(function() { if (catSpeechEl) catSpeechEl.style.opacity = '1'; });
            if (catSpeechTimer) clearTimeout(catSpeechTimer);
            catSpeechTimer = setTimeout(function() {
                if (catSpeechEl) {
                    catSpeechEl.style.opacity = '0';
                    setTimeout(function() { if (catSpeechEl) { catSpeechEl.remove(); catSpeechEl = null; } }, 200);
                }
            }, 1800);
        }

        function moveCat(dx) {
            catX += dx;
            if (catX > 90) { catX = 90; catDirection = -1; }
            if (catX < 3) { catX = 3; catDirection = 1; }
            if (catEl) catEl.style.left = catX + 'vw';
        }

        function adjustEnergy(d) { catEnergy = Math.max(0, Math.min(100, catEnergy + d)); }

        function pickCatBehavior() {
            var e = catEnergy;
            var behaviors = [
                { value: 'walk', weight: 20 },
                { value: 'run', weight: e > 60 ? 12 : 3 },
                { value: 'creep', weight: e > 30 ? 8 : 2 },
                { value: 'sit', weight: e < 50 ? 15 : 6 },
                { value: 'sleep', weight: e < 30 ? 18 : e < 50 ? 8 : 2 },
                { value: 'scratch', weight: 6 },
                { value: 'eat', weight: e < 40 ? 8 : 4 },
                { value: 'dig', weight: 4 },
                { value: 'play', weight: e > 50 ? 14 : 4 },
                { value: 'drama', weight: e > 40 ? 4 : 1 },
                { value: 'poop', weight: 2 },
                { value: 'idle', weight: 10 }
            ];
            for (var i = 0; i < behaviors.length; i++) {
                var recency = catLastBehaviors.lastIndexOf(behaviors[i].value);
                if (recency === catLastBehaviors.length - 1) behaviors[i].weight *= 0.15;
                else if (recency >= 0) behaviors[i].weight *= 0.4;
            }
            var chosen = weightedPick(behaviors);
            catLastBehaviors.push(chosen);
            if (catLastBehaviors.length > 6) catLastBehaviors.shift();
            return chosen;
        }

        async function catDoBehavior() {
            if (catBusy || !catEl) return;
            catBusy = true;
            adjustEnergy(-2);
            var behavior = pickCatBehavior();
            try {
                switch (behavior) {
                    case 'idle': {
                        var a = pick(['idle_1','idle_2','bow_1','bow_2','on_2_legs']);
                        var loops = a.startsWith('idle') ? Math.floor(Math.random()*3)+2 : Math.floor(Math.random()*2)+1;
                        if (a === 'on_2_legs') showCatSpeech(pick(['ta-da!','look!',':3']));
                        else if (a.startsWith('bow')) showCatSpeech(pick(['*stretch*','*yawn*','mrrr...']));
                        else if (Math.random() < 0.15) showCatSpeech(pick(CAT_MEOWS));
                        await playCatAnim(a, loops); adjustEnergy(-1); break;
                    }
                    case 'walk': {
                        var wa = pick(['w_1','w_2','w_3']);
                        var steps = Math.floor(Math.random()*8)+4;
                        if (Math.random() < 0.15) catDirection *= -1;
                        loopCatAnim(wa);
                        for (var i = 0; i < steps; i++) { moveCat(catDirection*(Math.random()*1.2+0.5)); await new Promise(function(r){setTimeout(r,400)}); if (!catEl) break; }
                        await playCatAnim('stop', 1); adjustEnergy(-3);
                        if (catEnergy < 40 && Math.random() < 0.4 && catEl) {
                            await playCatAnim('sit_down', 1); showCatSpeech(pick(['*phew*','tired...']));
                            await playCatAnim(pick(['sit_1','sit_2']), 2); await playCatAnim('sit_up', 1); adjustEnergy(5);
                        }
                        break;
                    }
                    case 'run': {
                        var ra = pick(['run_1','run_2']);
                        if (Math.random() < 0.3) catDirection *= -1;
                        showCatSpeech(pick(['zoom!','nyoom!','!!!','wheee!']));
                        loopCatAnim(ra);
                        var rs = Math.floor(Math.random()*10)+6;
                        for (var j = 0; j < rs; j++) { moveCat(catDirection*(Math.random()*2.5+1.5)); await new Promise(function(r){setTimeout(r,150)}); if (!catEl) break; }
                        await playCatAnim('stop', 1); adjustEnergy(-8); break;
                    }
                    case 'creep': {
                        if (Math.random() < 0.2) catDirection *= -1;
                        showCatSpeech(pick(['...','*sneaky*','*creep*']));
                        loopCatAnim('creep_up');
                        var cs = Math.floor(Math.random()*6)+3;
                        for (var k = 0; k < cs; k++) { moveCat(catDirection*(Math.random()*0.5+0.2)); await new Promise(function(r){setTimeout(r,500)}); if (!catEl) break; }
                        if (Math.random() < 0.5) { await playCatAnim(pick(['j_1','attack_1','attack_2']), 1); showCatSpeech(pick(['GOTCHA!','*pounce*','hya!'])); moveCat(catDirection*3); }
                        adjustEnergy(-4); break;
                    }
                    case 'sit': {
                        await playCatAnim('sit_down', 1);
                        showCatSpeech(pick(['*purr*','comfy~',':3']));
                        await playCatAnim(pick(['sit_1','sit_2']), Math.floor(Math.random()*3)+2);
                        if (Math.random() < 0.35 && catEl) { await playCatAnim('scratching', 2); showCatSpeech(pick(['*scritch*','ahh~'])); }
                        await playCatAnim('sit_up', 1); adjustEnergy(8); break;
                    }
                    case 'sleep': {
                        await playCatAnim('sit_down', 1);
                        var sa = pick(['dream','rest']); showCatSpeech('zzz...');
                        await playCatAnim(sa, Math.floor(Math.random()*4)+3);
                        if (Math.random() < 0.3) showCatSpeech(pick(['*snore*','zzZZz...','*twitch*']));
                        await playCatAnim(sa, 2);
                        showCatSpeech(pick(['*yawn*','mrrh?','...huh?']));
                        await playCatAnim('sit_up', 1); adjustEnergy(25); break;
                    }
                    case 'scratch': {
                        showCatSpeech(pick(['*scritch*','*scratch*','itchy!']));
                        await playCatAnim('scratching', Math.floor(Math.random()*3)+2); break;
                    }
                    case 'eat': {
                        showCatSpeech(pick(['*munch*','yum!','*nom nom*','*crunch*']));
                        await playCatAnim('eat', Math.floor(Math.random()*3)+2);
                        if (Math.random() < 0.4) showCatSpeech(pick(['*burp*','tasty!',':3']));
                        adjustEnergy(15);
                        if (Math.random() < 0.3 && catEl) { await playCatAnim('scratching', 2); showCatSpeech('*wash*'); }
                        break;
                    }
                    case 'dig': {
                        showCatSpeech(pick(['*dig dig*','treasure?','*scratch*']));
                        await playCatAnim('dig_forward', Math.floor(Math.random()*2)+2);
                        if (Math.random() < 0.5) { await playCatAnim('dig_back', 2); showCatSpeech(pick(['nothing...','*found bug*','hm.'])); }
                        adjustEnergy(-3); break;
                    }
                    case 'play': {
                        var ja = pick(['j_1','j_2','j_3']); var aa = pick(['attack_1','attack_2','attack_3','attack_4','aggression']);
                        showCatSpeech(pick(['hya!','rawr!','*play*','*swipe*','!!']));
                        await playCatAnim(ja, 1); moveCat(catDirection*(Math.random()*3+1));
                        if (Math.random() < 0.6) { await playCatAnim(aa, 1); showCatSpeech(pick(['take that!','pow!','*smack*','hiss!'])); }
                        if (Math.random() < 0.4 && catEl) { catDirection *= -1; await playCatAnim(pick(['j_2','j_3']), 1); moveCat(catDirection*2); }
                        adjustEnergy(-6); break;
                    }
                    case 'drama': {
                        showCatSpeech(pick(['*gasp*','oh no!','!!']));
                        await playCatAnim('dmg', 2); await playCatAnim('ko', 2);
                        showCatSpeech(pick(['*ded*','x_x','...']));
                        await playCatAnim(pick(['death_1','death_2']), 2);
                        showCatSpeech(pick(['jk!','*revive*','ta-da!']));
                        await playCatAnim('sit_up', 1); adjustEnergy(-2); break;
                    }
                    case 'poop': {
                        showCatSpeech(pick(['uh oh','brb','...']));
                        await playCatAnim('pooping', 3);
                        showCatSpeech(pick(['done!','*phew*',':3']));
                        break;
                    }
                }
            } catch(e) {}
            catBusy = false;
        }

        function startCatBehavior() {
            catBehaviorTimer = setInterval(function() { if (!catBusy && catEl) catDoBehavior(); }, 3000 + Math.random()*2000);
        }

        function triggerCatReaction() {
            if (!catEl) return;
            catBusy = false;
            var reactions = [
                function() { loopCatAnim('j_1'); showCatSpeech(pick(['wheee!','*bounce*','boing!','jump!']), true); },
                function() { loopCatAnim('attack_1'); showCatSpeech(pick(['*HISS*','rawr!','pounce!','got you!']), true); },
                function() { loopCatAnim('idle_1'); showCatSpeech(pick(['MEOW!','mew mew!','*loud meow*','meeeow!']), true); },
                function() {
                    loopCatAnim('w_1'); showCatSpeech(pick(['aaaah!','*runs away*','nope!','bye!']), true);
                    catBusy = true; var runPhase = 'away'; var runDir = catX > 50 ? 1 : -1;
                    var runTimer = setInterval(function() {
                        if (!catEl) { clearInterval(runTimer); catBusy = false; return; }
                        if (runPhase === 'away') {
                            catX += runDir * 3; catEl.style.left = catX + 'vw';
                            if (catX > 105 || catX < -10) { runPhase = 'pause'; setTimeout(function() { runPhase = 'return'; }, 800); }
                        } else if (runPhase === 'return') {
                            catX -= runDir * 2; catEl.style.left = catX + 'vw';
                            var target = 20 + Math.random() * 50;
                            if ((runDir > 0 && catX <= target) || (runDir < 0 && catX >= target)) {
                                clearInterval(runTimer); catBusy = false; loopCatAnim('idle_1');
                                showCatSpeech(pick(['...back','ok hi','*peeks*',':3']), true);
                            }
                        }
                    }, 60);
                },
                function() {
                    loopCatAnim('attack_1'); showCatSpeech(pick(['*dramatic death*','noooo!','*falls over*','ded.']), true);
                    catEl.style.transform = 'scaleY(-1)';
                    setTimeout(function() { if (catEl) catEl.style.transform = ''; loopCatAnim('idle_1'); }, 1500);
                }
            ];
            pick(reactions)();
        }

        async function createCat() {
            await loadCatSprite();
            if (!catSpriteReady) return;
            catEl = document.createElement('div');
            catX = -8; catDirection = 1; catEnergy = 60 + Math.floor(Math.random()*30);
            Object.assign(catEl.style, {
                position: 'fixed', bottom: '0px', left: catX + 'vw',
                width: CAT_FRAME_W + 'px', height: CAT_FRAME_H + 'px',
                pointerEvents: 'auto', cursor: 'pointer', zIndex: '9998',
                transition: 'left 0.4s linear', userSelect: 'none',
                contain: 'layout style', filter: 'drop-shadow(0 1px 2px rgba(0,0,0,0.25))'
            });
            catCanvas = document.createElement('canvas');
            catCanvas.width = CAT_FRAME_W; catCanvas.height = CAT_FRAME_H;
            Object.assign(catCanvas.style, { width: CAT_FRAME_W+'px', height: CAT_FRAME_H+'px', imageRendering: 'pixelated' });
            catCtx = catCanvas.getContext('2d'); catCtx.imageSmoothingEnabled = false;
            catEl.appendChild(catCanvas);
            document.documentElement.appendChild(catEl);
            catEl.addEventListener('click', triggerCatReaction);
            catBusy = true;
            loopCatAnim('w_1');
            var targetX = 15 + Math.random() * 50;
            var walkIn = setInterval(function() {
                catX += 1.5; if (catEl) catEl.style.left = catX + 'vw';
                if (catX >= targetX || !catEl) {
                    clearInterval(walkIn); catBusy = false;
                    if (catEl) { loopCatAnim('idle_1'); showCatSpeech(pick(['hi!','mew!',':3','*purr*']), true); startCatBehavior(); }
                }
            }, 120);
        }

        // Start after DOM ready
        if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', createCat);
        else createCat();
    })();

    /* ═══════════════════════════════════════════════════════════════
       MATRIX RAIN — Canvas, katakana + hex, exactly like the app
       ═══════════════════════════════════════════════════════════════ */
    (function() {
        var c = document.getElementById('matrix-rain');
        if (!c) return;
        var ctx = c.getContext('2d');
        var w, h, cols;
        var columns = [];
        var chars = '\u30A2\u30A4\u30A6\u30A8\u30AA\u30AB\u30AD\u30AF\u30B1\u30B3\u30B5\u30B7\u30B9\u30BB\u30BD\u30BF\u30C1\u30C4\u30C6\u30C8\u30CA\u30CB\u30CC\u30CD\u30CE\u30CF\u30D2\u30D5\u30D8\u30DB\u30DE\u30DF\u30E0\u30E1\u30E2\u30E4\u30E6\u30E8\u30E9\u30EA\u30EB\u30EC\u30ED\u30EF\u30F2\u30F30123456789ABCDEF';

        function resize() {
            w = c.width = window.innerWidth; h = c.height = window.innerHeight;
            cols = Math.floor(w / 14); columns = [];
            for (var i = 0; i < cols; i++) columns.push({ x: i*14, y: Math.random()*h, speed: 2+Math.random()*6 });
        }
        resize(); window.addEventListener('resize', resize);

        function draw() {
            ctx.fillStyle = 'rgba(0,0,0,0.05)'; ctx.fillRect(0,0,w,h);
            ctx.fillStyle = '#00ff41'; ctx.font = '12px monospace';
            for (var i = 0; i < columns.length; i++) {
                var ch = chars[Math.floor(Math.random()*chars.length)];
                ctx.fillText(ch, columns[i].x, columns[i].y);
                columns[i].y += columns[i].speed;
                if (columns[i].y > h && Math.random() > 0.98) columns[i].y = 0;
            }
            requestAnimationFrame(draw);
        }
        draw();
    })();

    /* ═══════════════════════════════════════════════════════════════
       EMOJI RAIN — Fires periodically to show off the feature
       ═══════════════════════════════════════════════════════════════ */
    (function() {
        var EMOJIS = ['\ud83c\udf89','\u2728','\ud83d\udd25','\ud83d\udc96','\ud83c\udf08','\u2b50','\ud83c\udf8a','\ud83e\udd84','\ud83c\udf55','\ud83c\udfb8','\ud83d\ude80','\ud83c\udf38','\ud83d\udc8e','\ud83c\udfaf','\ud83e\uddc3','\ud83d\udc31','\ud83c\udfaa','\ud83c\udf69','\ud83c\udf0a','\ud83c\udfb5'];
        function burst() {
            var count = Math.floor(Math.random()*4)+3;
            for (var i = 0; i < count; i++) {
                var el = document.createElement('div');
                var x = Math.random()*100;
                var size = Math.random()*16+16;
                var duration = Math.random()*2+2;
                var drift = (Math.random()-0.5)*100;
                var spin = Math.random()*720-360;
                Object.assign(el.style, {
                    position:'fixed', left: x+'vw', top:'-40px', fontSize:size+'px',
                    pointerEvents:'none', zIndex:'9998', opacity:'1',
                    transition:'all '+duration+'s cubic-bezier(.25,.1,.25,1)',
                    willChange:'transform, opacity'
                });
                el.textContent = EMOJIS[Math.floor(Math.random()*EMOJIS.length)];
                document.body.appendChild(el);
                (function(el, drift, duration, spin) {
                    requestAnimationFrame(function() {
                        Object.assign(el.style, {
                            transform:'translateX('+drift+'px) translateY('+(window.innerHeight+60)+'px) rotate('+spin+'deg)',
                            opacity:'0'
                        });
                    });
                    setTimeout(function() { el.remove(); }, (duration+0.5)*1000);
                })(el, drift, duration, spin);
            }
        }
        // Periodic emoji rain bursts — demo the feature
        setInterval(burst, 8000);
        setTimeout(burst, 3000);
    })();

    /* ═══════════════════════════════════════════════════════════════
       COMBO COUNTER — Demo that cycles through the tiers
       ═══════════════════════════════════════════════════════════════ */
    (function() {
        var comboEl = document.getElementById('combo-counter');
        if (!comboEl) return;
        var tiers = [
            { min: 5, label: 'COMBO', color: '#48dbfb' },
            { min: 15, label: 'GREAT!', color: '#feca57' },
            { min: 30, label: 'AMAZING!', color: '#ff9ff3' },
            { min: 50, label: 'INCREDIBLE!', color: '#ff6b6b' },
            { min: 75, label: 'UNSTOPPABLE!', color: '#54a0ff' },
            { min: 100, label: 'GODLIKE!', color: '#5f27cd' },
            { min: 150, label: 'BEYOND GODLIKE!!', color: '#f368e0' },
            { min: 200, label: 'LEGENDARY!!!', color: '#ff9234' }
        ];
        var count = 0, tierIdx = 0;
        function pulse() {
            var tier = tiers[tierIdx];
            count = tier.min + Math.floor(Math.random()*10);
            comboEl.textContent = count + 'x ' + tier.label;
            comboEl.style.color = tier.color;
            comboEl.style.opacity = '1';
            comboEl.style.transform = 'translateX(-50%) scale(1.4)';
            setTimeout(function() { comboEl.style.transform = 'translateX(-50%) scale(1)'; }, 200);
            setTimeout(function() { comboEl.style.opacity = '0'; }, 2500);
            tierIdx = (tierIdx + 1) % tiers.length;
        }
        setInterval(pulse, 12000);
        setTimeout(pulse, 6000);
    })();

    /* ═══════════════════════════════════════════════════════════════
       VAPORWAVE CRT — Flash it briefly every so often
       ═══════════════════════════════════════════════════════════════ */
    (function() {
        var crt = document.getElementById('vaporwave-crt');
        if (!crt) return;
        function flash() {
            crt.style.opacity = '1';
            document.getElementById('main-content').style.animation = 'vaporwave-hue 10s linear infinite';
            setTimeout(function() {
                crt.style.opacity = '0';
                document.getElementById('main-content').style.animation = '';
            }, 5000);
        }
        setInterval(flash, 25000);
        setTimeout(flash, 15000);
    })();

    /* ── Scroll Reveal ── */
    (function() {
        var obs = new IntersectionObserver(function(entries) {
            entries.forEach(function(e) { if (e.isIntersecting) e.target.classList.add('visible'); });
        }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
        document.querySelectorAll('.reveal').forEach(function(el) { obs.observe(el); });
    })();
    </script>
</body>
</html>
