  {% bundledCss %}
  {% include sketch-styles.liquid %}

  <!-- Pixel fonts for the Minecraft look -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet" />

  <script src="https://unpkg.com/vue@3"></script>

  <style>
    [v-cloak] { display: none; }

    .font-mc { font-family: 'Press Start 2P', monospace; }
    .font-px { font-family: 'VT323', monospace; }
    .pixelated { image-rendering: pixelated; }

    /* Dark dirt page background with a faint pixel checker */
    .mc-world {
      background-color: #241a12;
      background-image:
        repeating-conic-gradient(#2a1f15 0% 25%, #241a12 0% 50%);
      background-size: 16px 16px;
    }

    /* Classic inventory panel: stone gray, black outline, light TL / dark BR bevel */
    .mc-panel {
      background: #c6c6c6;
      border: 3px solid #1a1a1a;
      box-shadow:
        inset 3px 3px 0 rgba(255, 255, 255, 0.7),
        inset -3px -3px 0 rgba(0, 0, 0, 0.35),
        0 6px 0 rgba(0, 0, 0, 0.4);
    }

    /* Inventory slot: inverted bevel (pressed-in look) */
    .mc-slot {
      background: #8b8b8b;
      border: 3px solid #1a1a1a;
      box-shadow:
        inset 3px 3px 0 rgba(0, 0, 0, 0.45),
        inset -3px -3px 0 rgba(255, 255, 255, 0.5);
    }
    .mc-slot.dragging { background: #9fae7c; }

    /* Classic MC button */
    .mc-btn {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.65rem;
      line-height: 1.4;
      color: #ffffff;
      text-shadow: 2px 2px 0 rgba(0, 0, 0, 0.6);
      background: #6d6d6d;
      border: 3px solid #1a1a1a;
      box-shadow:
        inset 2px 2px 0 rgba(255, 255, 255, 0.55),
        inset -3px -3px 0 rgba(0, 0, 0, 0.4);
      padding: 0.85rem 1.15rem;
      cursor: pointer;
      transition: background 80ms linear;
      touch-action: manipulation;
    }
    .mc-btn:hover { background: #7e88cf; }
    .mc-btn:active {
      box-shadow:
        inset -2px -2px 0 rgba(255, 255, 255, 0.4),
        inset 3px 3px 0 rgba(0, 0, 0, 0.4);
    }
    .mc-btn:focus-visible { outline: 3px solid #ffd83d; outline-offset: 2px; }
    .mc-btn:disabled { opacity: 0.5; cursor: not-allowed; }

    .mc-btn-green { background: #417a28; }
    .mc-btn-green:hover { background: #4c8a2f; }

    .mc-btn-gold { background: #b3831c; }
    .mc-btn-gold:hover { background: #c79422; }

    .mc-btn.is-selected {
      background: #417a28;
      outline: 3px solid #ffd83d;
      outline-offset: -6px;
    }

    /* Grass ground strip */
    .grass-strip {
      height: 14px;
      background: linear-gradient(
        to bottom,
        #8fca5c 0%, #8fca5c 40%,
        #71a844 40%, #71a844 60%,
        #6a4526 60%, #5c3a20 100%
      );
      image-rendering: pixelated;
    }

    /* Title screen splash text */
    .mc-splash {
      font-family: 'VT323', monospace;
      color: #ffff54;
      text-shadow: 2px 2px 0 #3f3f00;
      transform: rotate(-10deg);
      display: inline-block;
      animation: splash-pulse 0.9s ease-in-out infinite alternate;
    }
    @keyframes splash-pulse {
      from { transform: rotate(-10deg) scale(1); }
      to { transform: rotate(-10deg) scale(1.07); }
    }
    @media (prefers-reduced-motion: reduce) {
      .mc-splash { animation: none; }
    }

    /* Number chip used in the block list */
    .mc-chip {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 2rem;
      height: 2rem;
      flex-shrink: 0;
      border: 2px solid #1a1a1a;
      font-family: 'Press Start 2P', monospace;
      font-size: 0.6rem;
      box-shadow: inset 1px 1px 0 rgba(255,255,255,.4), inset -1px -1px 0 rgba(0,0,0,.3);
    }

    /* Scrollable build-guide viewport */
    .mc-viewport {
      overflow: auto;
      max-height: 70vh;
      background: #313131;
      border: 3px solid #1a1a1a;
      box-shadow: inset 3px 3px 0 rgba(0,0,0,.5), inset -3px -3px 0 rgba(255,255,255,.15);
    }

    .mc-label {
      font-family: 'Press Start 2P', monospace;
      font-size: 0.6rem;
      letter-spacing: 0.02em;
      color: #3d3d3d;
    }
  </style>
</head>

<body class="mc-world min-h-screen">
  <main id="main-content">
    <div v-cloak id="app" class="mx-auto max-w-5xl px-4 sm:px-6 py-10 sm:py-14">

      <!-- Skip link -->
      <a href="#upload-section" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 bg-espresso text-white px-4 py-2 rounded-lg z-50">
        Skip to main content
      </a>

      <!-- Back link -->
      <a href="/" class="font-px text-2xl text-white/80 hover:text-white transition-colors inline-flex items-center gap-2 mb-8" style="text-shadow: 2px 2px 0 rgba(0,0,0,.6);" aria-label="Back to Coffee & Fun homepage">
        <span aria-hidden="true">&larr;</span> coffeeandfun.com
      </a>

      <!-- Title -->
      <header class="text-center mb-10 relative">
        <h1 class="font-mc text-white text-xl sm:text-3xl leading-relaxed" style="text-shadow: 3px 3px 0 #3f3f3f;">
          MINECRAFT&nbsp;PIXEL&nbsp;ART<br />GENERATOR
        </h1>
        <p class="mc-splash text-2xl sm:text-3xl mt-3" aria-hidden="true">{% raw %}{{ splash }}{% endraw %}</p>
        <p class="font-px text-2xl text-stone-300 mt-4 max-w-xl mx-auto">
          Drop in any image. Get blocks, a numbered build guide, and a shopping list. All in your browser.
        </p>
      </header>

      <!-- Upload slot -->
      <section id="upload-section" aria-label="Image upload" class="mb-8">
        <div v-if="!uploadedImage"
             @drop.prevent="handleDrop"
             @dragover.prevent="isDragging = true"
             @dragleave="isDragging = false"
             :class="{ dragging: isDragging }"
             class="mc-slot p-10 sm:p-14 text-center cursor-pointer select-none"
             @click="$refs.fileInput.click()"
             role="button"
             tabindex="0"
             @keydown.enter="$refs.fileInput.click()"
             @keydown.space.prevent="$refs.fileInput.click()"
             aria-label="Upload an image. Click, drag and drop, or paste from clipboard.">

          <div class="mx-auto mb-5 w-16 h-16 pixelated" aria-hidden="true">
            <svg viewBox="0 0 16 16" class="w-full h-full">
              <rect x="1" y="1" width="14" height="14" fill="#417a28" stroke="#1a1a1a" stroke-width="1"/>
              <rect x="7" y="4" width="2" height="6" fill="#fff"/>
              <rect x="5" y="8" width="2" height="2" fill="#fff"/>
              <rect x="9" y="8" width="2" height="2" fill="#fff"/>
              <rect x="7" y="10" width="2" height="2" fill="#fff"/>
            </svg>
          </div>

          <h2 class="font-mc text-sm text-white mb-3" style="text-shadow: 2px 2px 0 rgba(0,0,0,.6);">DROP IMAGE HERE</h2>
          <p class="font-px text-2xl text-stone-100">click to browse &bull; or paste with Ctrl+V</p>
          <p class="font-px text-xl text-stone-300 mt-1">PNG, JPG, or WEBP &mdash; any size</p>

          <button type="button" @click.stop="loadSample" class="mc-btn mc-btn-gold mt-6">
            NO IMAGE? TRY A SAMPLE
          </button>

          <input
            ref="fileInput"
            type="file"
            @change="handleFileSelect"
            accept="image/png,image/jpeg,image/jpg,image/webp"
            class="hidden"
            aria-label="Choose an image file to convert to pixel art" />
        </div>

        <!-- Loaded file bar -->
        <div v-else class="mc-panel p-4 sm:p-5 flex flex-wrap items-center gap-4">
          <img :src="uploadedImage" alt="Uploaded image thumbnail" class="w-16 h-16 object-cover border-2 border-black pixelated" />
          <div class="min-w-0 flex-1">
            {% raw %}
            <p class="font-px text-2xl text-stone-800 truncate">{{ fileName }}</p>
            <p class="font-px text-xl text-stone-600">{{ imageWidth }} &times; {{ imageHeight }} px</p>
            {% endraw %}
          </div>
          <button @click="resetUpload" class="mc-btn" style="background:#8e3c3c;">SWAP IMAGE</button>
        </div>
      </section>

      <!-- Settings -->
      <section v-if="uploadedImage" aria-label="Conversion settings" class="mc-panel p-5 sm:p-6 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_auto] gap-6 items-start">
          <div>
            <p class="mc-label mb-3" id="size-label">ART WIDTH (BLOCKS)</p>
            <div class="flex flex-wrap gap-2" role="radiogroup" aria-labelledby="size-label">
              <button v-for="size in gridSizes" :key="size"
                @click="gridWidth = size"
                class="mc-btn"
                :class="{ 'is-selected': gridWidth === size }"
                role="radio"
                :aria-checked="gridWidth === size">
                {% raw %}{{ size }}{% endraw %}
              </button>
            </div>
            <p class="font-px text-xl text-stone-600 mt-3" aria-live="polite">
              {% raw %}= {{ gridWidth }} &times; {{ gridHeight }} blocks ({{ totalBlocks.toLocaleString() }} total){% endraw %}
            </p>
          </div>

          <div class="flex flex-col gap-4">
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" v-model="useDithering" class="toggle toggle-success" />
              <div>
                <span class="mc-label block">DITHERING</span>
                <span class="font-px text-lg text-stone-600">Smoother gradients, speckled texture</span>
              </div>
            </label>
            <label class="flex items-center gap-3 cursor-pointer">
              <input type="checkbox" v-model="showGrid" class="toggle toggle-success" />
              <div>
                <span class="mc-label block">GRID ON ART</span>
                <span class="font-px text-lg text-stone-600">Chunk lines + coordinates on the art PNG</span>
              </div>
            </label>
          </div>
        </div>
        <p class="font-px text-xl text-emerald-800 mt-4 flex items-center gap-2" role="status" aria-live="polite">
          <span v-if="isGenerating">Mining blocks&hellip;</span>
          <span v-else>Changes apply instantly &mdash; no button mashing needed.</span>
        </p>
      </section>

      <!-- Results -->
      <section v-if="pixelArtDataUrl" ref="results" class="space-y-8" aria-label="Pixel art results">

        <!-- Preview panel with tabs -->
        <div class="mc-panel p-5 sm:p-6">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
            <div class="flex flex-wrap gap-2" role="tablist" aria-label="Preview mode">
              <button role="tab" :aria-selected="activeTab === 'art'" @click="activeTab = 'art'"
                class="mc-btn" :class="{ 'is-selected': activeTab === 'art' }">BLOCKS</button>
              <button role="tab" :aria-selected="activeTab === 'guide'" @click="activeTab = 'guide'"
                class="mc-btn" :class="{ 'is-selected': activeTab === 'guide' }">BUILD GUIDE</button>
              <button role="tab" :aria-selected="activeTab === 'original'" @click="activeTab = 'original'"
                class="mc-btn" :class="{ 'is-selected': activeTab === 'original' }">ORIGINAL</button>
            </div>
            {% raw %}
            <p class="font-px text-xl text-stone-600">{{ uniqueBlockCount }} block types &bull; {{ totalBlocks.toLocaleString() }} blocks</p>
            {% endraw %}
          </div>

          <!-- Blocks tab -->
          <div v-show="activeTab === 'art'" role="tabpanel" aria-label="Block art preview">
            <img :src="pixelArtDataUrl" alt="Generated Minecraft pixel art preview" class="w-full pixelated border-2 border-black bg-white" />
          </div>

          <!-- Build guide tab -->
          <div v-show="activeTab === 'guide'" role="tabpanel" aria-label="Numbered build guide">
            <p class="font-px text-xl text-stone-700 mb-3">
              Every cell shows the block number &mdash; match it to the list below. Bold lines mark 16-block chunks. Scroll to explore.
            </p>
            <div class="mc-viewport" tabindex="0" aria-label="Scrollable build guide. Each cell is numbered with the block to place.">
              <img :src="guideDataUrl" alt="" class="pixelated block" style="max-width: none;" />
            </div>
          </div>

          <!-- Original tab -->
          <div v-show="activeTab === 'original'" role="tabpanel" aria-label="Original image">
            <img :src="uploadedImage" alt="Original uploaded image" class="w-full border-2 border-black bg-white" />
          </div>

          <!-- Downloads -->
          <div class="flex flex-wrap gap-3 mt-5">
            <button @click="downloadPixelArt" class="mc-btn mc-btn-green">DOWNLOAD ART PNG</button>
            <button @click="downloadGuide" class="mc-btn mc-btn-gold">BUILD GUIDE PNG</button>
            <button @click="downloadBlockList" class="mc-btn">BLOCK LIST TXT</button>
          </div>
        </div>

        <!-- Shopping list -->
        <div class="mc-panel p-5 sm:p-6">
          <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
            <h2 class="font-mc text-sm text-stone-800">BLOCK SHOPPING LIST</h2>
            <div class="flex gap-2" role="group" aria-label="Sort block list">
              <button @click="sortBy = 'count'" class="mc-btn" :class="{ 'is-selected': sortBy === 'count' }">BY COUNT</button>
              <button @click="sortBy = 'name'" class="mc-btn" :class="{ 'is-selected': sortBy === 'name' }">BY NAME</button>
            </div>
          </div>

          <div class="overflow-x-auto bg-[#d7d7d7] border-2 border-black">
            <table class="table w-full">
              <thead>
                <tr class="border-b-2 border-stone-500">
                  <th scope="col" class="mc-label py-3">#</th>
                  <th scope="col" class="mc-label py-3">BLOCK</th>
                  <th scope="col" class="mc-label py-3 text-right">COUNT</th>
                  <th scope="col" class="mc-label py-3 text-right">STACKS</th>
                </tr>
              </thead>
              <tbody class="font-px text-2xl text-stone-800">
                <tr v-for="block in sortedBlockList" :key="block.name" class="border-b border-stone-400/40">
                  <td class="py-2">
                    <span class="mc-chip" :style="{ backgroundColor: block.hex, color: block.textColor }">{% raw %}{{ block.num }}{% endraw %}</span>
                  </td>
                  <td class="py-2">{% raw %}{{ block.name }}{% endraw %}</td>
                  <td class="py-2 text-right font-bold">{% raw %}{{ block.count.toLocaleString() }}{% endraw %}</td>
                  <td class="py-2 text-right text-stone-600">{% raw %}{{ stacksLabel(block.count) }}{% endraw %}</td>
                </tr>
              </tbody>
            </table>
          </div>
        </div>

        <!-- How to build -->
        <div class="mc-panel p-5 sm:p-6">
          <h2 class="font-mc text-sm text-stone-800 mb-5">HOW TO BUILD IT</h2>
          <ol class="space-y-4 font-px text-2xl text-stone-800">
            <li class="flex gap-4 items-start">
              <span class="mc-chip" style="background:#417a28; color:#fff;">1</span>
              <span>Download the <strong>Build Guide PNG</strong> &mdash; every cell is numbered, and the legend at the bottom maps numbers to blocks.</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="mc-chip" style="background:#417a28; color:#fff;">2</span>
              <span>Gather the blocks from the shopping list. A stack is 64 &mdash; the list does the math for you.</span>
            </li>
            <li class="flex gap-4 items-start">
              <span class="mc-chip" style="background:#417a28; color:#fff;">3</span>
              {% raw %}
              <span>Build it as a wall, starting from the bottom-left corner. Your art is {{ gridWidth }} wide &times; {{ gridHeight }} tall. Bold chunk lines every 16 blocks help you keep your place.</span>
              {% endraw %}
            </li>
            <li class="flex gap-4 items-start">
              <span class="mc-chip" style="background:#417a28; color:#fff;">4</span>
              <span>Work chunk by chunk and tick off the numbers as you go. Happy mining!</span>
            </li>
          </ol>
        </div>
      </section>

    </div>
  </main>

  <div class="grass-strip" aria-hidden="true"></div>

