    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/chrome-extension-icon-generator/" />

    <!-- Favicon -->
    <link rel="icon" href="/assets/images/favicon.png" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />
    <link rel="icon" href="/assets/images/social/192.png" sizes="192x192" type="image/png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:title" content="Chrome Extension Icon Generator - Every Size from One Image" />
    <meta property="og:description" content="Upload one 1024x1024 image and get every icon size your Chrome extension needs, ready to download individually or as a zip. Free and browser-based." />
