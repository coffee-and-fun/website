<!DOCTYPE html>
<html
  class="brand-color-background scroll-smooth antialiased"
  lang="en"
  data-theme="light"
  style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;"
>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About Coffee & Fun LLC | Brewing Joy & Community in Every Cup</title>
    <meta
      name="description"
      content="Get to know Coffee & Fun LLC where every cup is crafted with love, laughter, and a dash of mischief. Discover our story and join the community!"
    />
    <meta name="author" content="Coffee & Fun LLC" />
    <meta name="robots" content="index, follow" />
    <meta name="rating" content="safe for kids" />

    <link rel="icon" href="/assets/images/favicon.png" />

    <meta
      name="title"
      content="About Coffee & Fun LLC | Brewing Joy & Community in Every Cup"
    />

    <!-- PWA Manifest -->
    <link rel="manifest" href="/assets/images/social/site.webmanifest" />

    <!-- Theme & Mobile Meta -->
    <meta name="theme-color" content="#fef5ec" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />

    <!-- Icons -->
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />
    <link
      rel="icon"
      href="/assets/images/social/192.png"
      sizes="192x192"
      type="image/png"
    />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/about/" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:title" content="About Coffee & Fun LLC | Brewing Joy & Community in Every Cup" />
    <meta property="og:description" content="Get to know Coffee & Fun LLC where every cup is crafted with love, laughter, and a dash of mischief. Discover our story and join the community!" />
    <meta property="og:url" content="https://www.coffeeandfun.com/about/" />
    <meta property="og:image" content="https://www.coffeeandfun.com/assets/images/social/pages/about.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bycoffeeandfun" />
    <meta name="twitter:title" content="About Coffee & Fun LLC | Brewing Joy & Community in Every Cup" />
    <meta name="twitter:description" content="Get to know Coffee & Fun LLC where every cup is crafted with love, laughter, and a dash of mischief. Discover our story and join the community!" />
    <meta name="twitter:image" content="https://www.coffeeandfun.com/assets/images/social/pages/about.png" />
    <meta name="twitter:image:alt" content=" Coffee & Fun" />

    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "AboutPage",
        "name": "About Coffee & Fun LLC",
        "description": "Get to know Coffee & Fun LLC where every app is crafted with love, laughter, and a dash of mischief.",
        "url": "https://www.coffeeandfun.com/about/",
        "mainEntity": {
          "@type": "Organization",
          "@id": "https://www.coffeeandfun.com/#organization",
          "name": "Coffee & Fun LLC",
          "url": "https://www.coffeeandfun.com/",
          "founder": {
            "@type": "Person",
            "name": "Robert James Gabriel"
          },
          "logo": {
            "@type": "ImageObject",
            "url": "https://www.coffeeandfun.com/assets/images/coffee-and-fun-logo-dark.png",
            "width": 180,
            "height": 180
          },
          "sameAs": [
            "https://x.com/bycoffeeandfun"
          ]
        }
      }
    </script>

    {% bundledCss %}
    {% include sketch-styles.liquid %}

    <style>
      .stat-number {
        font-family: 'Pacifico', cursive;
        font-size: clamp(2.75rem, 7vw, 5rem);
        line-height: 1.2;
      }

      .full-bleed {
        width: 100vw;
        margin-left: calc(50% - 50vw);
      }

      .team-card img {
        transition: transform 0.3s ease;
      }
      @media (prefers-reduced-motion: no-preference) {
        .team-card:hover img,
        .team-card:focus-within img {
          transform: scale(1.03) rotate(-1deg);
        }
      }
    </style>

    <script>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/service-worker.js').catch(() => {});
        });
      }
    </script>

    {% include scripts.html %}
  </head>

  <body>
    {% assign showFun = true %}
    {% assign showMiddleBadgeWithText = true %}
    {% include header.liquid %}

    <main id="main-content">

    <!-- Mission Statement -->
    <section class="relative mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-20 sm:py-28 overflow-visible">
      <div class="max-w-4xl mx-auto text-center">
        <!-- Sketch: heart near mission text -->
        <div class="sketch-note sketch-float-slow" style="top: 20%; left: 5%; --sketch-rotate: -12deg;">
            <svg width="26" height="24" viewBox="0 0 24 22">
                <path d="M12 21 C12 21, 2 14, 2 7 C2 3, 5 1, 8 2 C10 3, 11 5, 12 6 C13 5, 14 3, 16 2 C19 1, 22 3, 22 7 C22 14, 12 21, 12 21 Z" class="sketch-heart"/>
            </svg>
        </div>

        <!-- Sketch: star top-right -->
        <div class="sketch-note" style="top: 15%; right: 6%; transform: rotate(15deg);">
            <svg width="24" height="24" viewBox="0 0 30 30">
                <path d="M15 2 L17 11 L26 11 L19 17 L22 26 L15 21 L8 26 L11 17 L4 11 L13 11 Z" fill="none" stroke="#fd6155" stroke-width="1.5" stroke-linejoin="round" opacity="0.35"/>
            </svg>
        </div>

        <!-- Sketch: "our mission" with arrow -->
        <div class="sketch-note text-lg sm:text-xl" style="top: 12%; right: 12%; transform: rotate(-5deg);">
            our mission
            <svg width="40" height="30" style="bottom: -26px; left: 10px;">
                <path d="M20 2 C15 10, 10 18, 8 26" class="sketch-arrow"/>
                <path d="M2 22 L8 28 L13 21" class="sketch-arrow"/>
            </svg>
        </div>

        <h1 class="brand-heading text-4xl sm:text-5xl lg:text-7xl leading-[1.2] sm:leading-[1.2] lg:leading-[1.2]">
          Making the world a little brighter,
          <br />
          one app at a time
        </h1>

        <p class="mt-6 sm:mt-8 text-xl sm:text-2xl text-stone-600 max-w-[50ch] mx-auto leading-relaxed text-balance">
          Where every app is crafted with love, laughter, and a dash of mischief.
        </p>

        <!-- Trust row -->
        <p class="mt-10 text-xl sm:text-2xl text-caramel" style="font-family: 'Caveat', cursive;">
          One human&nbsp;&nbsp;&middot;&nbsp;&nbsp;Four pups&nbsp;&nbsp;&middot;&nbsp;&nbsp;A lot of coffee
        </p>

        <!-- Sketch: wavy underline under mischief -->
        <div class="sketch-note" style="bottom: 22%; left: 50%; transform: translateX(-50%);">
            <svg width="140" height="12" viewBox="0 0 140 12">
                <path d="M2 8 C18 2, 28 12, 46 6 C64 0, 74 12, 92 6 C110 0, 125 10, 138 5" class="sketch-underline"/>
            </svg>
        </div>

        <!-- Sketch: squiggly bottom-left -->
        <div class="sketch-note" style="bottom: 8%; left: 8%;">
            <svg width="50" height="14" viewBox="0 0 50 14">
                <path d="M2 8 C8 2, 14 12, 20 7 C26 2, 32 12, 38 7 C44 2, 48 10, 48 7" class="sketch-squiggle"/>
            </svg>
        </div>

        <!-- Sketch: lightning bolt right -->
        <div class="sketch-note" style="bottom: 15%; right: 8%; transform: rotate(12deg);">
            <svg width="14" height="24" viewBox="0 0 16 28">
                <path d="M10 0 L4 12 L10 12 L6 28" class="sketch-lightning"/>
            </svg>
        </div>

        <!-- Sketch: checkmark -->
        <div class="sketch-note sketch-wiggle" style="top: 70%; right: 12%; --sketch-rotate: 5deg;">
            <svg width="20" height="18" viewBox="0 0 22 20">
                <path d="M3 10 L9 16 L19 4" class="sketch-check"/>
            </svg>
        </div>

        <!-- Sketch: exclamation left -->
        <div class="sketch-note" style="top: 40%; left: 3%;">
            <svg width="8" height="22" viewBox="0 0 10 24">
                <path d="M5 2 L5 16" class="sketch-exclaim"/>
                <circle cx="5" cy="22" r="2" fill="#fd6155" opacity="0.4"/>
            </svg>
        </div>
      </div>
    </section>

    <!-- About Content -->
    <section class="relative max-w-5xl mx-auto py-16 sm:py-24 px-4 sm:px-6 lg:px-8 overflow-visible">
      <!-- Sketch: "the good stuff" with arrow sweeping down-right to the Who We Are heading -->
      <div class="sketch-note text-xl sm:text-2xl" style="top: 8px; left: 4%; transform: rotate(-4deg);">
        the good stuff
        <svg width="66" height="68" style="bottom: -62px; right: -12px;">
            <path d="M6 4 C20 24, 38 44, 54 62" class="sketch-arrow"/>
            <path d="M43 60 L56 64 L52 51" class="sketch-arrow"/>
        </svg>
      </div>
      <!-- Sketch: sparkle burst left of content -->
      <div class="sketch-note sketch-float" style="top: 35%; left: 1%; --sketch-rotate: 0deg;">
          <svg width="22" height="22" viewBox="0 0 22 22">
              <path d="M11 2 L11 20" class="sketch-sparkle"/>
              <path d="M2 11 L20 11" class="sketch-sparkle"/>
              <path d="M4 4 L18 18" class="sketch-sparkle"/>
              <path d="M18 4 L4 18" class="sketch-sparkle"/>
          </svg>
      </div>

      <!-- Sketch: zigzag bottom of section -->
      <div class="sketch-note" style="bottom: 8%; right: 5%;">
          <svg width="50" height="16" viewBox="0 0 50 16">
              <path d="M2 14 L12 2 L22 14 L32 2 L42 14 L50 4" class="sketch-zigzag"/>
          </svg>
      </div>

      <!-- Sketch: loop arrow near content -->
      <div class="sketch-note" style="bottom: 15%; left: 2%;">
          <svg width="30" height="22" viewBox="0 0 30 22">
              <path d="M4 18 C4 4, 20 4, 22 10 C24 18, 16 20, 14 12" class="sketch-loop"/>
              <path d="M10 14 L14 10 L18 14" class="sketch-loop"/>
          </svg>
      </div>

      <!-- Sketch: leaf near top-left -->
      <div class="sketch-note sketch-float-slow" style="top: 18%; left: 3%; --sketch-rotate: -18deg;">
          <svg width="20" height="24" viewBox="0 0 24 28">
              <path d="M12 2 C4 8, 2 18, 12 26 C22 18, 20 8, 12 2 Z" class="sketch-leaf"/>
              <path d="M12 6 L12 22" class="sketch-leaf"/>
          </svg>
      </div>

      <!-- Sketch: dashed line -->
      <div class="sketch-note" style="top: 65%; right: 3%;">
          <svg width="60" height="6" viewBox="0 0 60 6">
              <path d="M0 3 L60 3" class="sketch-dash"/>
          </svg>
      </div>

      <!-- Sketch: coffee cup near Who We Are -->
      <div class="sketch-note" style="top: 20%; right: 2%; transform: rotate(10deg);">
          <svg width="24" height="28" viewBox="0 0 28 32">
              <path d="M4 10 L4 26 C4 28 6 30 10 30 L18 30 C22 30 24 28 24 26 L24 10" class="sketch-arrow" style="opacity: 0.3;"/>
              <path d="M24 14 C28 14, 28 22, 24 22" class="sketch-arrow" style="opacity: 0.3;"/>
              <path d="M10 6 C10 2, 12 0, 12 0" class="sketch-arrow" style="opacity: 0.15;"/>
              <path d="M16 4 C16 0, 18 -2, 18 -2" class="sketch-arrow" style="opacity: 0.15;"/>
          </svg>
      </div>

      <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <h2 class="brand-heading text-3xl sm:text-4xl lg:text-5xl leading-[1.25] mb-6">Who We Are</h2>
          <p class="text-xl sm:text-2xl text-stone-600 leading-relaxed">
            We're a small team of passionate coffee enthusiasts and software
            engineers who believe in the power of community and creativity.
          </p>
        </div>
        <div>
          <p class="text-lg sm:text-xl text-stone-600 leading-relaxed">
            Our mission is to bring joy and a little bit of mischief to your daily
            routine through our innovative products and engaging content.
            Whether it's crafting the perfect cup of coffee or sharing our
            latest adventures, we strive to make every interaction with Coffee &
            Fun a delightful experience.
          </p>
        </div>
      </div>
    </section>

    <!-- Stats Section - Full Width -->
    <section class="relative full-bleed py-20 sm:py-28 px-6 overflow-visible" style="background-color: var(--color-cocoa);">
      <!-- Sketch: "est." near founded date -->
      <div class="sketch-note text-lg" style="bottom: 20%; left: 8%; transform: rotate(-5deg); color: var(--color-toffee);">
          est.
      </div>

      <!-- Sketch: sparkle near 1M+ -->
      <div class="sketch-note sketch-float-slow" style="top: 22%; right: 10%; --sketch-rotate: 5deg;">
          <svg width="24" height="24" viewBox="0 0 28 28">
              <path d="M14 2 L14 26" class="sketch-sparkle" style="stroke: var(--color-toffee);"/>
              <path d="M2 14 L26 14" class="sketch-sparkle" style="stroke: var(--color-toffee);"/>
              <path d="M5 5 L23 23" class="sketch-sparkle" style="stroke: var(--color-toffee);"/>
              <path d="M23 5 L5 23" class="sketch-sparkle" style="stroke: var(--color-toffee);"/>
          </svg>
      </div>

      <!-- Sketch: zigzag bottom -->
      <div class="sketch-note" style="bottom: 8%; left: 50%; transform: translateX(-50%);">
          <svg width="80" height="14" viewBox="0 0 80 14">
              <path d="M2 12 L12 2 L22 12 L32 2 L42 12 L52 2 L62 12 L72 2 L80 10" class="sketch-zigzag" style="stroke: var(--color-toffee);"/>
          </svg>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="grid md:grid-cols-3 gap-12 sm:gap-16 text-center">
          <div>
            <div class="stat-number mb-3 text-white">2022</div>
            <p class="text-2xl" style="font-family: 'Caveat', cursive; color: var(--color-cream);">founded</p>
          </div>
          <div>
            <div class="stat-number mb-3 text-white">2</div>
            <p class="text-2xl" style="font-family: 'Caveat', cursive; color: var(--color-cream);">team members</p>
          </div>
          <div class="relative">
            <!-- Sketch: "and growing!" pointing down at the 1M+ stat -->
            <div class="sketch-note text-xl sm:text-2xl" style="bottom: 100%; left: 50%; transform: translateX(-30%) rotate(-3deg); color: var(--color-toffee);">
              and growing!
              <svg width="46" height="42" style="bottom: -36px; left: 6px;">
                  <path d="M30 2 C24 16, 14 26, 7 38" class="sketch-arrow" style="stroke: var(--color-toffee);"/>
                  <path d="M2 28 L6 40 L16 32" class="sketch-arrow" style="stroke: var(--color-toffee);"/>
              </svg>
            </div>
            <div class="stat-number mb-3 text-white">1M+</div>
            <p class="text-2xl" style="font-family: 'Caveat', cursive; color: var(--color-cream);">happy users</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class="relative max-w-6xl mx-auto py-16 sm:py-24 px-4 sm:px-6 lg:px-8 overflow-visible">
      <div class="mb-14 sm:mb-20 text-center">
        <h2 class="brand-heading text-3xl sm:text-4xl lg:text-5xl leading-[1.25] mb-5">Our Team</h2>
        <p class="text-xl sm:text-2xl text-stone-600 max-w-3xl mx-auto">
          Meet the people (and pups) behind Coffee & Fun.
        </p>
      </div>

      <!-- Sketch: "woof!" near the team cards -->
      <div class="sketch-note text-xl sm:text-2xl" style="top: 20px; right: 4%; transform: rotate(5deg);">
        <svg width="18" height="18" viewBox="0 0 30 30" style="position: relative; display: inline-block; margin-right: 4px; vertical-align: middle;">
            <path d="M15 2 L17 11 L26 11 L19 17 L22 26 L15 21 L8 26 L11 17 L4 11 L13 11 Z" fill="none" stroke="#fd6155" stroke-width="1.5" stroke-linejoin="round" opacity="0.5"/>
        </svg>
        woof!
      </div>

      <div class="relative grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
        <!-- Sketch: "the boss" with arrow to Robert -->
        <div class="sketch-note text-base sm:text-lg" style="top: -20px; left: 4%; transform: rotate(-4deg);">
            the boss
            <svg width="30" height="24" style="bottom: -20px; left: 16px;">
                <path d="M15 2 C12 10, 8 16, 6 20" class="sketch-arrow"/>
                <path d="M1 16 L6 22 L10 15" class="sketch-arrow"/>
            </svg>
        </div>

        <!-- Sketch: floating heart near the pups -->
        <div class="sketch-note sketch-float" style="top: 30%; right: -1%; --sketch-rotate: 6deg;">
            <svg width="18" height="16" viewBox="0 0 24 22">
                <path d="M12 21 C12 21, 2 14, 2 7 C2 3, 5 1, 8 2 C10 3, 11 5, 12 6 C13 5, 14 3, 16 2 C19 1, 22 3, 22 7 C22 14, 12 21, 12 21 Z" class="sketch-heart-filled"/>
            </svg>
        </div>

        <!-- Sketch: swirl near the pets -->
        <div class="sketch-note" style="bottom: 8%; left: 50%; transform: translateX(-50%);">
            <svg width="28" height="28" viewBox="0 0 30 30">
                <path d="M15 15 C15 10, 20 8, 22 12 C24 16, 20 20, 15 18 C10 16, 8 10, 12 6 C16 2, 24 4, 26 10 C28 18, 22 26, 12 24" class="sketch-swirl"/>
            </svg>
        </div>

        <!-- Sketch: exclamation near the team heading -->
        <div class="sketch-note" style="top: -15px; left: 38%;">
            <svg width="8" height="22" viewBox="0 0 10 24">
                <path d="M5 2 L5 16" class="sketch-exclaim"/>
                <circle cx="5" cy="22" r="2" fill="#fd6155" opacity="0.4"/>
            </svg>
        </div>

        <!-- Sketch: lightning near bottom-left -->
        <div class="sketch-note sketch-wiggle" style="bottom: 3%; left: 3%; --sketch-rotate: -10deg;">
            <svg width="14" height="24" viewBox="0 0 16 28">
                <path d="M10 0 L4 12 L10 12 L6 28" class="sketch-lightning"/>
            </svg>
        </div>

        <div class="team-card text-center">
          <div class="mb-6">
            <img
              class="w-full aspect-square object-cover rounded-2xl"
              loading="lazy"
              decoding="async"
              src="/assets/images/about/rob.png"
              alt="Robert James"
              width="400" height="400"
            />
          </div>
          <h3 class="text-xl font-bold text-stone-900 mb-1">Robert James</h3>
          <p class="text-xl text-caramel" style="font-family: 'Caveat', cursive;">Founder / CTO</p>
        </div>

        <div class="team-card text-center">
          <div class="mb-6">
            <img
              class="w-full aspect-square object-cover rounded-2xl"
              loading="lazy"
              decoding="async"
              src="/assets/images/about/coco.webp"
              alt="Coco"
              width="400" height="400"
            />
          </div>
          <h3 class="text-xl font-bold text-stone-900 mb-1">Coco</h3>
          <p class="text-xl text-caramel" style="font-family: 'Caveat', cursive;">Head of Search</p>
        </div>

        <div class="team-card text-center">
          <div class="mb-6">
            <img
              class="w-full aspect-square object-cover rounded-2xl"
              loading="lazy"
              decoding="async"
              src="/assets/images/about/crash.webp"
              alt="Crash"
              width="400" height="400"
            />
          </div>
          <h3 class="text-xl font-bold text-stone-900 mb-1">Crash</h3>
          <p class="text-xl text-caramel" style="font-family: 'Caveat', cursive;">Head of Security</p>
        </div>

        <div class="team-card text-center">
          <div class="mb-6">
            <img
              class="w-full aspect-square object-cover rounded-2xl"
              loading="lazy"
              decoding="async"
              src="/assets/images/about/honey.webp"
              alt="Honey"
              width="400" height="400"
            />
          </div>
          <h3 class="text-xl font-bold text-stone-900 mb-1">Honey</h3>
          <p class="text-xl text-caramel" style="font-family: 'Caveat', cursive;">Head of Activity</p>
        </div>

        <div class="team-card text-center">
          <div class="mb-6">
            <img
              class="w-full aspect-square object-cover rounded-2xl"
              loading="lazy"
              decoding="async"
              src="/assets/images/about/juneo.webp"
              alt="Juneau"
              width="400" height="400"
            />
          </div>
          <h3 class="text-xl font-bold text-stone-900 mb-1">Juneau</h3>
          <p class="text-xl text-caramel" style="font-family: 'Caveat', cursive;">Assistant</p>
        </div>
      </div>
    </section>

    <!-- Blog Section -->
    <section class="relative mx-auto max-w-6xl py-16 sm:py-24 px-4 sm:px-6 lg:px-8 overflow-visible">
      <div class="max-w-6xl mx-auto">
        <div class="relative mb-12 sm:mb-16 text-center">
          <!-- Sketch: "hot off the press!" near blog heading -->
          <div class="sketch-note text-lg sm:text-xl" style="top: -10px; right: 4%; transform: rotate(4deg);">
              hot off the press!
              <svg width="18" height="18" viewBox="0 0 30 30" style="position: relative; display: inline-block; margin-left: 4px; vertical-align: middle;">
                  <path d="M15 2 L17 11 L26 11 L19 17 L22 26 L15 21 L8 26 L11 17 L4 11 L13 11 Z" fill="none" stroke="#fd6155" stroke-width="1.5" stroke-linejoin="round" opacity="0.5"/>
              </svg>
          </div>
          <h2 class="brand-heading text-3xl sm:text-4xl lg:text-5xl leading-[1.25] mb-5">Latest From The Blog</h2>
          <p class="text-xl sm:text-2xl text-stone-600 max-w-3xl mx-auto">
            Discover our latest updates, guides, and announcements.
          </p>
        </div>

        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          {% for post in blog.posts limit:3 %}
               <a
                  class="group bg-white rounded-2xl border border-stone-200 overflow-hidden transition-all duration-200 hover:-translate-y-1 hover:shadow-lg focus:outline-none focus:ring-2 focus:ring-offset-2" style="--tw-ring-color: var(--color-mocha);"
                  href="{{ post.link }}">
                  <figure class="p-3 pb-0">
                    <img
                      loading="lazy"
                      src="{{ post.image }}"
                      width="600" height="400"
                      class="rounded-xl w-full object-cover"
                      alt="{{ post.name }}"
                    />
                  </figure>
                  <div class="p-4 pt-3">
                    <h2 class="text-lg font-semibold text-stone-900 mb-1 group-hover:text-mocha transition-colors">{{ post.name }}</h2>
                    <p class="text-sm text-stone-600 line-clamp-2">{{ post.description }}</p>

                    <div class="flex flex-wrap gap-1.5 mt-4">
                      {% for platform in post.platform %}
                      {% assign ptag = platform | downcase %}
                      {% if ptag == "blog" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-mocha);">{{ platform }}</span>
                      {% elsif ptag == "hack" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-coral-deep);">{{ platform }}</span>
                      {% elsif ptag == "guide" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-caramel);">{{ platform }}</span>
                      {% elsif ptag == "web" or ptag == "nodejs" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-espresso);">{{ platform }}</span>
                      {% elsif ptag == "update" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-caramel);">{{ platform }}</span>
                      {% elsif ptag == "company" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-cocoa);">{{ platform }}</span>
                      {% elsif ptag == "ios" or ptag == "ipad" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:#4a7249;">{{ platform }}</span>
                      {% elsif ptag == "social" %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:#8b6f4e;">{{ platform }}</span>
                      {% else %}
                      <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium text-white" style="background-color:var(--color-mocha);">{{ platform }}</span>
                      {% endif %}
                      {% endfor %}
                    </div>
                  </div>
                </a>
          {% endfor %}
        </div>
      </div>
    </section>

