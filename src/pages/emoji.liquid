<!DOCTYPE html>
<html class="antialiased" lang="en" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary Meta Tags -->
    <title>Emoji Search & Copy - Find Any Emoji Fast | Coffee & Fun LLC</title>
    <meta name="description" content="Search thousands of emoji by name, browse by category, and copy any of them with one click. Free, fast, and everything happens in your browser." />
    <meta name="author" content="Coffee & Fun LLC" />
    <meta name="robots" content="index, follow" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/emoji/" />

    <!-- Favicon -->
    <link rel="icon" href="/assets/images/favicon.png" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/images/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:title" content="Emoji Search & Copy - Find Any Emoji Fast" />
    <meta property="og:description" content="Search thousands of emoji by name, browse by category, and copy any of them with one click. Free and fast." />
    <meta property="og:url" content="https://www.coffeeandfun.com/emoji/" />
    <meta property="og:image" content="https://www.coffeeandfun.com/assets/images/social/pages/emoji.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Emoji Search & Copy by Coffee & Fun" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@bycoffeeandfun" />
    <meta name="twitter:creator" content="@bycoffeeandfun" />
    <meta name="twitter:title" content="Emoji Search & Copy - Find Any Emoji Fast" />
    <meta name="twitter:description" content="Search thousands of emoji by name, browse by category, and copy any of them with one click." />
    <meta name="twitter:image" content="https://www.coffeeandfun.com/assets/images/social/pages/emoji.png" />
    <meta name="twitter:image:alt" content="Emoji Search & Copy by Coffee & Fun" />

    <meta name="theme-color" content="#f4f4f2" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Emoji Search & Copy",
        "description": "Search thousands of emoji by name, browse by category, and copy any of them with one click.",
        "url": "https://www.coffeeandfun.com/emoji/",
        "applicationCategory": "UtilityApplication",
        "operatingSystem": "Web Browser",
        "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
        "creator": {
            "@type": "Organization",
            "name": "Coffee & Fun LLC",
            "url": "https://www.coffeeandfun.com"
        },
        "featureList": [
            "Search emoji by name or keyword",
            "Browse by category",
            "One-click copy to clipboard",
            "Recently used emoji list",
            "Popular emoji shortcuts"
        ]
    }
    </script>

    <script src="https://unpkg.com/vue@3"></script>

    <style>
        :root {
            --bg: #f4f4f2;
            --surface: #ffffff;
            --ink: #16161a;
            --muted: #6c6c74;
            --faint: #9a9aa2;
            --line: #e4e4e0;
            --line-strong: #d3d3ce;
            --good: #0f7b4f;
            --warn: #b4341f;
            --radius: 14px;
            --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
            --emoji-font: 'Apple Color Emoji', 'Segoe UI Emoji', 'Noto Color Emoji', sans-serif;
        }

        * { box-sizing: border-box; }

        html, body { background: var(--bg); }
        body {
            margin: 0;
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            -webkit-font-smoothing: antialiased;
            accent-color: var(--ink);
        }
        [v-cloak] { display: none; }

        .sr-only {
            position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
            overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
        }

        a.skip {
            position: absolute; left: -9999px; top: 0;
            background: var(--ink); color: #fff; padding: 0.6rem 1rem; z-index: 20;
            border-radius: 0 0 8px 0;
        }
        a.skip:focus { left: 0; }

        .wrap {
            width: 100%;
            max-width: 880px;
            margin: 0 auto;
            padding: 2rem 1.25rem 4rem;
            flex: 1;
        }

        .topbar {
            display: flex;
            align-items: center;
            margin-bottom: 2.5rem;
        }

        /* Logo home link + tooltip (hover AND keyboard focus) */
        .home-link { position: relative; display: inline-flex; border-radius: 10px; }
        .home-link img { width: 40px; height: 40px; display: block; transition: transform 0.15s ease; }
        .home-link:hover img, .home-link:focus-visible img { transform: rotate(-8deg) scale(1.08); }
        .home-link:focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
        .home-link .tip {
            position: absolute; top: calc(100% + 9px); left: 0;
            background: var(--ink); color: #fff;
            font-size: 0.78rem; font-weight: 600; letter-spacing: 0.01em;
            white-space: nowrap; padding: 0.4rem 0.7rem; border-radius: 8px;
            opacity: 0; transform: translateY(-4px); pointer-events: none;
            transition: opacity 0.15s, transform 0.15s;
            z-index: 30;
        }
        .home-link .tip::before {
            content: ''; position: absolute; top: -4px; left: 14px;
            width: 8px; height: 8px; background: var(--ink);
            transform: rotate(45deg);
        }
        .home-link:hover .tip, .home-link:focus-visible .tip { opacity: 1; transform: translateY(0); }
        @media (prefers-reduced-motion: reduce) {
            .home-link img, .home-link .tip { transition: none; }
            .home-link:hover img, .home-link:focus-visible img { transform: none; }
        }

        h1 {
            font-size: 2.1rem;
            line-height: 1.2;
            letter-spacing: -0.02em;
            margin: 0 0 0.6rem;
            font-weight: 650;
        }
        .lede {
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.55;
            margin: 0 0 2.25rem;
            max-width: 56ch;
        }

        h2.step-label {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--muted);
            margin: 0 0 0.8rem;
        }
        section.step { margin-bottom: 2.25rem; }
        .row-head {
            display: flex; justify-content: space-between; align-items: baseline;
            gap: 1rem; flex-wrap: wrap; margin-bottom: 0.8rem;
        }
        .row-head h2.step-label { margin: 0; }
        .row-head h2.step-label:focus { outline: none; }
        .counter { font-size: 0.8rem; color: var(--muted); }

        /* Search box — one big friendly field, front and center */
        .search-row { display: flex; gap: 10px; flex-wrap: wrap; max-width: 640px; }
        .search { position: relative; flex: 1 1 300px; min-width: 0; }
        .search .mag {
            position: absolute; left: 1.1rem; top: 50%; transform: translateY(-50%);
            color: var(--muted); pointer-events: none;
        }
        .field {
            width: 100%;
            min-height: 56px;
            border: 1px solid var(--line-strong);
            border-radius: 16px;
            padding: 0.9rem 4.2rem 0.9rem 2.9rem;
            font-size: 1.1rem;
            font-family: inherit;
            line-height: 1.5;
            color: var(--ink);
            background: var(--surface);
            outline: none;
        }
        .field:focus { border-color: var(--ink); box-shadow: 0 0 0 3px rgba(22,22,26,0.08); }
        .field::placeholder { color: #74747b; }
        .field::-webkit-search-cancel-button { display: none; }
        .clear-btn {
            position: absolute; right: 0.6rem; top: 50%; transform: translateY(-50%);
            appearance: none; border: none; background: none;
            width: 36px; height: 36px; border-radius: 10px;
            color: var(--muted); font-size: 1rem; line-height: 1;
            cursor: pointer; font-family: inherit;
            display: inline-flex; align-items: center; justify-content: center;
        }
        .clear-btn:hover { color: var(--ink); background: #ececea; }
        .clear-btn:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        .kbd-hint {
            position: absolute; right: 0.95rem; top: 50%; transform: translateY(-50%);
            pointer-events: none;
        }
        @media (max-width: 560px) {
            .kbd-hint { display: none; }
        }

        /* Surprise button — lives beside the search */
        .btn.surprise { min-height: 56px; border-radius: 16px; }
        .surprise .die { font-family: var(--emoji-font); font-size: 1.25rem; line-height: 1; }

        kbd {
            font-family: var(--mono); font-size: 0.72rem;
            border: 1px solid var(--line-strong); border-bottom-width: 2px;
            border-radius: 5px; padding: 0.05rem 0.35rem;
            background: var(--surface); color: var(--muted);
        }

        button.linkish {
            appearance: none; border: none; background: none; padding: 0;
            font-size: 0.82rem; color: var(--muted); text-decoration: underline;
            cursor: pointer; font-family: inherit; white-space: nowrap;
        }
        button.linkish:hover { color: var(--ink); }
        button.linkish:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; border-radius: 4px; }

        /* Category chips — one quiet row, scrolls sideways on small screens */
        .cats {
            display: flex; flex-wrap: nowrap; gap: 8px;
            overflow-x: auto; -webkit-overflow-scrolling: touch;
            scrollbar-width: none; -ms-overflow-style: none;
            padding: 5px; margin: -5px; /* room for focus outlines inside the scroller */
        }
        .cats::-webkit-scrollbar { display: none; }
        .cat {
            appearance: none; font-family: inherit;
            border: 1px solid var(--line-strong); background: transparent;
            border-radius: 999px; padding: 0.45rem 0.9rem;
            font-size: 0.85rem; font-weight: 600; color: var(--ink);
            cursor: pointer; white-space: nowrap; flex: 0 0 auto;
            transition: background 0.15s, border-color 0.15s, color 0.15s;
        }
        .cat:hover { border-color: var(--ink); }
        .cat[aria-pressed="true"] { background: var(--ink); border-color: var(--ink); color: #fff; }
        .cat:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        .cat .ico { font-family: var(--emoji-font); margin-right: 0.3rem; }

        /* Emoji buttons — the emoji are the color, the chrome recedes */
        .ebtn {
            appearance: none; font-family: inherit;
            background: transparent;
            border: none;
            border-radius: 12px;
            padding: 0.55rem 0.3rem 0.5rem;
            min-width: 48px; min-height: 48px;
            cursor: pointer;
            display: flex; flex-direction: column; align-items: center; gap: 0.3rem;
            transition: background 0.15s;
        }
        .ebtn:hover { background: #ececea; }
        .ebtn:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        .ebtn .glyph {
            font-size: 2.5rem; line-height: 1.15; font-family: var(--emoji-font);
            transition: transform 0.12s ease;
        }
        .ebtn:hover .glyph, .ebtn:focus-visible .glyph { transform: scale(1.12); }
        .ebtn:active .glyph { transform: scale(0.92); }
        .ebtn .ename {
            font-size: 0.7rem; color: var(--muted); line-height: 1.25; text-align: center;
            display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
            overflow: hidden; overflow-wrap: anywhere;
        }
        .ebtn.mini {
            width: 52px; height: 52px; padding: 0;
            justify-content: center; gap: 0;
        }
        .ebtn.mini .glyph { font-size: 1.8rem; }

        .egrid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(92px, 1fr));
            gap: 6px 4px;
        }
        .mini-row { display: flex; flex-wrap: wrap; gap: 6px; }

        /* Empty state */
        .code-empty {
            border: 1.5px dashed var(--line-strong);
            border-radius: var(--radius);
            padding: 2.4rem 1.25rem;
            text-align: center;
            color: var(--muted);
            font-size: 0.92rem;
            line-height: 1.6;
        }
        .code-empty .big { font-size: 2.2rem; font-family: var(--emoji-font); display: block; margin-bottom: 0.5rem; }

        /* Buttons */
        .btn {
            appearance: none; border: none; border-radius: 11px;
            padding: 0.85rem 1.4rem;
            font-size: 0.98rem; font-weight: 600; cursor: pointer; font-family: inherit;
            display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
            transition: background 0.15s, opacity 0.15s, border-color 0.15s;
        }
        .btn:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        .btn-secondary {
            background: var(--surface); color: var(--ink);
            border: 1px solid var(--line-strong);
        }
        .btn-secondary:hover { border-color: var(--ink); }
        .load-wrap { display: flex; justify-content: center; margin-top: 1.4rem; }

        /* Copied toast (decorative twin of the screen-reader announcement) */
        .toast {
            position: fixed; left: 50%; bottom: 1.4rem; transform: translateX(-50%);
            background: var(--ink); color: #fff;
            border-radius: 999px; padding: 0.5rem 1.3rem 0.5rem 0.8rem;
            display: flex; align-items: center; gap: 0.7rem;
            font-size: 0.95rem; font-weight: 700;
            box-shadow: 0 6px 24px rgba(0,0,0,0.18);
            z-index: 30; max-width: calc(100vw - 2rem);
        }
        .toast .glyph { font-size: 1.9rem; line-height: 1; font-family: var(--emoji-font); }
        .toast .tname { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        @keyframes toast-pop {
            0% { opacity: 0; transform: translate(-50%, 10px) scale(0.9); }
            60% { opacity: 1; transform: translate(-50%, -2px) scale(1.03); }
            100% { opacity: 1; transform: translate(-50%, 0) scale(1); }
        }
        .toast-enter-active { animation: toast-pop 0.25s ease; }
        .toast-leave-active { transition: opacity 0.18s ease, transform 0.18s ease; }
        .toast-leave-to { opacity: 0; transform: translate(-50%, 8px); }

        .foot {
            text-align: center; padding: 1.5rem 1rem 2rem;
            font-size: 0.8rem; color: var(--muted);
        }

        @media (prefers-reduced-motion: reduce) {
            .cat, .btn, .ebtn, .ebtn .glyph { transition: none; }
            .ebtn:hover .glyph, .ebtn:focus-visible .glyph, .ebtn:active .glyph { transform: none; }
            .toast-enter-active, .toast-leave-active { animation: none; transition: none; }
        }

        @media (max-width: 480px) {
            h1 { font-size: 1.7rem; }
            .wrap { padding-top: 1.5rem; }
            .topbar { margin-bottom: 2rem; }
            .egrid { grid-template-columns: repeat(auto-fill, minmax(78px, 1fr)); }
        }

        /* ---- Site footer ----
           footer.liquid is written against Tailwind utilities, which this
           standalone page doesn't load; these rules cover exactly the classes
           that markup uses (plus sketch-styles.liquid for the doodles). */
        footer.brand-color-background { position: relative; overflow: visible; padding: 1rem; }
        footer .mx-auto { margin-left: auto; margin-right: auto; }
        footer .max-w-7xl { max-width: 80rem; padding: 3rem 1rem; }
        footer .max-w-2xl { max-width: 42rem; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
        footer .mb-4 { display: inline-block; margin-bottom: 1rem; border-radius: 1rem; }
        footer img { height: 4rem; width: 4rem; }
        footer h2 { margin: 0 0 0.5rem; font-size: 1.125rem; font-weight: 700; }
        footer p { margin: 0; font-size: 0.875rem; }
        footer .text-stone-600 { color: #57534e; }
        footer .font-semibold { font-weight: 600; }
        footer .text-base { font-size: 1rem; }
        footer .text-lg { font-size: 1.125rem; }
        footer .flex-wrap { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; margin-top: 2rem; }
        footer .flex-wrap a { display: inline-flex; padding: 0.5rem; border-radius: 1rem; color: #78716c; transition: color 0.15s; }
        footer .flex-wrap svg { height: 1.5rem; width: 1.5rem; }
        footer .hover\:text-blue-400:hover { color: #60a5fa; }
        footer .hover\:text-pink-500:hover { color: #ec4899; }
        footer .hover\:text-indigo-500:hover { color: #6366f1; }
        footer .hover\:text-stone-900:hover { color: #1c1917; }
        footer .hover\:text-red-500:hover { color: #ef4444; }
        footer p.text-center { margin-top: 2rem; text-align: center; }
        footer a:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        @media (min-width: 640px) {
            footer.brand-color-background { padding: 1.5rem; }
            footer .sm\:text-lg { font-size: 1.125rem; }
            footer .sm\:text-xl { font-size: 1.25rem; }
            footer .max-w-7xl { padding: 4rem 1.5rem; }
            footer img { height: 5rem; width: 5rem; }
            footer h2 { font-size: 1.25rem; }
            footer p { font-size: 1rem; }
            footer .flex-wrap { gap: 1.5rem; margin-top: 3rem; }
            footer .flex-wrap svg { height: 1.75rem; width: 1.75rem; }
            footer p.text-center { margin-top: 2.5rem; }
        }
        @media (min-width: 1024px) {
            footer.brand-color-background { padding: 2.5rem; }
            footer .max-w-7xl { padding: 5rem 2rem; }
            footer img { height: 6rem; width: 6rem; }
            footer h2 { font-size: 1.5rem; }
            footer .flex-wrap { margin-top: 4rem; }
            footer p.text-center { margin-top: 3rem; }
        }
    </style>
    {% include sketch-styles.liquid %}
</head>

<body>
{% raw %}
    <a href="#tool" class="skip">Skip to the tool</a>

    <main v-cloak id="app" class="wrap">

        <div class="topbar">
            <a href="/" class="home-link" aria-label="Back to coffeeandfun.com">
                <img src="/assets/images/coffee-and-fun-logo-dark.png" alt="" width="40" height="40" decoding="async" />
                <span class="tip" aria-hidden="true">Back to coffeeandfun.com</span>
            </a>
        </div>

        <header id="tool">
            <h1>The emoji you want, one click away</h1>
            <p class="lede">Search {{ totalFormatted }} emoji, click your favorite, and it&rsquo;s copied — ready to paste anywhere.</p>
        </header>

        <!-- Live status for screen readers -->
        <div class="sr-only" role="status" aria-live="polite">{{ announcement }}</div>

        <!-- ===== Search ===== -->
        <section class="step" aria-labelledby="h-search">
            <h2 class="step-label sr-only" id="h-search">Search</h2>
            <label class="sr-only" for="emoji-search">Search emoji by name</label>
            <div class="search-row">
                <div class="search">
                    <svg class="mag" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
                    <input id="emoji-search" ref="searchInput" class="field" type="search"
                           v-model="searchQuery"
                           placeholder="Try &ldquo;heart&rdquo;, &ldquo;cat&rdquo;, or &ldquo;party&rdquo;&hellip;"
                           aria-describedby="search-tip"
                           autocomplete="off" autocapitalize="off" spellcheck="false"
                           @keydown.escape.prevent="clearSearch" />
                    <button v-if="searchQuery" type="button" class="clear-btn" @click="clearSearch" aria-label="Clear search">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
                    </button>
                    <span v-else class="kbd-hint" aria-hidden="true"><kbd>{{ kbdHint }}</kbd></span>
                </div>
                <button type="button" class="btn btn-secondary surprise" @click="surpriseMe">
                    <span class="die" aria-hidden="true">&#127922;</span> Surprise me
                </button>
            </div>
            <p class="sr-only" id="search-tip">Press Control+K, or Command+K on Mac, to jump to search. Escape clears it.</p>
        </section>

        <!-- ===== Categories ===== -->
        <section v-if="!appliedQuery" class="step" aria-labelledby="h-cats">
            <h2 class="step-label sr-only" id="h-cats">Browse by category</h2>
            <div class="cats" role="group" aria-label="Emoji categories">
                <button v-for="g in availableGroups" :key="g" type="button" class="cat"
                        :aria-pressed="selectedGroup === g ? 'true' : 'false'"
                        @click="setGroup(g)">
                    <span class="ico" aria-hidden="true">{{ catIcon(g) }}</span>{{ catLabel(g) }}
                </button>
            </div>
        </section>

        <!-- ===== Recently used ===== -->
        <section v-if="!appliedQuery && recentEmojis.length" class="step" aria-labelledby="h-recent">
            <div class="row-head">
                <h2 class="step-label" id="h-recent">Recently used</h2>
                <button type="button" class="linkish" @click="clearRecent">Clear this list</button>
            </div>
            <div class="mini-row">
                <button v-for="emoji in recentEmojis" :key="'recent-' + emoji.codes" type="button"
                        class="ebtn mini" :title="'Copy ' + emoji.name"
                        :aria-label="'Copy ' + emoji.name" @click="copyEmoji(emoji)">
                    <span class="glyph" aria-hidden="true">{{ emoji.char }}</span>
                </button>
            </div>
        </section>

        <!-- ===== Popular ===== -->
        <section v-if="!appliedQuery" class="step" aria-labelledby="h-popular">
            <h2 class="step-label" id="h-popular">Popular right now</h2>
            <div class="mini-row">
                <button v-for="emoji in trendingEmojis" :key="'trending-' + emoji.codes" type="button"
                        class="ebtn mini" :title="'Copy ' + emoji.name"
                        :aria-label="'Copy ' + emoji.name" @click="copyEmoji(emoji)">
                    <span class="glyph" aria-hidden="true">{{ emoji.char }}</span>
                </button>
            </div>
        </section>

        <!-- ===== The grid ===== -->
        <section class="step" aria-labelledby="h-browse">
            <div class="row-head">
                <h2 class="step-label" id="h-browse" tabindex="-1">{{ browseHeading }}</h2>
                <span class="counter">{{ countLine }}</span>
            </div>

            <div v-if="filteredEmojis.length === 0" class="code-empty">
                <span class="big" aria-hidden="true">&#128533;</span>
                No emoji match &ldquo;{{ appliedQuery }}&rdquo;.<br />
                Try a different word, or
                <button type="button" class="linkish" style="font-size: inherit;" @click="clearSearch">clear the search</button>
                and browse by category.
            </div>

            <div v-else class="egrid">
                <button v-for="emoji in displayedEmojis" :key="emoji.codes" type="button"
                        class="ebtn" :title="'Copy ' + emoji.name"
                        :aria-label="'Copy ' + emoji.name" @click="copyEmoji(emoji)">
                    <span class="glyph" aria-hidden="true">{{ emoji.char }}</span>
                    <span class="ename" aria-hidden="true">{{ emoji.name }}</span>
                </button>
            </div>

            <div v-if="remainingCount > 0" class="load-wrap">
                <button type="button" class="btn btn-secondary" @click="loadMore">
                    {{ remainingCount > 120 ? 'Show 120 more' : 'Show the last ' + remainingCount }}
                    <span v-if="remainingCount > 120">&middot; {{ remainingCount.toLocaleString() }} left</span>
                </button>
            </div>
        </section>

        <p class="foot">Everything happens in your browser — clicking an emoji just copies it to your clipboard.</p>

        <!-- Copied toast (announced separately for screen readers) -->
        <transition name="toast">
            <div v-if="toastVisible" class="toast" aria-hidden="true">
                <span class="glyph">{{ toastChar }}</span>
                <span class="tname">{{ toastPhrase }}</span>
            </div>
        </transition>
    </main>
{% endraw %}

    {% include footer.liquid %}

    <script>
        const { createApp } = Vue;

        const EMOJI_DATA = {{ emojis | json }};
        // Precompute the search haystack once, then freeze — frozen objects are
        // skipped by Vue's reactivity, which keeps a 5,000-item list snappy.
        for (let i = 0; i < EMOJI_DATA.length; i++) {
            const e = EMOJI_DATA[i];
            e.q = (e.name + ' ' + e.group + ' ' + (e.subgroup || '')).toLowerCase();
            Object.freeze(e);
        }
        Object.freeze(EMOJI_DATA);

        // Most-copied emoji, by Unicode code point.
        const TRENDING = ['1F602', '2764', '1F60D', '1F923', '1F44D', '1F618',
                          '1F970', '1F525', '1F4AF', '1F389', '1F440', '2728'];

        const GROUP_META = {
            all: { icon: '\u{1F31F}', label: 'All' },
            'Smileys & Emotion': { icon: '\u{1F600}', label: 'Smileys' },
            'People & Body': { icon: '\u{1F44B}', label: 'People' },
            'Animals & Nature': { icon: '\u{1F43B}', label: 'Animals & nature' },
            'Food & Drink': { icon: '\u{1F355}', label: 'Food & drink' },
            'Travel & Places': { icon: '✈️', label: 'Travel & places' },
            Activities: { icon: '⚽', label: 'Activities' },
            Objects: { icon: '\u{1F4A1}', label: 'Objects' },
            Symbols: { icon: '❤️', label: 'Symbols' },
            Flags: { icon: '\u{1F3C1}', label: 'Flags' },
            Component: { icon: '\u{1F590}️', label: 'Skin tones & hair' }
        };

        const RECENT_KEY = 'recentEmojis';
        const PAGE_SIZE = 120;

        // Visible toast wording rotates for fun; the aria-live announcement
        // stays consistent ("Copied {name} to clipboard.") so screen-reader
        // users always get the same reliable feedback.
        const COPY_PHRASES = ['Copied ✓', 'Snagged ✓', 'Yours ✓', 'In the clipboard ✓'];

        createApp({
            data() {
                return {
                    allEmojis: EMOJI_DATA,
                    searchQuery: '',
                    appliedQuery: '',
                    selectedGroup: 'all',
                    displayLimit: PAGE_SIZE,
                    recentEmojis: [],
                    announcement: '',
                    toastVisible: false,
                    toastChar: '',
                    toastPhrase: '',
                    phraseIndex: 0,
                    toastTimer: null,
                    searchTimer: null,
                    kbdHint: /Mac|iPhone|iPad|iPod/.test(navigator.platform || '') ? '⌘K' : 'Ctrl K'
                };
            },
            watch: {
                searchQuery() {
                    if (this.searchTimer) clearTimeout(this.searchTimer);
                    this.searchTimer = setTimeout(() => this.applySearch(), 250);
                }
            },
            computed: {
                totalFormatted() {
                    return this.allEmojis.length.toLocaleString();
                },
                availableGroups() {
                    // Data order is Unicode's standard category order; the
                    // building-block "Component" group goes last.
                    const seen = [];
                    for (const e of this.allEmojis) {
                        if (e.group && !seen.includes(e.group)) seen.push(e.group);
                    }
                    const rest = seen.filter(g => g !== 'Component');
                    if (seen.includes('Component')) rest.push('Component');
                    return ['all'].concat(rest);
                },
                filteredEmojis() {
                    const q = this.appliedQuery.toLowerCase();
                    if (q) {
                        const words = q.split(/\s+/).filter(Boolean);
                        const list = this.allEmojis.filter(e => words.every(w => e.q.includes(w)));
                        // Best name matches first: exact, then starts-with, then contains.
                        list.sort((a, b) => {
                            const an = a.name.toLowerCase();
                            const bn = b.name.toLowerCase();
                            if ((an === q) !== (bn === q)) return an === q ? -1 : 1;
                            if (an.startsWith(q) !== bn.startsWith(q)) return an.startsWith(q) ? -1 : 1;
                            if (an.includes(q) !== bn.includes(q)) return an.includes(q) ? -1 : 1;
                            return 0;
                        });
                        return list;
                    }
                    if (this.selectedGroup !== 'all') {
                        return this.allEmojis.filter(e => e.group === this.selectedGroup);
                    }
                    return this.allEmojis;
                },
                displayedEmojis() {
                    return this.filteredEmojis.slice(0, this.displayLimit);
                },
                trendingEmojis() {
                    return this.allEmojis.filter(e => TRENDING.includes(e.codes)).slice(0, 12);
                },
                remainingCount() {
                    return Math.max(0, this.filteredEmojis.length - this.displayedEmojis.length);
                },
                browseHeading() {
                    if (this.appliedQuery) return 'Search results';
                    if (this.selectedGroup === 'all') return 'All emoji';
                    return this.catLabel(this.selectedGroup);
                },
                countLine() {
                    const total = this.filteredEmojis.length;
                    if (total === 0) return '';
                    const shown = this.displayedEmojis.length;
                    let line = shown < total
                        ? 'Showing ' + shown.toLocaleString() + ' of ' + total.toLocaleString() + ' emoji'
                        : total.toLocaleString() + ' emoji';
                    if (this.appliedQuery) line += ' for “' + this.appliedQuery + '”';
                    return line;
                }
            },
            mounted() {
                this.loadRecent();

                // Restore a shared/bookmarked search from the address bar.
                const params = new URLSearchParams(window.location.search);
                const q = (params.get('q') || '').trim();
                if (q) {
                    this.searchQuery = q;
                    if (this.searchTimer) clearTimeout(this.searchTimer);
                    this.appliedQuery = q;
                }

                this.keyHandler = (e) => {
                    if ((e.ctrlKey || e.metaKey) && e.key.toLowerCase() === 'k') {
                        e.preventDefault();
                        this.$refs.searchInput.focus();
                    }
                };
                document.addEventListener('keydown', this.keyHandler);
            },
            beforeUnmount() {
                document.removeEventListener('keydown', this.keyHandler);
            },
            methods: {
                catLabel(g) {
                    return GROUP_META[g] ? GROUP_META[g].label : g;
                },
                catIcon(g) {
                    return GROUP_META[g] ? GROUP_META[g].icon : '\u{1F4C1}';
                },
                announce(msg) {
                    this.announcement = '';
                    this.$nextTick(() => { this.announcement = msg; });
                },
                applySearch() {
                    const q = this.searchQuery.trim();
                    if (q === this.appliedQuery) return;
                    this.appliedQuery = q;
                    this.displayLimit = PAGE_SIZE;
                    this.syncUrl();
                    if (q) {
                        const n = this.filteredEmojis.length;
                        this.announce(n === 0
                            ? 'No emoji match ' + q + '.'
                            : n.toLocaleString() + ' emoji found for ' + q + '.');
                    } else {
                        this.announce('Search cleared. Showing all emoji.');
                    }
                },
                syncUrl() {
                    const url = new URL(window.location);
                    if (this.appliedQuery) {
                        url.searchParams.set('q', this.appliedQuery);
                    } else {
                        url.searchParams.delete('q');
                    }
                    window.history.replaceState({}, '', url);
                },
                clearSearch() {
                    if (this.searchTimer) clearTimeout(this.searchTimer);
                    this.searchQuery = '';
                    this.applySearch();
                    this.$refs.searchInput.focus();
                },
                setGroup(g) {
                    this.selectedGroup = g;
                    this.displayLimit = PAGE_SIZE;
                    this.announce(this.catLabel(g) + ' — ' + this.filteredEmojis.length.toLocaleString() + ' emoji.');
                },
                loadMore() {
                    this.displayLimit += PAGE_SIZE;
                    this.announce('Now showing ' + this.displayedEmojis.length.toLocaleString()
                        + ' of ' + this.filteredEmojis.length.toLocaleString() + ' emoji.');
                    // If that was the last batch the button disappears — keep
                    // keyboard focus on the page instead of dropping it.
                    if (this.remainingCount === 0) {
                        this.$nextTick(() => {
                            const h = document.getElementById('h-browse');
                            if (h) h.focus();
                        });
                    }
                },
                async copyEmoji(emoji) {
                    let ok = false;
                    try {
                        await Promise.race([
                            navigator.clipboard.writeText(emoji.char),
                            new Promise((_, reject) => setTimeout(() => reject(new Error('timeout')), 1500))
                        ]);
                        ok = true;
                    } catch {
                        ok = this.fallbackCopy(emoji.char);
                    }
                    if (ok) {
                        this.showToast(emoji);
                        this.addToRecent(emoji);
                        this.announce('Copied ' + emoji.name + ' to clipboard.');
                    } else {
                        this.announce('Sorry — copying didn’t work in this browser.');
                    }
                },
                fallbackCopy(text) {
                    const ta = document.createElement('textarea');
                    ta.value = text;
                    ta.style.position = 'fixed';
                    ta.style.opacity = '0';
                    document.body.appendChild(ta);
                    ta.focus();
                    ta.select();
                    let ok = false;
                    try { ok = document.execCommand('copy'); } catch { ok = false; }
                    document.body.removeChild(ta);
                    return ok;
                },
                showToast(emoji) {
                    this.toastChar = emoji.char;
                    this.toastPhrase = COPY_PHRASES[this.phraseIndex % COPY_PHRASES.length];
                    this.phraseIndex++;
                    this.toastVisible = true;
                    if (this.toastTimer) clearTimeout(this.toastTimer);
                    this.toastTimer = setTimeout(() => { this.toastVisible = false; }, 1800);
                },
                surpriseMe() {
                    // Random pick from the full set; copyEmoji handles the toast,
                    // the recents list, and the live-region announcement.
                    const pick = this.allEmojis[Math.floor(Math.random() * this.allEmojis.length)];
                    this.copyEmoji(pick);
                },
                addToRecent(emoji) {
                    const entry = {
                        codes: emoji.codes, char: emoji.char, name: emoji.name,
                        group: emoji.group, subgroup: emoji.subgroup
                    };
                    this.recentEmojis = [entry]
                        .concat(this.recentEmojis.filter(e => e.codes !== emoji.codes))
                        .slice(0, 12);
                    this.saveRecent();
                },
                loadRecent() {
                    try {
                        const saved = JSON.parse(localStorage.getItem(RECENT_KEY) || '[]');
                        if (Array.isArray(saved)) {
                            this.recentEmojis = saved
                                .filter(e => e && e.codes && e.char && e.name)
                                .slice(0, 12);
                        }
                    } catch {
                        this.recentEmojis = [];
                    }
                },
                saveRecent() {
                    try {
                        localStorage.setItem(RECENT_KEY, JSON.stringify(this.recentEmojis));
                    } catch { /* private mode — recents just won't persist */ }
                },
                clearRecent() {
                    this.recentEmojis = [];
                    this.saveRecent();
                    this.announce('Recently used list cleared.');
                }
            }
        }).mount('#app');
    </script>
</body>
</html>
