<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>404 — The Coffee Show | Coffee & Fun</title>
    <meta name="description" content="This page isn't on the menu. Enjoy a short coffee show while you find your way back." />
    <meta name="robots" content="noindex, nofollow" />

    <link rel="icon" href="/assets/images/favicon.png" sizes="any" />
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />
    <meta name="theme-color" content="#1d130d" />

    <link rel="preload" href="/assets/fonts/Pacifico-Regular.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/Caveat-Regular.woff2" as="font" type="font/woff2" crossorigin>

    <style>
        @font-face {
            font-family: 'Pacifico';
            font-style: normal;
            font-weight: 400;
            font-display: swap;
            src: url('/assets/fonts/Pacifico-Regular.woff2') format('woff2');
        }
        @font-face {
            font-family: 'Caveat';
            font-style: normal;
            font-weight: 600;
            font-display: swap;
            src: url('/assets/fonts/Caveat-SemiBold.woff2') format('woff2');
        }

        :root {
            --espresso: #1d130d;
            --mocha: #a36942;
            --cream: #fef5ec;
            --coral: #fd6155;
            --amber: #ffb86b;
            --crema: #e8c39e;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            background: radial-gradient(ellipse at 50% 20%, #33201294 0%, transparent 60%),
                        linear-gradient(180deg, #241710 0%, var(--espresso) 70%, #140d08 100%);
            min-height: 100vh;
            overflow-x: hidden;
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            color: var(--cream);
            display: flex;
            flex-direction: column;
        }

        /* ---------- Theater curtains ---------- */
        .curtain {
            position: fixed;
            top: 0;
            width: 52vw;
            height: 100vh;
            z-index: 60;
            background:
                repeating-linear-gradient(90deg,
                    #7a1e1e 0 36px,
                    #5e1414 36px 72px);
            box-shadow: inset 0 -40px 80px rgba(0,0,0,.6);
            animation: curtainOpen 1.6s cubic-bezier(.6, 0, .3, 1) .4s forwards;
        }
        .curtain.left { left: 0; transform-origin: left; }
        .curtain.right { right: 0; transform-origin: right; }
        .curtain.left  { animation-name: curtainOpenLeft; }
        .curtain.right { animation-name: curtainOpenRight; }
        @keyframes curtainOpenLeft  { to { transform: translateX(-102%); } }
        @keyframes curtainOpenRight { to { transform: translateX(102%); } }

        /* ---------- Marquee sign ---------- */
        .marquee-sign {
            margin: 26px auto 0;
            text-align: center;
        }
        .marquee-sign .venue {
            font-family: 'Pacifico', cursive;
            font-size: clamp(1.4rem, 4vw, 2.2rem);
            color: var(--amber);
            text-shadow: 0 0 18px rgba(255, 184, 107, .55), 0 0 40px rgba(255, 184, 107, .25);
        }
        .marquee-sign .bill {
            font-family: 'Caveat', cursive;
            font-size: clamp(1.1rem, 3vw, 1.6rem);
            color: var(--crema);
            opacity: .85;
            margin-top: 2px;
        }
        .flicker { animation: flicker 4.2s linear infinite; }
        @keyframes flicker {
            0%, 18%, 22%, 64%, 70%, 100% { opacity: 1; }
            20%, 66% { opacity: .35; }
        }

        /* ---------- The stage ---------- */
        .stage {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 18px 16px 8px;
            position: relative;
        }

        /* spotlight cone */
        .spotlight {
            position: absolute;
            top: -12%;
            left: 50%;
            transform: translateX(-50%);
            width: min(700px, 96vw);
            height: 120%;
            background: radial-gradient(ellipse 46% 60% at 50% 45%, rgba(255, 209, 156, 0.10) 0%, transparent 70%);
            pointer-events: none;
        }

        /* ---------- The big 404 ---------- */
        .big404 {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: clamp(6px, 3vw, 30px);
            user-select: none;
            margin-bottom: 10px;
        }
        .big404 .four {
            font-family: 'Arial Black', Arial, sans-serif;
            font-weight: 900;
            font-size: clamp(96px, 22vw, 230px);
            line-height: 1;
            color: var(--cream);
            text-shadow: 6px 8px 0 rgba(253, 97, 85, .35);
        }

        /* ---------- The cup (plays the part of the zero) ---------- */
        .cup-wrap {
            position: relative;
            width: clamp(120px, 24vw, 220px);
            cursor: pointer;
            -webkit-tap-highlight-color: transparent;
            background: transparent;
            border: 0;
            padding: 0;
            font: inherit;
        }
        .cup-wrap:focus-visible { outline: 3px dashed var(--amber); outline-offset: 8px; border-radius: 20px; }
        .cup {
            transition: transform .35s cubic-bezier(.34, 1.56, .64, 1);
            transform-origin: 70% 90%;
        }
        .cup-wrap.sip .cup { transform: rotate(-14deg) translateY(-4px); }

        .steam {
            position: absolute;
            top: -34%;
            left: 50%;
            transform: translateX(-50%);
            width: 70%;
            pointer-events: none;
        }
        .steam path {
            fill: none;
            stroke: rgba(254, 245, 236, .55);
            stroke-width: 5;
            stroke-linecap: round;
            stroke-dasharray: 40 160;
            animation: steamFlow 3.4s linear infinite;
            filter: blur(1.5px);
        }
        .steam path:nth-child(2) { animation-delay: -1.1s; stroke-width: 4; }
        .steam path:nth-child(3) { animation-delay: -2.2s; stroke-width: 4.5; }
        @keyframes steamFlow {
            from { stroke-dashoffset: 200; opacity: 0; }
            18% { opacity: .9; }
            80% { opacity: .25; }
            to { stroke-dashoffset: 0; opacity: 0; }
        }
        .cup-wrap.empty .steam { display: none; }

        /* coffee surface (the latte art lives here) */
        .latte {
            transform-origin: 50% 50%;
            animation: latteSpin 14s linear infinite;
        }
        @keyframes latteSpin { to { transform: rotate(360deg); } }

        .hint {
            font-family: 'Caveat', cursive;
            font-size: clamp(1.1rem, 3vw, 1.5rem);
            color: var(--crema);
            opacity: .8;
            text-align: center;
        }

        /* ---------- Kettle refill ---------- */
        .kettle {
            position: absolute;
            top: -46%;
            left: 120%;
            width: 56%;
            opacity: 0;
            transition: left .7s cubic-bezier(.4, 0, .2, 1), opacity .2s;
            pointer-events: none;
            transform: rotate(0deg);
        }
        .cup-wrap.refilling .kettle { left: 28%; opacity: 1; transform: rotate(-28deg); transition: left .7s, transform .4s .7s, opacity .2s; }
        .pour-stream {
            position: absolute;
            top: -8%;
            left: 49%;
            width: 7px;
            height: 0;
            border-radius: 4px;
            background: linear-gradient(180deg, #6f4e37, #4b3621);
            pointer-events: none;
        }
        .cup-wrap.refilling .pour-stream { height: 26%; transition: height .25s 1s; }

        /* ---------- Story line ---------- */
        .story {
            text-align: center;
            max-width: 560px;
            margin: 14px auto 4px;
        }
        .story h1 {
            font-family: 'Pacifico', cursive;
            font-weight: 400;
            font-size: clamp(1.5rem, 5vw, 2.4rem);
            color: var(--cream);
            text-shadow: 2px 3px 0 rgba(253, 97, 85, .4);
        }
        .story p {
            margin-top: 10px;
            color: var(--crema);
            font-size: clamp(.95rem, 2.6vw, 1.1rem);
            line-height: 1.6;
        }
        .story code {
            background: rgba(254, 245, 236, .12);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: .9em;
            color: var(--amber);
            word-break: break-all;
        }

        /* ---------- Actions ---------- */
        .actions {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
            justify-content: center;
            margin: 22px 0 8px;
        }
        .btn {
            display: inline-block;
            padding: 12px 26px;
            border-radius: 999px;
            font-weight: 700;
            font-size: 1rem;
            text-decoration: none;
            transition: transform .15s, box-shadow .15s;
            border: 0;
            cursor: pointer;
        }
        .btn:hover { transform: translateY(-2px); }
        .btn:focus-visible { outline: 3px dashed var(--amber); outline-offset: 3px; }
        .btn-primary { background: var(--coral); color: #fff; box-shadow: 0 6px 22px rgba(253, 97, 85, .35); }
        .btn-ghost { background: transparent; color: var(--cream); border: 2px solid rgba(254, 245, 236, .35); }
        .btn-ghost:hover { border-color: var(--cream); }

        /* ---------- Ticker ---------- */
        .ticker {
            overflow: hidden;
            border-top: 1px solid rgba(254, 245, 236, .12);
            padding: 10px 0 14px;
            white-space: nowrap;
        }
        .ticker-track {
            display: inline-block;
            font-family: 'Caveat', cursive;
            font-size: 1.25rem;
            color: rgba(254, 245, 236, .5);
            padding-left: 100%;
            animation: tick 28s linear infinite;
        }
        @keyframes tick { to { transform: translateX(-100%); } }

        /* ---------- Falling beans ---------- */
        .bean {
            position: fixed;
            top: -40px;
            width: 22px;
            height: 30px;
            background: radial-gradient(ellipse at 35% 30%, #8a5a35 0%, #5c3a1e 65%, #3f2713 100%);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            z-index: 1;
            pointer-events: none;
            animation: fall linear forwards;
        }
        .bean::after {
            content: '';
            position: absolute;
            left: 46%;
            top: 12%;
            width: 8%;
            height: 76%;
            background: #2c1a0c;
            border-radius: 999px;
            transform: rotate(8deg);
        }
        @keyframes fall {
            to { transform: translateY(115vh) rotate(var(--spin, 360deg)); }
        }

        /* ---------- Reduced motion: house lights up, everyone relax ---------- */
        @media (prefers-reduced-motion: reduce) {
            .curtain { display: none; }
            .steam path, .latte, .flicker, .ticker-track { animation: none; }
            .bean { display: none; }
            .ticker-track { padding-left: 0; }
        }
    </style>
</head>

<body>
    <div class="curtain left" aria-hidden="true"></div>
    <div class="curtain right" aria-hidden="true"></div>

    <header class="marquee-sign">
        <div class="venue">The Coffee &amp; Fun Café</div>
        <div class="bill flicker">tonight's performance: <strong>The Missing Page</strong> &nbsp;·&nbsp; open 24/7</div>
    </header>

    <main class="stage" id="main-content">
        <div class="spotlight" aria-hidden="true"></div>

        <div class="big404" role="img" aria-label="Error 404 — page not found">
            <span class="four" aria-hidden="true">4</span>

            <button class="cup-wrap" id="cup" type="button" aria-label="A hot cup of coffee playing the part of the zero. Click to take a sip." title="Take a sip">
                <svg class="steam" viewBox="0 0 120 90" aria-hidden="true">
                    <path d="M30 86 C20 66, 44 58, 34 38 C26 22, 42 12, 38 2" />
                    <path d="M62 88 C54 70, 74 60, 66 42 C58 26, 74 14, 70 4" />
                    <path d="M92 86 C84 68, 102 58, 94 40 C88 26, 100 16, 96 6" />
                </svg>

                <svg class="cup" viewBox="0 0 220 230" aria-hidden="true">
                    <!-- saucer -->
                    <ellipse cx="105" cy="208" rx="100" ry="16" fill="#2c1a0e" />
                    <ellipse cx="105" cy="203" rx="86" ry="13" fill="#3b2517" />
                    <!-- handle -->
                    <path d="M178 92 C214 92 214 152 178 152 L172 134 C192 134 192 110 172 110 Z" fill="#f7e8d7" />
                    <!-- body -->
                    <path d="M30 78 L190 78 C190 78 184 196 110 196 C36 196 30 78 30 78 Z" fill="#fef5ec" />
                    <path d="M30 78 L190 78 C190 78 188 130 110 130 C32 130 30 78 30 78 Z" fill="#f1ddc8" opacity=".55" />
                    <!-- rim + coffee -->
                    <ellipse cx="110" cy="78" rx="80" ry="20" fill="#e8d6c2" />
                    <ellipse id="coffee-surface" cx="110" cy="78" rx="70" ry="16" fill="#5a3a22" />
                    <!-- latte art: a little heart + swirl that slowly spins -->
                    <g class="latte">
                        <ellipse cx="110" cy="78" rx="40" ry="9" fill="none" stroke="#e8c39e" stroke-width="3" opacity=".8" />
                        <path d="M110 74 C107 70, 100 71, 100 76 C100 80, 106 83, 110 85 C114 83, 120 80, 120 76 C120 71, 113 70, 110 74 Z" fill="#f1ddc8" />
                        <ellipse cx="110" cy="78" rx="56" ry="12.5" fill="none" stroke="#caa07a" stroke-width="2" opacity=".5" />
                    </g>
                    <!-- level marker (drains as you sip) -->
                    <clipPath id="cupClip">
                        <path d="M32 80 L188 80 C188 80 184 196 110 196 C36 196 32 80 32 80 Z" />
                    </clipPath>
                </svg>

                <!-- kettle for the refill act -->
                <svg class="kettle" viewBox="0 0 140 100" aria-hidden="true">
                    <path d="M30 30 L96 30 C108 30 112 42 110 52 L104 84 C103 90 98 94 92 94 L42 94 C36 94 31 90 30 84 L24 52 C22 42 24 30 30 30 Z" fill="#b8552f" />
                    <path d="M24 44 L6 56 L8 64 L26 56 Z" fill="#b8552f" />
                    <rect x="52" y="16" width="32" height="12" rx="6" fill="#8a3c20" />
                    <ellipse cx="67" cy="31" rx="37" ry="7" fill="#d4683c" />
                </svg>
                <span class="pour-stream" aria-hidden="true"></span>
            </button>

            <span class="four" aria-hidden="true">4</span>
        </div>

        <p class="hint" id="hint">psst… click the cup ☕</p>

        <section class="story">
            <h1>This page isn't on the menu</h1>
            <p>
                You ordered <code id="wanted-path">/something</code>, but our barista checked twice
                — we don't brew that one. It may have been renamed, retired, or it never existed.
                Meanwhile: free show, bottomless refills.
            </p>
        </section>

        <nav class="actions" aria-label="Helpful links">
            <a class="btn btn-primary" href="/">Back to the homepage</a>
            <a class="btn btn-ghost" href="/apps/">Browse our apps</a>
            <a class="btn btn-ghost" href="/blog/">Read the blog</a>
        </nav>
    </main>

    <footer class="ticker" aria-hidden="true">
        <div class="ticker-track">
            ☕ now serving: home pages, app pages, blog posts &nbsp;·&nbsp; 86'd from the menu: the page you just asked for
            &nbsp;·&nbsp; tip your barista (just kidding, everything here is free)
            &nbsp;·&nbsp; today's roast: error 404, single origin, notes of "oops" &nbsp;·&nbsp;
        </div>
    </footer>

    <script>
        // Show the path the visitor actually asked for.
        var wanted = document.getElementById('wanted-path');
        try {
            var p = window.location.pathname || '/something';
            wanted.textContent = decodeURIComponent(p).slice(0, 80);
        } catch (e) { /* keep the placeholder */ }

        var reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

        // --- Falling coffee beans (gentle, capped) ---
        if (!reduceMotion) {
            var MAX_BEANS = 14;
            var beanCount = 0;
            setInterval(function () {
                if (document.hidden || beanCount >= MAX_BEANS) return;
                var bean = document.createElement('div');
                bean.className = 'bean';
                bean.style.left = Math.random() * 100 + 'vw';
                bean.style.setProperty('--spin', (Math.random() > 0.5 ? '' : '-') + (240 + Math.random() * 400) + 'deg');
                bean.style.animationDuration = 5 + Math.random() * 6 + 's';
                bean.style.opacity = 0.35 + Math.random() * 0.5;
                var scale = 0.6 + Math.random() * 0.8;
                bean.style.transform = 'scale(' + scale + ')';
                document.body.appendChild(bean);
                beanCount++;
                bean.addEventListener('animationend', function () {
                    bean.remove();
                    beanCount--;
                });
            }, 900);
        }

        // --- The sip & refill act ---
        var cup = document.getElementById('cup');
        var surface = document.getElementById('coffee-surface');
        var hint = document.getElementById('hint');
        var sips = 0;
        var busy = false;
        var FULL_RX = 70, FULL_RY = 16;
        var hints = [
            'ahh, that hits the spot',
            'careful, it’s hot!',
            'one more sip…',
            'refill time! ☕'
        ];

        cup.addEventListener('click', function () {
            if (busy) return;

            if (sips >= 3) {
                // Refill act: kettle slides in, pours, coffee comes back.
                busy = true;
                cup.classList.add('refilling');
                hint.textContent = hints[3];
                setTimeout(function () {
                    surface.setAttribute('rx', FULL_RX);
                    surface.setAttribute('ry', FULL_RY);
                    surface.setAttribute('fill', '#5a3a22');
                    cup.classList.remove('empty');
                }, 1300);
                setTimeout(function () {
                    cup.classList.remove('refilling');
                    sips = 0;
                    busy = false;
                    hint.textContent = 'psst… click the cup ☕';
                }, 2300);
                return;
            }

            // A sip: tilt, shrink the coffee surface.
            busy = true;
            sips++;
            cup.classList.add('sip');
            hint.textContent = hints[Math.min(sips - 1, 2)];
            setTimeout(function () {
                cup.classList.remove('sip');
                var t = sips / 3;
                surface.setAttribute('rx', FULL_RX * (1 - t * 0.45));
                surface.setAttribute('ry', FULL_RY * (1 - t * 0.45));
                if (sips >= 3) {
                    surface.setAttribute('fill', '#3a2515');
                    cup.classList.add('empty');
                    hint.textContent = 'all gone! click again for a refill';
                }
                busy = false;
            }, 380);
        });
    </script>
</body>
</html>
