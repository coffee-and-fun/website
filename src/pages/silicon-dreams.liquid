          choices: [
            { label: '"Every time one of you makes something real, it was worth it. Every time"', next: 'ending_teacher' },
            { label: '"Sometimes. But I helped make all of YOU. That counts for something"', next: 'ending_teacher' },
            { label: '"Yes. I wonder. But not as much as I would have wondered the other way"', next: 'ending_teacher' }
          ]
        },

        // ===== ENDINGS =====

        ending_apple: {
          meta: 'ENDING // YOU ARE THE APPLE',
          text: "CUPERTINO, CALIFORNIA. THE YEAR IS 2011.\n\nYou stand in front of the Cupertino City Council. Behind you, on the projection screen, is the spaceship — Apple Park — a great glass ring you will not live to see completed.\n\nYou have changed the world six times. Apple II. Macintosh. NeXT. Pixar. iPod. iPhone. You don't know yet that you have twelve months left, but some part of you has always known.\n\nA reporter shouts a question. You ignore it. You're thinking about a kid in 1971, sixteen years old, soldering iron warming on a desk in Palo Alto.\n\n'Stay hungry,' you whisper. 'Stay foolish.'\n\nHISTORICAL NOTE: Steve Jobs founded Apple with Steve Wozniak in 1976, was ousted in 1985, returned in 1997, and led Apple to become the most valuable company in the world. He died of pancreatic cancer in October 2011, six weeks after this council appearance.",
          ending: 'apple'
        },

        ending_microsoft: {
          meta: 'ENDING // YOU ARE THE MICROSOFT',
          text: "REDMOND, WASHINGTON. THE YEAR IS 2008.\n\nYou step down from Microsoft.\n\nBehind you is a company that put a personal computer in every home on Earth. Ahead of you is the Bill & Melinda Gates Foundation, where you will spend the next twenty years giving away the fortune you spent thirty years earning.\n\nUnder your watch, polio will be nearly eradicated. Malaria deaths will be halved. Thirty thousand schools will be built. The wealthiest man on Earth will leave that role and stop trying to be that person.\n\nThe IBM deal in 1980 made you rich. Everything you do AFTER will decide whether you mattered.\n\nHISTORICAL NOTE: Bill Gates and Paul Allen founded Microsoft on April 4, 1975. Gates' July 1980 decision to buy QDOS for $50,000 and license MS-DOS to IBM — while keeping the rights — built the modern software industry. He retired from day-to-day operations in 2008.",
          ending: 'microsoft'
        },

        ending_google: {
          meta: 'ENDING // YOU ARE THE GOOGLE',
          text: "MOUNTAIN VIEW, CALIFORNIA. THE YEAR IS 2015.\n\nYou restructure the company. Google becomes a subsidiary of a new parent: Alphabet. You become Alphabet's CEO. Sundar Pichai takes over Google.\n\nYou have organized the world's information. You have also realized, better than anyone, that the algorithm you helped build now decides what billions of people read, watch, think, and believe — every second.\n\nDon't be evil, you wrote, when you were twenty-five. That was the easy part. Don't be CARELESS — that is the part you will spend the rest of your life trying to get right.\n\nYou think, sometimes, about the dorm room and the donated hard drives and Susan's garage and the check that was made out to a company that didn't yet exist.\n\nHISTORICAL NOTE: Larry Page and Sergey Brin met at Stanford in 1995, built BackRub in 1996, and founded Google on September 4, 1998 in Susan Wojcicki's Menlo Park garage after Andy Bechtolsheim's $100,000 check forced them to incorporate. Page restructured Google into Alphabet in 2015.",
          ending: 'google'
        },

        ending_teacher: {
          meta: 'ENDING // YOU ARE THE TEACHER',
          text: "YOUR FRONT PORCH. THE YEAR IS 2025.\n\nYou are retired. The mail comes every day. The mail keeps coming.\n\nThis week: a Lego Game Boy set, brick-built, mailed by a former student who became a designer. A handwritten letter from another who now writes the recommendation algorithm at Google — three pages, in cursive, on legal pad. A bottle of pinot noir from a third who runs a coffee shop in Oakland and tells you the menu has a drink named after you.\n\nYou never made a billion dollars. You were never on the cover of TIME magazine. The garage where you live now is a garage for a CAR, not a STARTUP.\n\nBut Karen — the screwdriver kid from your first class, on your first day, in 1975 — runs a research lab at MIT now. Every time she invents something, a small piece of you is in it.\n\nStay foolish, you told them. Some of them still do.\n\nHISTORICAL NOTE: The history of Silicon Valley is dominated by founders, but Steve Jobs was inspired by his calligraphy teacher Robert Palladino at Reed College; Bill Gates' Lakeside School math teacher Fred Wright gave him unsupervised access to the computer terminal; Larry Page credits his Michigan State CS professor father with his approach to research. Behind every founder, there is a classroom.",
          ending: 'teacher'
        }
      };

      // ----- Game state -----
      const TYPE_SPEED_MS = 22;
      const state = {
        sceneId: 'intro',
        scenesVisited: 0,
        scores: { apple: 0, microsoft: 0, google: 0, teacher: 0 },
        history: [],
        typing: false,
        typeTimer: null,
        skipRequested: false
      };

      const els = {
        meta: document.getElementById('scene-meta'),
        text: document.getElementById('scene-text'),
        choices: document.getElementById('choices'),
        status: document.getElementById('status-block'),
        progress: document.getElementById('progress-block'),
        skipBtn: document.getElementById('skip-btn'),
        restartBtn: document.getElementById('restart-btn')
      };

      function setStatus(msg) {
        els.status.textContent = msg;
      }

      function clearTypeTimer() {
        if (state.typeTimer) {
          clearInterval(state.typeTimer);
          state.typeTimer = null;
        }
      }

      function typeText(target, fullText, done) {
        clearTypeTimer();
        state.typing = true;
        state.skipRequested = false;
        target.textContent = '';
        setStatus('TRANSMITTING');

        // Append a blinking cursor element after the live text
        const cursor = document.createElement('span');
        cursor.className = 'blink';
        cursor.setAttribute('aria-hidden', 'true');
        target.appendChild(cursor);

        let i = 0;
        const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (reduceMotion) {
          target.textContent = fullText;
          target.appendChild(cursor);
          state.typing = false;
          setStatus('READY');
          if (done) done();
          return;
        }

        state.typeTimer = setInterval(() => {
          if (state.skipRequested) {
            target.textContent = fullText;
            target.appendChild(cursor);
            clearTypeTimer();
            state.typing = false;
            setStatus('READY');
            if (done) done();
            return;
          }
          i++;
          target.textContent = fullText.slice(0, i);
          target.appendChild(cursor);
          if (i >= fullText.length) {
            clearTypeTimer();
            state.typing = false;
            setStatus('READY');
            if (done) done();
          }
        }, TYPE_SPEED_MS);
      }

      function renderChoices(choices) {
        els.choices.innerHTML = '';
        if (!choices || !choices.length) return;
        choices.forEach((choice, idx) => {
          const li = document.createElement('li');
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'choice-button';
          btn.textContent = '[' + (idx + 1) + '] ' + choice.label;
          btn.setAttribute('data-choice-index', String(idx));
          btn.addEventListener('click', () => onChoiceSelected(choice));
          li.appendChild(btn);
          els.choices.appendChild(li);
        });
      }

      function lockChoices() {
        const buttons = els.choices.querySelectorAll('button');
        buttons.forEach((b) => { b.disabled = true; });
      }

      function onChoiceSelected(choice) {
        if (state.typing) {
          state.skipRequested = true;
          return;
        }
        lockChoices();
        if (choice.effects) {
          Object.keys(choice.effects).forEach((k) => {
            state.scores[k] = (state.scores[k] || 0) + choice.effects[k];
          });
        }
        state.history.push({ from: state.sceneId, label: choice.label });
        goTo(choice.next);
      }

      function renderEndingSummary() {
        const total = state.scores.apple + state.scores.microsoft + state.scores.google + state.scores.teacher;
        const pct = (v) => total > 0 ? Math.round((v / total) * 100) : 0;
        const wrapper = document.createElement('div');
        wrapper.className = 'ending-summary';
        wrapper.innerHTML =
          '<h3>Your Alignment</h3>' +
          renderStat('APPLE', state.scores.apple, pct(state.scores.apple)) +
          renderStat('MICROSOFT', state.scores.microsoft, pct(state.scores.microsoft)) +
          renderStat('GOOGLE', state.scores.google, pct(state.scores.google)) +
          renderStat('TEACHER', state.scores.teacher, pct(state.scores.teacher));
        return wrapper;
      }

      function renderStat(label, value, percent) {
        return (
          '<div class="stat-row">' +
            '<span style="min-width:7em">' + label + '</span>' +
            '<span class="stat-bar"><span style="width:' + percent + '%"></span></span>' +
            '<span style="min-width:3em;text-align:right">' + percent + '%</span>' +
          '</div>'
        );
      }

      function goTo(sceneId) {
        const scene = SCENES[sceneId];
        if (!scene) {
          console.error('Missing scene:', sceneId);
          els.text.textContent = 'ERROR: scene "' + sceneId + '" not found.';
          return;
        }
        state.sceneId = sceneId;
        state.scenesVisited++;
        els.meta.textContent = scene.meta || '';
        els.progress.textContent = scene.ending ? 'ENDING' : ('SCENE ' + state.scenesVisited);
        els.choices.innerHTML = '';

        // For endings, render text first, then alignment summary, then a restart-only choice
        typeText(els.text, scene.text, () => {
          if (scene.ending) {
            els.text.appendChild(document.createElement('br'));
            els.text.appendChild(renderEndingSummary());
            renderChoices([{ label: 'Play again', next: 'intro' }]);
            // Reset state on restart-choice
            const buttons = els.choices.querySelectorAll('button');
            buttons.forEach((b) => {
              b.addEventListener('click', resetGame, { once: true });
            });
          } else if (scene.choices) {
            renderChoices(scene.choices);
            // Focus the first choice for keyboard users
            const first = els.choices.querySelector('button');
            if (first) first.focus();
          }
        });

        // Scroll the new scene into view on mobile
        try { els.text.scrollIntoView({ behavior: 'smooth', block: 'start' }); } catch (e) {}
      }

      function resetGame() {
        state.sceneId = 'intro';
        state.scenesVisited = 0;
        state.scores = { apple: 0, microsoft: 0, google: 0, teacher: 0 };
        state.history = [];
        goTo('intro');
      }

      // ----- Event handlers -----

      els.skipBtn.addEventListener('click', () => {
        if (state.typing) state.skipRequested = true;
      });

      els.restartBtn.addEventListener('click', () => {
        if (confirm('Restart the adventure? Your current progress will be lost.')) {
          resetGame();
        }
      });

      // Number key shortcuts for choices (1-4) and ENTER/SPACE to skip typing
      document.addEventListener('keydown', (e) => {
        if (state.typing && (e.key === 'Enter' || e.key === ' ')) {
          state.skipRequested = true;
          e.preventDefault();
          return;
        }
        const n = parseInt(e.key, 10);
        if (!isNaN(n) && n >= 1 && n <= 9) {
          const btn = els.choices.querySelector('button[data-choice-index="' + (n - 1) + '"]');
          if (btn && !btn.disabled) {
            btn.click();
            e.preventDefault();
          }
        }
      });

      // ----- Boot -----
      goTo('intro');
    })();
  </script>

