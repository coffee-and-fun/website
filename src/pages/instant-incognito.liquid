<!DOCTYPE html>
<html class="brand-color-background scroll-smooth antialiased" lang="en" data-theme="light" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary Meta Tags -->
    <title>Instant Incognito - Auto-Open Sites in Private Mode | Coffee & Fun</title>
    <meta name="title" content="Instant Incognito - Auto-Open Sites in Private Mode | Coffee & Fun" />
    <meta name="description" content="Browser extension that automatically opens specific websites in incognito mode for enhanced privacy. Available for Chrome, Edge, Firefox, and Safari. Keep your browsing private effortlessly." />
    <meta name="keywords" content="incognito mode, private browsing, browser extension, privacy tool, Chrome extension, Safari extension, Coffee and Fun" />
    <meta name="author" content="Coffee & Fun LLC" />
    <meta name="publisher" content="Coffee & Fun LLC" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="rating" content="general" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.coffeeandfun.com/instant-incognito/" />
    <meta property="og:title" content="Instant Incognito - Auto-Open Sites in Private Mode" />
    <meta property="og:description" content="Automatically open specific websites in incognito mode for enhanced privacy. Available for Chrome, Edge, Firefox, and Safari." />
    <meta property="og:image" content="/assets/images/social/pages/instant-incognito.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Instant Incognito browser extension preview" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="/instant-incognito/" />
    <meta name="twitter:title" content="Instant Incognito - Auto-Open Sites in Private Mode" />
    <meta name="twitter:description" content="Automatically open specific websites in incognito mode. Keep your browsing private effortlessly." />
    <meta name="twitter:image" content="/assets/images/social/pages/instant-incognito.png" />
    <meta name="twitter:image:alt" content="Instant Incognito extension" />
    <meta name="twitter:site" content="@bycoffeeandfun" />
    <meta name="twitter:creator" content="@bycoffeeandfun" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/instant-incognito/" />
    
    <!-- Favicon & Icons -->
    <link rel="icon" href="/assets/images/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />
    <link rel="icon" href="/assets/images/social/192.png" sizes="192x192" type="image/png" />
    
    <!-- PWA & Mobile -->
    <link rel="manifest" href="/assets/images/social/site.webmanifest" />
    <meta name="theme-color" content="#fef5ec" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Instant Incognito" />
    
    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Instant Incognito",
        "description": "Browser extension that automatically opens specific websites in incognito mode",
        "url": "https://www.coffeeandfun.com/instant-incognito/",
        "applicationCategory": "BrowserApplication",
        "operatingSystem": "Chrome, Edge, Firefox, Safari",
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.7",
            "ratingCount": "218"
        },
        "creator": {
            "@type": "Organization",
            "name": "Coffee & Fun LLC",
            "url": "https://www.coffeeandfun.com",
            "sameAs": ["https://x.com/bycoffeeandfun"]
        }
    }
    </script>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "What does Instant Incognito do?",
                "acceptedAnswer": { "@type": "Answer", "text": "It automatically opens certain websites in private mode. Add sites to your list, and whenever you visit them, they'll open in incognito automatically — keeping your browsing private without any extra clicks." }
            },
            {
                "@type": "Question",
                "name": "Does Instant Incognito track or store my data?",
                "acceptedAnswer": { "@type": "Answer", "text": "Absolutely not. We don't monitor your browsing activity, your settings stay on your device only, and what you browse is your business alone." }
            },
            {
                "@type": "Question",
                "name": "What permissions does it need?",
                "acceptedAnswer": { "@type": "Answer", "text": "webNavigation to detect when you're navigating to a website, tabs to open and manage incognito tabs automatically, and storage to save your settings locally on your device." }
            },
            {
                "@type": "Question",
                "name": "Is Instant Incognito really free?",
                "acceptedAnswer": { "@type": "Answer", "text": "Yes! The extension is completely free to use with all features unlocked. Donations are welcome but never required." }
            }
        ]
    }
    </script>

    {% bundledCss %}
    {% include scripts.html %}
    
    <!-- Service Worker -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then((registrations) => {
                registrations.forEach(registration => {
                    registration.unregister();
                });
                
                navigator.serviceWorker.register('/service-worker.js')
                    .then(() => console.log('✅ Service worker registered'))
                    .catch((err) => console.error('Service worker error:', err));
            });
        }
    </script>
    {% include sketch-styles.liquid %}
</head>

