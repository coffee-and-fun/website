				"@type": "FAQPage",
				"mainEntity": [
					{
						"@type": "Question",
						"name": "What does ProcrastiNOT do?",
						"acceptedAnswer": { "@type": "Answer", "text": "ProcrastiNOT helps you stay focused by blocking websites you choose, like Facebook or YouTube. If you try to visit a blocked site, it redirects you with a message to refocus, and you'll need to solve a math problem to turn it off." }
					},
