<!DOCTYPE html>
<html class="brand-color-background scroll-smooth antialiased" lang="en" data-theme="light" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary Meta Tags -->
    <title>Hide Spoilers - Browse Without Spoilers | Coffee & Fun</title>
    <meta name="title" content="Hide Spoilers - Browse Without Spoilers | Coffee & Fun" />
    <meta name="description" content="Browser extension that blurs spoilers on any website. Block full phrases, blur text, images, and thumbnails. Available for Chrome and Safari." />
    <meta name="keywords" content="spoiler blocker, hide spoilers, browser extension, Chrome extension, Safari extension, spoiler prevention, Coffee and Fun" />
    <meta name="author" content="Coffee & Fun LLC" />
    <meta name="publisher" content="Coffee & Fun LLC" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="rating" content="general" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="/hide-spoilers-extension/" />
    <meta property="og:title" content="Hide Spoilers - Browse Without Spoilers" />
    <meta property="og:description" content="Browser extension that blurs spoilers on any website. Block full phrases, blur text, images, and thumbnails." />
    <meta property="og:image" content="/assets/images/social/pages/hide-spoilers-extension.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Hide Spoilers browser extension preview" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="/hide-spoilers-extension/" />
    <meta name="twitter:title" content="Hide Spoilers - Browse Without Spoilers" />
    <meta name="twitter:description" content="Browser extension that blurs spoilers on any website. Block full phrases, blur text, images, and thumbnails." />
    <meta name="twitter:image" content="/assets/images/social/pages/hide-spoilers-extension.png" />
    <meta name="twitter:image:alt" content="Hide Spoilers extension" />
    <meta name="twitter:site" content="@bycoffeeandfun" />
    <meta name="twitter:creator" content="@bycoffeeandfun" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/hide-spoilers-extension/" />

    <!-- Favicon & Icons -->
    <link rel="icon" href="/assets/images/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />
    <link rel="icon" href="/assets/images/social/192.png" sizes="192x192" type="image/png" />

    <!-- PWA & Mobile -->
    <link rel="manifest" href="/assets/images/social/site.webmanifest" />
    <meta name="theme-color" content="#fef5ec" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Hide Spoilers" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Hide Spoilers",
        "description": "Browser extension that blurs spoilers on any website",
        "url": "https://www.coffeeandfun.com/hide-spoilers-extension/",
        "applicationCategory": "BrowserApplication",
        "operatingSystem": "Chrome, Safari",
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "ratingCount": "342"
        },
        "creator": {
            "@type": "Organization",
            "name": "Coffee & Fun LLC",
            "url": "https://www.coffeeandfun.com",
            "sameAs": ["https://x.com/bycoffeeandfun"]
        }
    }
    </script>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "How does Hide Spoilers work?",
                "acceptedAnswer": { "@type": "Answer", "text": "It scans pages for your keywords and blurs anything that matches — text, images, and entire sections." }
            },
            {
                "@type": "Question",
                "name": "Can I choose my own keywords?",
                "acceptedAnswer": { "@type": "Answer", "text": "Yes. Add or remove keywords anytime — show names, character names, whatever you want to avoid." }
            },
            {
                "@type": "Question",
                "name": "Does it work on all websites?",
                "acceptedAnswer": { "@type": "Answer", "text": "Most sites, including Twitter, YouTube, Reddit, and news sites. We're constantly improving compatibility." }
            },
            {
                "@type": "Question",
                "name": "Is Hide Spoilers free?",
                "acceptedAnswer": { "@type": "Answer", "text": "Yes. Completely free on both Chrome and Safari." }
            }
        ]
    }
    </script>

    {% bundledCss %}
    {% include scripts.html %}

    <!-- Service Worker -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then((registrations) => {
                registrations.forEach(registration => {
                    registration.unregister();
                });
                navigator.serviceWorker.register('/service-worker.js')
                    .then(() => console.log('Service worker registered'))
                    .catch((err) => console.error('Service worker error:', err));
            });
        }
    </script>
    {% include sketch-styles.liquid %}
</head>

<body>
    {% assign showDonation = false %}
    {% assign showTriviaApp = false %}
    {% assign showKeyboardModal = false %}
    {% assign showInstantApp = false %}
    {% assign showSpoilers = false %}

    {% include header.liquid %}

    <main id="main-content" class="mx-auto max-w-7xl pb-4 pt-4">

        <!-- Hero -->
        <div class="mb-16 mt-16 sm:mb-24 sm:mt-12">
            <div class="relative">
                <div class="absolute inset-2 bottom-0 rounded-4xl bg-black"></div>
                <div class="relative px-6 lg:px-8">
                    <div class="mx-auto max-w-2xl lg:max-w-7xl">
                        <div class="pt-16 pb-24 sm:pt-24 sm:pb-32 md:pt-32 md:pb-48 mx-auto max-w-3xl text-center">

                            <img
                                alt="Hide Spoilers logo"
                                src="/assets/images/spoilers.png"
                                class="h-24 w-auto mx-auto mb-8"
                                decoding="async"
                                loading="eager"
                            />

                            <!-- Sketch: "no peeking!" — light strokes for the dark hero -->
                            <div class="sketch-note text-lg sm:text-xl" style="top: 8%; right: 6%; transform: rotate(-5deg); color: var(--color-toffee);">
                                no peeking!
                                <svg width="40" height="34" style="bottom: -30px; left: 14px;">
                                    <path d="M20 2 C16 12, 10 20, 8 28" class="sketch-arrow" style="stroke: var(--color-toffee);"/>
                                    <path d="M2 22 L8 30 L14 22" class="sketch-arrow" style="stroke: var(--color-toffee);"/>
                                </svg>
                            </div>

                            <!-- Sketch: star left, toffee on dark -->
                            <div class="sketch-note sketch-float-slow" style="top: 25%; left: 6%; --sketch-rotate: -12deg;">
                                <svg width="22" height="22" viewBox="0 0 30 30">
                                    <path d="M15 2 L17 11 L26 11 L19 17 L22 26 L15 21 L8 26 L11 17 L4 11 L13 11 Z" fill="none" stroke="#c4813a" stroke-width="1.5" stroke-linejoin="round" opacity="0.5"/>
                                </svg>
                            </div>

                            <h1 class="text-4xl sm:text-5xl md:text-6xl leading-[1.3] sm:leading-[1.3] md:leading-[1.3]" style="font-family: 'Pacifico', cursive; color: var(--color-cream); text-shadow: 2px 3.5px 0px rgba(253, 97, 85, 0.55);">
                                Browse without spoilers
                            </h1>
                            <p class="mt-5 text-xl sm:text-2xl font-semibold text-white tracking-tight">
                                You'll see it when you're ready. Not before.
                            </p>
                            <p class="mt-4 max-w-xl text-lg text-white/80 mx-auto">
                                Set your keywords. We blur the rest. Text, images, thumbnails — if it matches, it's hidden until you choose to look.
                            </p>

                            <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
                                <a href="https://chromewebstore.google.com/detail/hide-spoilers-block-blur/dglgbepdhdpfihbiklibdcecpadcdcln"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn-lg w-full sm:w-auto bg-[#e25440] hover:bg-[#c94836] text-white border-none">
                                    Download for Chrome
                                </a>
                                <a href="https://apps.apple.com/us/app/hide-spoilers/id6740436834"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   class="btn btn-lg w-full sm:w-auto text-white border-white/20 hover:bg-white/10 hover:border-white/40 bg-transparent">
                                    Download for Safari
                                </a>
                            </div>

                            <!-- Trust row -->
                            <p class="mt-8 text-xl sm:text-2xl" style="font-family: 'Caveat', cursive; color: var(--color-toffee);">
                                100% free&nbsp;&nbsp;&middot;&nbsp;&nbsp;Chrome & Safari&nbsp;&nbsp;&middot;&nbsp;&nbsp;Hover to peek
                            </p>

                            <!-- Video -->
                            <div class="mx-auto mt-16 flow-root max-w-4xl sm:mt-20">
                                <div class="rounded-2xl bg-white/10 p-2 lg:p-3">
                                    <video aria-label="Hide Spoilers extension demo"
                                           autoplay controls loop muted playsinline
                                           width="2432" height="1442"
                                           class="rounded-xl">
                                        <source src="/assets/videos/spoilers.mp4" type="video/mp4" />
                                        Your browser does not support the video tag.
                                    </video>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- What's New Banner -->
        <div class="relative mx-auto max-w-3xl px-6 lg:px-8 mb-24 text-center overflow-visible">
            <!-- Sketch: sparkle by the banner -->
            <div class="sketch-note sketch-float" style="top: -4px; right: 10%; --sketch-rotate: 0deg;">
                <svg width="22" height="22" viewBox="0 0 22 22">
                    <path d="M11 2 L11 20" class="sketch-sparkle"/>
                    <path d="M2 11 L20 11" class="sketch-sparkle"/>
                    <path d="M4 4 L18 18" class="sketch-sparkle"/>
                    <path d="M18 4 L4 18" class="sketch-sparkle"/>
                </svg>
            </div>
            <p class="text-sm font-semibold uppercase tracking-widest text-coral-deep mb-2">What's New</p>
            <h2 class="brand-heading text-3xl sm:text-4xl leading-[1.3]">
                Completely redesigned.
            </h2>
            <p class="mt-3 text-lg text-stone-600">New logo. New interface. Smarter blocking.</p>
        </div>

        <!-- Features -->
        <div class="relative mx-auto max-w-5xl px-6 lg:px-8 mb-32 overflow-visible">
            <!-- Sketch: "our favorite part" with arrow -->
            <div class="sketch-note text-base sm:text-lg" style="top: -28px; left: 2%; transform: rotate(-5deg);">
                our favorite part
                <svg width="35" height="28" style="bottom: -24px; left: 24px;">
                    <path d="M18 2 C14 10, 10 16, 8 24" class="sketch-arrow"/>
                    <path d="M2 20 L8 26 L13 19" class="sketch-arrow"/>
                </svg>
            </div>

            <!-- Sketch: zigzag right -->
            <div class="sketch-note" style="top: 40%; right: -1%;">
                <svg width="40" height="14" viewBox="0 0 40 14">
                    <path d="M2 12 L10 2 L18 12 L26 2 L34 12 L40 4" class="sketch-zigzag"/>
                </svg>
            </div>

            <!-- Sketch: heart bottom-left -->
            <div class="sketch-note sketch-float-slow" style="bottom: 0; left: -1%; --sketch-rotate: -8deg;">
                <svg width="18" height="16" viewBox="0 0 24 22">
                    <path d="M12 21 C12 21, 2 14, 2 7 C2 3, 5 1, 8 2 C10 3, 11 5, 12 6 C13 5, 14 3, 16 2 C19 1, 22 3, 22 7 C22 14, 12 21, 12 21 Z" class="sketch-heart-filled"/>
                </svg>
            </div>

            <div class="grid md:grid-cols-2 gap-x-16 gap-y-14">

                <div>
                    <h3 class="text-lg font-semibold text-stone-900 mb-2">Multi-Word Blocking</h3>
                    <p class="text-stone-600 leading-relaxed">
                        Block full phrases like "Breaking Bad" or "Squid Games" — not just single words. Add any phrase and we'll blur it everywhere.
                    </p>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-900 mb-2">Smarter Detection</h3>
                    <p class="text-stone-600 leading-relaxed">
                        Rebuilt spoiler engine. Faster, catches more, and works better on sites like YouTube where content loads as you scroll.
                    </p>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-900 mb-2">Works Everywhere</h3>
                    <p class="text-stone-600 leading-relaxed">
                        Text, images, video thumbnails, links — if it contains your terms, it gets blurred. Hover to peek when you're ready.
                    </p>
                </div>

                <div>
                    <h3 class="text-lg font-semibold text-stone-900 mb-2">Better Performance</h3>
                    <p class="text-stone-600 leading-relaxed">
                        Faster on heavy sites, improved accessibility, better Safari integration, and a stack of bug fixes under the hood.
                    </p>
                </div>

            </div>
        </div>

        <!-- How It Works -->
        <div class="mb-32">
            <div class="relative mx-auto max-w-5xl px-6 lg:px-8 overflow-visible">
                <!-- Sketch: "easy as 1-2-3" -->
                <div class="sketch-note text-base sm:text-lg" style="top: 8px; right: 8%; transform: rotate(4deg); opacity: 0.75;">
                    easy as 1-2-3
                </div>
                <div class="text-center mb-14">
                    <h2 class="brand-heading text-3xl sm:text-4xl leading-[1.3]">How It Works</h2>
                </div>
                <div class="grid md:grid-cols-3 gap-12 text-center">
                    <div>
                        <div class="w-12 h-12 rounded-full bg-cocoa text-white flex items-center justify-center mx-auto mb-4 text-lg font-bold">1</div>
                        <h3 class="text-base font-semibold mb-1">Add Keywords</h3>
                        <p class="text-stone-600 text-sm">Shows, movies, games — anything you want to avoid.</p>
                    </div>
                    <div>
                        <div class="w-12 h-12 rounded-full bg-cocoa text-white flex items-center justify-center mx-auto mb-4 text-lg font-bold">2</div>
                        <h3 class="text-base font-semibold mb-1">Browse Normally</h3>
                        <p class="text-stone-600 text-sm">The extension runs quietly in the background.</p>
                    </div>
                    <div>
                        <div class="w-12 h-12 rounded-full bg-cocoa text-white flex items-center justify-center mx-auto mb-4 text-lg font-bold">3</div>
                        <h3 class="text-base font-semibold mb-1">Stay Spoiler-Free</h3>
                        <p class="text-stone-600 text-sm">Matching content gets blurred automatically.</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- FAQ -->
        <section class="mb-24 mx-6 lg:mx-8" id="faq">
            <div class="mx-auto max-w-3xl">
                <h2 class="brand-heading text-3xl sm:text-4xl leading-[1.3] mb-10">FAQ</h2>
                <div class="space-y-8">
                    <div>
                        <h3 class="text-base font-semibold text-stone-900">How does it work?</h3>
                        <p class="mt-2 text-stone-600">It scans pages for your keywords and blurs anything that matches — text, images, and entire sections.</p>
                    </div>
                    <div>
                        <h3 class="text-base font-semibold text-stone-900">Can I choose my own keywords?</h3>
                        <p class="mt-2 text-stone-600">Yes. Add or remove keywords anytime — show names, character names, whatever you want to avoid.</p>
                    </div>
                    <div>
                        <h3 class="text-base font-semibold text-stone-900">Does it work on all websites?</h3>
                        <p class="mt-2 text-stone-600">Most sites, including Twitter, YouTube, Reddit, and news sites. We're constantly improving compatibility.</p>
                    </div>
                    <div>
                        <h3 class="text-base font-semibold text-stone-900">Is it free?</h3>
                        <p class="mt-2 text-stone-600">Yes. Completely free on both Chrome and Safari.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <div class="relative mx-auto max-w-3xl px-6 lg:px-8 mb-24 text-center overflow-visible">
            <!-- Sketch: swirl left -->
            <div class="sketch-note" style="top: 10%; left: 2%;">
                <svg width="26" height="26" viewBox="0 0 30 30">
                    <path d="M15 15 C15 10, 20 8, 22 12 C24 16, 20 20, 15 18 C10 16, 8 10, 12 6 C16 2, 24 4, 26 10" class="sketch-swirl"/>
                </svg>
            </div>
            <!-- Sketch: star right -->
            <div class="sketch-note sketch-float" style="top: 0; right: 5%; --sketch-rotate: 12deg;">
                <svg width="22" height="22" viewBox="0 0 30 30">
                    <path d="M15 2 L17 11 L26 11 L19 17 L22 26 L15 21 L8 26 L11 17 L4 11 L13 11 Z" fill="none" stroke="#fd6155" stroke-width="1.5" stroke-linejoin="round" opacity="0.4"/>
                </svg>
            </div>
            <h2 class="brand-heading text-3xl sm:text-4xl leading-[1.3] mb-4">Keep the surprise.</h2>
            <p class="text-2xl text-caramel mb-8" style="font-family: 'Caveat', cursive;">Enjoy your shows spoiler-free.</p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
                <a href="https://chromewebstore.google.com/detail/hide-spoilers-block-blur/dglgbepdhdpfihbiklibdcecpadcdcln"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn btn-lg w-full sm:w-auto bg-[#e25440] hover:bg-[#c94836] text-white border-none">
                    Download for Chrome
                </a>
                <a href="https://apps.apple.com/us/app/hide-spoilers/id6740436834"
                   target="_blank"
                   rel="noopener noreferrer"
                   class="btn btn-lg btn-outline w-full sm:w-auto rounded-lg font-semibold border-2 border-coral-deep text-coral-deep hover:bg-coral-deep hover:text-white focus-visible:bg-coral-deep focus-visible:text-white focus:outline-none focus-visible:ring-2 focus-visible:ring-coral-deep focus-visible:ring-offset-2 transition-all duration-200">
                    Download for Safari
                </a>
            </div>
        </div>

    </main>

    {% include modals.liquid %}
    {% include footer.liquid %}
</body>
</html>
