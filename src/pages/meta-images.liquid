<!DOCTYPE html>
<html class="antialiased" lang="en" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <!-- Primary Meta Tags -->
    <title>Free Image Metadata Viewer & Remover - EXIF Data Tool | Coffee & Fun LLC</title>
    <meta name="title" content="Free Image Metadata Viewer & Remover - EXIF Data Tool | Coffee & Fun LLC" />
    <meta name="description" content="See every hidden detail your photo carries — GPS location, camera, dates — then download a clean copy with all of it removed. Free and private: nothing leaves your browser." />
    <meta name="keywords" content="EXIF data, image metadata, photo privacy, metadata removal, EXIF viewer, privacy tool, Coffee and Fun" />
    <meta name="author" content="Coffee & Fun LLC" />
    <meta name="publisher" content="Coffee & Fun LLC" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="rating" content="general" />

    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/meta-images/" />

    <!-- Favicon & Icons -->
    <link rel="icon" href="/assets/images/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:url" content="https://www.coffeeandfun.com/meta-images/" />
