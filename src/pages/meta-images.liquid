            <button type="button" class="btn btn-primary btn-block" @click="removeMetadata" :disabled="cleaning">
                <span v-if="cleaning" class="spin" aria-hidden="true"></span>
                {{ cleaning ? 'Cleaning…' : 'Remove all metadata' }}
            </button>

