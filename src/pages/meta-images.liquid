    <meta property="og:description" content="See the hidden EXIF data inside your photos and download a clean copy with it removed. Privacy-focused — everything happens in your browser." />
    <meta property="og:image" content="https://www.coffeeandfun.com/assets/images/social/pages/meta-images.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Image Metadata Viewer & Remover tool by Coffee & Fun" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="https://www.coffeeandfun.com/meta-images/" />
    <meta name="twitter:title" content="Free Image Metadata Viewer & Remover - EXIF Data Tool" />
    <meta name="twitter:description" content="See the hidden EXIF data inside your photos and download a clean copy with it removed. Works entirely in your browser." />
    <meta name="twitter:image" content="https://www.coffeeandfun.com/assets/images/social/pages/meta-images.png" />
    <meta name="twitter:image:alt" content="Image Metadata Viewer & Remover by Coffee & Fun" />
    <meta name="twitter:site" content="@bycoffeeandfun" />
    <meta name="twitter:creator" content="@bycoffeeandfun" />

    <!-- PWA & Mobile -->
    <meta name="theme-color" content="#f4f4f2" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Image Metadata" />

    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "WebApplication",
        "name": "Image Metadata Viewer & Remover",
        "description": "View the hidden EXIF metadata inside photos — GPS location, camera details, dates — and remove it for privacy. Everything runs locally in the browser.",
        "url": "https://www.coffeeandfun.com/meta-images/",
        "applicationCategory": "UtilityApplication",
        "operatingSystem": "Any",
        "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "USD"
        },
        "featureList": [
            "View EXIF, GPS, and camera metadata",
            "GPS location and personal data warnings",
            "Remove all metadata with one click",
            "Download a clean copy",
            "Local processing — no uploads"
        ],
        "creator": {
            "@type": "Organization",
            "name": "Coffee & Fun LLC",
            "url": "https://www.coffeeandfun.com",
            "sameAs": ["https://x.com/bycoffeeandfun"]
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.9",
            "ratingCount": "89"
        }
    }
    </script>

    <script src="https://unpkg.com/vue@3"></script>

    <style>
        :root {
            --bg: #f4f4f2;
            --surface: #ffffff;
            --ink: #16161a;
            --muted: #6c6c74;
            --faint: #9a9aa2;
            --line: #e4e4e0;
            --line-strong: #d3d3ce;
            --good: #0f7b4f;
            --good-bg: #eaf6ef;
            --warn: #b4341f;
            --warn-bg: #fbecea;
            --radius: 14px;
            --mono: ui-monospace, 'SF Mono', 'JetBrains Mono', 'Fira Code', Menlo, Consolas, monospace;
        }

        * { box-sizing: border-box; }

        html, body { background: var(--bg); }
        body {
            margin: 0;
            color: var(--ink);
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            -webkit-font-smoothing: antialiased;
            accent-color: var(--ink);
        }
        [v-cloak] { display: none; }

        .sr-only {
            position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px;
            overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
        }

        a.skip {
            position: absolute; left: -9999px; top: 0;
            background: var(--ink); color: #fff; padding: 0.6rem 1rem; z-index: 20;
            border-radius: 0 0 8px 0;
        }
        a.skip:focus { left: 0; }

        .wrap {
            width: 100%;
            max-width: 640px;
            margin: 0 auto;
            padding: 2rem 1.25rem 4rem;
            flex: 1;
        }

        .topbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2.75rem;
        }
        .topbar a {
            font-size: 0.82rem;
            color: var(--muted);
            text-decoration: none;
            letter-spacing: 0.01em;
        }
        .topbar a:hover { color: var(--ink); }
        .topbar a:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; border-radius: 4px; }
        .brandmark {
            display: inline-flex; align-items: center; gap: 0.5rem;
            font-weight: 600; font-size: 0.85rem; letter-spacing: 0.02em;
        }
        .brandmark .mark {
            width: 22px; height: 22px; border-radius: 6px;
            background: var(--ink); color: #fff;
            display: inline-flex; align-items: center; justify-content: center;
        }

        h1 {
            font-size: 1.9rem;
            line-height: 1.2;
            letter-spacing: -0.02em;
            margin: 0 0 0.6rem;
            font-weight: 650;
        }
        .lede {
            color: var(--muted);
            font-size: 1rem;
            line-height: 1.55;
            margin: 0 0 2.25rem;
            max-width: 52ch;
        }

        h2.step-label {
            font-size: 0.78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.07em;
            color: var(--muted);
            margin: 0 0 0.8rem;
        }
        section.step { margin-bottom: 2.25rem; }

        /* Drop zone */
        .drop {
            display: block;
            border: 1.5px dashed var(--line-strong);
            border-radius: var(--radius);
            background: var(--surface);
            padding: 2rem 1.25rem;
            text-align: center;
            cursor: pointer;
            transition: border-color 0.15s, background 0.15s;
        }
        .drop:hover, .drop.drag { border-color: var(--ink); background: #fbfbfa; }
        .drop:focus-within { outline: 2px solid var(--ink); outline-offset: 2px; }
        .drop .ico { color: var(--faint); margin-bottom: 0.6rem; }
        .drop .main { font-weight: 600; font-size: 0.95rem; }
        .drop .sub { color: var(--muted); font-size: 0.85rem; margin-top: 0.25rem; }

        /* Thumbnail row */
        .thumb-row {
            display: flex; align-items: center; gap: 0.9rem;
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            padding: 0.75rem;
        }
        .thumb {
            width: 56px; height: 56px; border-radius: 9px;
            object-fit: cover; background: #f0f0ee; flex-shrink: 0;
            border: 1px solid var(--line);
        }
        .thumb-ph {
            display: inline-flex; align-items: center; justify-content: center;
            color: var(--faint);
        }
        .thumb-meta { flex: 1; min-width: 0; }
        .thumb-meta .name { font-weight: 600; font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .thumb-meta .dim { color: var(--muted); font-size: 0.82rem; }

        /* Buttons */
        .btn {
            appearance: none; border: none; border-radius: 11px;
            padding: 0.85rem 1.4rem;
            font-size: 0.98rem; font-weight: 600; cursor: pointer; font-family: inherit;
            display: inline-flex; align-items: center; justify-content: center; gap: 0.5rem;
            transition: background 0.15s, opacity 0.15s, border-color 0.15s;
        }
        .btn:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        .btn-block { width: 100%; }
        .btn-primary { background: var(--ink); color: #fff; }
        .btn-primary:hover { background: #000; }
        .btn-primary:disabled { background: #dcdcd7; color: #6c6c74; cursor: not-allowed; }
        .btn-secondary {
            background: var(--surface); color: var(--ink);
            border: 1px solid var(--line-strong);
        }
        .btn-secondary:hover { border-color: var(--ink); }
        .btn-ghost { background: transparent; color: var(--muted); padding: 0.6rem 0.9rem; }
        .btn-ghost:hover { color: var(--ink); }

        /* Findings */
        .tally { margin: 0 0 1rem; font-size: 0.95rem; line-height: 1.5; }

        .banner {
            display: flex; gap: 0.55rem; align-items: flex-start;
            border-radius: 10px; padding: 0.75rem 0.9rem;
            font-size: 0.88rem; line-height: 1.45; margin-top: 0.8rem;
        }
        .banner.warn { background: var(--warn-bg); color: #7a2314; border: 1px solid #f0ccc5; }
        .banner.good { background: var(--good-bg); color: #143d2b; border: 1px solid #cfe8db; }
        .banner svg { flex-shrink: 0; margin-top: 1px; }

        .note {
            display: flex; gap: 0.55rem; align-items: flex-start;
            font-size: 0.85rem; line-height: 1.5; color: var(--muted);
            margin-top: 0.9rem;
        }
        .note svg { flex-shrink: 0; margin-top: 1px; }

        /* Category tabs */
        .cat-tabs {
            display: flex; flex-wrap: wrap; gap: 6px;
            margin-top: 1.1rem;
        }
        .cat-tab {
            appearance: none; cursor: pointer; font-family: inherit;
            border: 1px solid var(--line-strong);
            background: transparent;
            border-radius: 999px;
            padding: 0.42rem 0.9rem;
            font-size: 0.85rem; font-weight: 600;
            color: var(--muted);
            transition: background 0.15s, color 0.15s, border-color 0.15s;
        }
        .cat-tab:hover { border-color: var(--ink); color: var(--ink); }
        .cat-tab[aria-selected="true"] {
            background: var(--ink); color: #fff; border-color: var(--ink);
        }
        .cat-tab:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }

        /* Metadata table */
        .meta-scroll {
            background: var(--surface);
            border: 1px solid var(--line);
            border-radius: var(--radius);
            max-height: 400px; overflow: auto;
            margin-top: 0.8rem;
        }
        .meta-scroll:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        table.meta { width: 100%; border-collapse: collapse; }
        table.meta th, table.meta td {
            text-align: left; vertical-align: top;
            padding: 0.55rem 0.9rem;
            font-size: 0.85rem; line-height: 1.5;
            word-break: break-word;
        }
        table.meta th { font-weight: 600; color: var(--muted); width: 42%; }
        table.meta td { font-family: var(--mono); font-size: 0.8rem; color: var(--ink); }
        table.meta tr + tr th, table.meta tr + tr td { border-top: 1px solid var(--line); }

        .code-empty {
            border: 1.5px dashed var(--line-strong);
            border-radius: var(--radius);
            padding: 1.6rem 1.25rem;
            text-align: center;
            color: var(--muted);
            font-size: 0.9rem;
            margin-top: 0.8rem;
        }

        /* Result card */
        .result {
            border: 1px solid var(--line);
            border-radius: var(--radius);
            background: var(--surface);
            padding: 1.25rem;
            margin-top: 1.2rem;
        }
        .result-title { font-weight: 650; font-size: 1.02rem; margin: 0 0 0.35rem; }
        .sizes { color: var(--muted); font-size: 0.88rem; margin: 0 0 1rem; }
        .sizes strong { color: var(--ink); }
        .result-actions { display: flex; gap: 0.6rem; flex-wrap: wrap; }
        .result-actions .btn { flex: 1; min-width: 150px; }

        /* About section */
        .about { border-top: 1px solid var(--line); padding-top: 1.75rem; margin-top: 2.5rem; }
        .about h3 { font-size: 0.95rem; font-weight: 650; margin: 1.1rem 0 0.3rem; }
        .about p { color: var(--muted); font-size: 0.9rem; line-height: 1.6; margin: 0; }

        .foot {
            text-align: center; padding: 1.5rem 1rem 2rem;
            font-size: 0.8rem; color: var(--muted);
        }
        .foot a { color: var(--muted); text-decoration: none; }
        .foot a:hover { color: var(--ink); }

        .spin {
            width: 16px; height: 16px; border: 2px solid rgba(255,255,255,0.4);
            border-top-color: #fff; border-radius: 50%;
            animation: spin 0.7s linear infinite;
        }
        .spin.dark { border-color: rgba(22,22,26,0.15); border-top-color: var(--ink); }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (prefers-reduced-motion: reduce) {
            .spin { animation: none; }
            .btn, .drop, .cat-tab { transition: none; }
        }

        @media (max-width: 480px) {
            h1 { font-size: 1.6rem; }
            .wrap { padding-top: 1.5rem; }
            .topbar { margin-bottom: 2rem; }
            .result-actions .btn { min-width: 100%; }
            table.meta th { width: 40%; }
        }

        /* ---- Site footer ----
           footer.liquid is written against Tailwind utilities, which this
           standalone page doesn't load; these rules cover exactly the classes
           that markup uses (plus sketch-styles.liquid for the doodles). */
        footer.brand-color-background { position: relative; overflow: visible; padding: 1rem; }
        footer .mx-auto { margin-left: auto; margin-right: auto; }
        footer .max-w-7xl { max-width: 80rem; padding: 3rem 1rem; }
        footer .max-w-2xl { max-width: 42rem; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
        footer .mb-4 { display: inline-block; margin-bottom: 1rem; border-radius: 1rem; }
        footer img { height: 4rem; width: 4rem; }
        footer h2 { margin: 0 0 0.5rem; font-size: 1.125rem; font-weight: 700; }
        footer p { margin: 0; font-size: 0.875rem; }
        footer .text-stone-600 { color: #57534e; }
        footer .font-semibold { font-weight: 600; }
        footer .text-base { font-size: 1rem; }
        footer .text-lg { font-size: 1.125rem; }
        footer .flex-wrap { display: flex; flex-wrap: wrap; justify-content: center; gap: 1rem; margin-top: 2rem; }
        footer .flex-wrap a { display: inline-flex; padding: 0.5rem; border-radius: 1rem; color: #78716c; transition: color 0.15s; }
        footer .flex-wrap svg { height: 1.5rem; width: 1.5rem; }
        footer .hover\:text-blue-400:hover { color: #60a5fa; }
        footer .hover\:text-pink-500:hover { color: #ec4899; }
        footer .hover\:text-indigo-500:hover { color: #6366f1; }
        footer .hover\:text-stone-900:hover { color: #1c1917; }
        footer .hover\:text-red-500:hover { color: #ef4444; }
        footer p.text-center { margin-top: 2rem; text-align: center; }
        footer a:focus-visible { outline: 2px solid var(--ink); outline-offset: 2px; }
        @media (min-width: 640px) {
            footer.brand-color-background { padding: 1.5rem; }
            footer .sm\:text-lg { font-size: 1.125rem; }
            footer .sm\:text-xl { font-size: 1.25rem; }
            footer .max-w-7xl { padding: 4rem 1.5rem; }
            footer img { height: 5rem; width: 5rem; }
            footer h2 { font-size: 1.25rem; }
            footer p { font-size: 1rem; }
            footer .flex-wrap { gap: 1.5rem; margin-top: 3rem; }
            footer .flex-wrap svg { height: 1.75rem; width: 1.75rem; }
            footer p.text-center { margin-top: 2.5rem; }
        }
        @media (min-width: 1024px) {
            footer.brand-color-background { padding: 2.5rem; }
            footer .max-w-7xl { padding: 5rem 2rem; }
            footer img { height: 6rem; width: 6rem; }
            footer h2 { font-size: 1.5rem; }
            footer .flex-wrap { margin-top: 4rem; }
            footer p.text-center { margin-top: 3rem; }
        }
    </style>
    {% include sketch-styles.liquid %}
</head>

<body>
{% raw %}
    <a href="#tool" class="skip">Skip to the tool</a>

    <main v-cloak id="app" class="wrap">

        <div class="topbar">
            <span class="brandmark">
                <span class="mark" aria-hidden="true">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"/><circle cx="12" cy="13" r="3"/></svg>
                </span>
                Photo Privacy
            </span>
            <a href="/">&larr; coffeeandfun.com</a>
        </div>

        <header id="tool">
            <h1>See what your photos know about you</h1>
            <p class="lede">Every photo quietly records where it was taken, when, and on what device. Drop one in to see everything it&rsquo;s carrying &mdash; then download a clean copy with all of it removed. Nothing leaves your device.</p>
        </header>

        <!-- Live status for screen readers -->
        <div class="sr-only" role="status" aria-live="polite">{{ announcement }}</div>

        <!-- ===== Step 1: pick a photo ===== -->
        <section class="step" aria-labelledby="h-pick">
            <h2 class="step-label" id="h-pick">1 &mdash; Pick a photo</h2>

            <label v-if="!image" for="mi-file" class="drop" :class="{ drag: drag }"
                   @dragover.prevent="drag = true" @dragleave="drag = false" @drop.prevent="onDrop">
                <template v-if="!processing">
                    <div class="ico"><svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg></div>
                    <div class="main">Drop a photo, or click to choose</div>
                    <div class="sub">JPEG, PNG, WEBP, TIFF &mdash; anything works</div>
                </template>
                <template v-else>
                    <div class="ico"><span class="spin dark" style="display:inline-block" aria-hidden="true"></span></div>
                    <div class="main">Reading photo&hellip;</div>
                </template>
                <input id="mi-file" ref="fileInput" type="file" accept="image/*" class="sr-only"
                       @change="onFileChange" aria-labelledby="h-pick" />
            </label>

            <div v-else class="thumb-row">
                <img v-if="!thumbBroken" :src="image.preview" alt="" class="thumb" @error="thumbBroken = true" />
                <span v-else class="thumb thumb-ph" aria-hidden="true">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="9" cy="9" r="2"/><path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"/></svg>
                </span>
                <div class="thumb-meta">
                    <div class="name">{{ image.name }}</div>
                    <div class="dim"><span v-if="image.width">{{ image.width }} &times; {{ image.height }} px &middot; </span>{{ formatFileSize(image.size) }} &middot; {{ image.type }}</div>
                </div>
                <button type="button" class="btn btn-ghost" @click="startOver" aria-label="Remove photo and choose another">Change</button>
            </div>

            <div v-if="fileError" class="banner warn" role="alert">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 9v4"/><path d="M12 17h.01"/><circle cx="12" cy="12" r="10"/></svg>
                <span>{{ fileError }}</span>
            </div>
        </section>

        <!-- ===== Step 2: what's inside ===== -->
        <section v-if="image" class="step" aria-labelledby="h-inside">
            <h2 class="step-label" id="h-inside">2 &mdash; What this photo is carrying</h2>

            <p class="tally">
                <strong>{{ fieldCount }} {{ fieldCount === 1 ? 'detail' : 'details' }}</strong>
                <template v-if="exifFound"> recorded inside this photo.</template>
                <template v-else> &mdash; this file carries no hidden camera data, only basic file facts.</template>
            </p>

            <div v-if="hasGpsData" class="banner warn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
                <span><strong>Location found.</strong> This photo contains GPS coordinates<template v-if="gpsCoords"> ({{ gpsCoords }})</template> &mdash; anyone you share it with can work out exactly where it was taken.</span>
            </div>

            <div v-if="hasPersonalData" class="banner warn">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                <span><strong>Personal details found.</strong> A name, copyright line, or owner tag is written into this file.</span>
            </div>

            <div v-if="exifFound && !hasGpsData && !hasPersonalData" class="banner good">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
                <span>No location or personal details found &mdash; mostly technical camera settings.</span>
            </div>

            <p v-if="hasCameraInfo || hasSoftwareInfo" class="note">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
                <span>It also names <template v-if="hasCameraInfo">the camera or phone that took it</template><template v-if="hasCameraInfo && hasSoftwareInfo"> and </template><template v-if="hasSoftwareInfo">the software used to edit it</template>.</span>
            </p>

            <button type="button" class="btn btn-secondary btn-block" style="margin-top: 1.2rem;"
                    @click="showAll = !showAll" :aria-expanded="showAll ? 'true' : 'false'" aria-controls="meta-details">
                {{ showAll ? 'Hide the full list' : 'Show all ' + fieldCount + ' details' }}
