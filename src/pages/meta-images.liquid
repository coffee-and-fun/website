{% endraw %}

    {% include footer.liquid %}

    <script>
        const { createApp } = Vue;

        /* ---------- EXIF parsing (inlined — no external library) ----------
           A self-contained TIFF/EXIF reader with the same tag dictionaries the
           old exif-js library used: the 0th IFD (TIFF) tags, the Exif sub-IFD,
           and the GPS IFD. It finds EXIF inside JPEG (APP1 segment), TIFF
           files, PNG (eXIf chunk), and WebP (EXIF chunk). */

        const TIFF_TAGS = {
            0x0100: 'ImageWidth', 0x0101: 'ImageHeight', 0x8769: 'ExifIFDPointer',
            0x8825: 'GPSInfoIFDPointer', 0xA005: 'InteroperabilityIFDPointer',
            0x0102: 'BitsPerSample', 0x0103: 'Compression', 0x0106: 'PhotometricInterpretation',
            0x0112: 'Orientation', 0x0115: 'SamplesPerPixel', 0x011C: 'PlanarConfiguration',
            0x0212: 'YCbCrSubSampling', 0x0213: 'YCbCrPositioning', 0x011A: 'XResolution',
            0x011B: 'YResolution', 0x0128: 'ResolutionUnit', 0x0111: 'StripOffsets',
            0x0116: 'RowsPerStrip', 0x0117: 'StripByteCounts', 0x0201: 'JPEGInterchangeFormat',
            0x0202: 'JPEGInterchangeFormatLength', 0x012D: 'TransferFunction',
            0x013E: 'WhitePoint', 0x013F: 'PrimaryChromaticities', 0x0211: 'YCbCrCoefficients',
            0x0214: 'ReferenceBlackWhite', 0x0132: 'DateTime', 0x010E: 'ImageDescription',
            0x010F: 'Make', 0x0110: 'Model', 0x0131: 'Software', 0x013B: 'Artist',
            0x8298: 'Copyright'
        };

        const EXIF_TAGS = {
            0x829A: 'ExposureTime', 0x829D: 'FNumber', 0x8822: 'ExposureProgram',
            0x8824: 'SpectralSensitivity', 0x8827: 'ISOSpeedRatings', 0x8828: 'OECF',
            0x9000: 'ExifVersion', 0x9003: 'DateTimeOriginal', 0x9004: 'DateTimeDigitized',
            0x9101: 'ComponentsConfiguration', 0x9102: 'CompressedBitsPerPixel',
            0x9201: 'ShutterSpeedValue', 0x9202: 'ApertureValue', 0x9203: 'BrightnessValue',
            0x9204: 'ExposureBias', 0x9205: 'MaxApertureValue', 0x9206: 'SubjectDistance',
            0x9207: 'MeteringMode', 0x9208: 'LightSource', 0x9209: 'Flash', 0x920A: 'FocalLength',
            0x9214: 'SubjectArea', 0x927C: 'MakerNote', 0x9286: 'UserComment',
            0x9290: 'SubsecTime', 0x9291: 'SubsecTimeOriginal', 0x9292: 'SubsecTimeDigitized',
            0xA000: 'FlashpixVersion', 0xA001: 'ColorSpace', 0xA002: 'PixelXDimension',
            0xA003: 'PixelYDimension', 0xA004: 'RelatedSoundFile', 0xA20B: 'FlashEnergy',
            0xA20E: 'FocalPlaneXResolution', 0xA20F: 'FocalPlaneYResolution',
            0xA210: 'FocalPlaneResolutionUnit', 0xA214: 'SubjectLocation', 0xA215: 'ExposureIndex',
            0xA217: 'SensingMethod', 0xA300: 'FileSource', 0xA301: 'SceneType',
            0xA302: 'CFAPattern', 0xA401: 'CustomRendered', 0xA402: 'ExposureMode',
            0xA403: 'WhiteBalance', 0xA404: 'DigitalZoomRation', 0xA405: 'FocalLengthIn35mmFilm',
            0xA406: 'SceneCaptureType', 0xA407: 'GainControl', 0xA408: 'Contrast',
            0xA409: 'Saturation', 0xA40A: 'Sharpness', 0xA40B: 'DeviceSettingDescription',
            0xA40C: 'SubjectDistanceRange', 0xA420: 'ImageUniqueID',
            0xA430: 'CameraOwnerName', 0xA431: 'BodySerialNumber', 0xA432: 'LensSpecification',
            0xA433: 'LensMake', 0xA434: 'LensModel', 0xA435: 'LensSerialNumber'
        };

        const GPS_TAGS = {
            0x0000: 'GPSVersionID', 0x0001: 'GPSLatitudeRef', 0x0002: 'GPSLatitude',
            0x0003: 'GPSLongitudeRef', 0x0004: 'GPSLongitude', 0x0005: 'GPSAltitudeRef',
            0x0006: 'GPSAltitude', 0x0007: 'GPSTimeStamp', 0x0008: 'GPSSatellites',
            0x0009: 'GPSStatus', 0x000A: 'GPSMeasureMode', 0x000B: 'GPSDOP',
            0x000C: 'GPSSpeedRef', 0x000D: 'GPSSpeed', 0x000E: 'GPSTrackRef',
            0x000F: 'GPSTrack', 0x0010: 'GPSImgDirectionRef', 0x0011: 'GPSImgDirection',
            0x0012: 'GPSMapDatum', 0x0013: 'GPSDestLatitudeRef', 0x0014: 'GPSDestLatitude',
            0x0015: 'GPSDestLongitudeRef', 0x0016: 'GPSDestLongitude', 0x0017: 'GPSDestBearingRef',
            0x0018: 'GPSDestBearing', 0x0019: 'GPSDestDistanceRef', 0x001A: 'GPSDestDistance',
            0x001B: 'GPSProcessingMethod', 0x001C: 'GPSAreaInformation', 0x001D: 'GPSDateStamp',
            0x001E: 'GPSDifferential'
        };

        /* Human-readable strings for enumerated values (mirrors exif-js). */
        const ENUM_STRINGS = {
            ExposureProgram: { 0: 'Not defined', 1: 'Manual', 2: 'Normal program', 3: 'Aperture priority', 4: 'Shutter priority', 5: 'Creative program', 6: 'Action program', 7: 'Portrait mode', 8: 'Landscape mode' },
            MeteringMode: { 0: 'Unknown', 1: 'Average', 2: 'Center-weighted average', 3: 'Spot', 4: 'Multi-spot', 5: 'Pattern', 6: 'Partial', 255: 'Other' },
            LightSource: { 0: 'Unknown', 1: 'Daylight', 2: 'Fluorescent', 3: 'Tungsten', 4: 'Flash', 9: 'Fine weather', 10: 'Cloudy weather', 11: 'Shade', 12: 'Daylight fluorescent', 13: 'Day white fluorescent', 14: 'Cool white fluorescent', 15: 'White fluorescent', 17: 'Standard light A', 18: 'Standard light B', 19: 'Standard light C', 20: 'D55', 21: 'D65', 22: 'D75', 23: 'D50', 24: 'ISO studio tungsten', 255: 'Other' },
            Flash: { 0x0000: 'Flash did not fire', 0x0001: 'Flash fired', 0x0005: 'Strobe return light not detected', 0x0007: 'Strobe return light detected', 0x0009: 'Flash fired, compulsory flash mode', 0x000D: 'Flash fired, compulsory flash mode, return light not detected', 0x000F: 'Flash fired, compulsory flash mode, return light detected', 0x0010: 'Flash did not fire, compulsory flash mode', 0x0018: 'Flash did not fire, auto mode', 0x0019: 'Flash fired, auto mode', 0x001D: 'Flash fired, auto mode, return light not detected', 0x001F: 'Flash fired, auto mode, return light detected', 0x0020: 'No flash function', 0x0041: 'Flash fired, red-eye reduction mode', 0x0045: 'Flash fired, red-eye reduction mode, return light not detected', 0x0047: 'Flash fired, red-eye reduction mode, return light detected', 0x0049: 'Flash fired, compulsory flash mode, red-eye reduction mode', 0x004D: 'Flash fired, compulsory flash mode, red-eye reduction mode, return light not detected', 0x004F: 'Flash fired, compulsory flash mode, red-eye reduction mode, return light detected', 0x0059: 'Flash fired, auto mode, red-eye reduction mode', 0x005D: 'Flash fired, auto mode, return light not detected, red-eye reduction mode', 0x005F: 'Flash fired, auto mode, return light detected, red-eye reduction mode' },
            SensingMethod: { 1: 'Not defined', 2: 'One-chip color area sensor', 3: 'Two-chip color area sensor', 4: 'Three-chip color area sensor', 5: 'Color sequential area sensor', 7: 'Trilinear sensor', 8: 'Color sequential linear sensor' },
            SceneCaptureType: { 0: 'Standard', 1: 'Landscape', 2: 'Portrait', 3: 'Night scene' },
            SceneType: { 1: 'Directly photographed' },
            CustomRendered: { 0: 'Normal process', 1: 'Custom process' },
            WhiteBalance: { 0: 'Auto white balance', 1: 'Manual white balance' },
            ExposureMode: { 0: 'Auto exposure', 1: 'Manual exposure', 2: 'Auto bracket' },
            GainControl: { 0: 'None', 1: 'Low gain up', 2: 'High gain up', 3: 'Low gain down', 4: 'High gain down' },
            Contrast: { 0: 'Normal', 1: 'Soft', 2: 'Hard' },
            Saturation: { 0: 'Normal', 1: 'Low saturation', 2: 'High saturation' },
            Sharpness: { 0: 'Normal', 1: 'Soft', 2: 'Hard' },
            SubjectDistanceRange: { 0: 'Unknown', 1: 'Macro', 2: 'Close view', 3: 'Distant view' },
            FileSource: { 3: 'Digital still camera' },
            Orientation: { 1: 'Normal', 2: 'Flipped horizontally', 3: 'Rotated 180 degrees', 4: 'Flipped vertically', 5: 'Rotated 90 CCW and flipped', 6: 'Rotated 90 CW', 7: 'Rotated 90 CW and flipped', 8: 'Rotated 90 CCW' },
            ResolutionUnit: { 1: 'None', 2: 'Inches', 3: 'Centimeters' },
            ColorSpace: { 1: 'sRGB', 0xFFFF: 'Uncalibrated' },
            GPSLatitudeRef: { N: 'North', S: 'South' },
            GPSLongitudeRef: { E: 'East', W: 'West' },
            GPSAltitudeRef: { 0: 'Above sea level', 1: 'Below sea level' },
            GPSStatus: { A: 'Measurement in progress', V: 'Measurement interrupted' },
            GPSSpeedRef: { K: 'km/h', M: 'mph', N: 'knots' }
        };

        const COMPONENTS = { 0: '', 1: 'Y', 2: 'Cb', 3: 'Cr', 4: 'R', 5: 'G', 6: 'B' };

        const TYPE_SIZES = { 1: 1, 2: 1, 3: 2, 4: 4, 5: 8, 6: 1, 7: 1, 8: 2, 9: 4, 10: 8, 11: 4, 12: 8 };

        function readTagValue(view, tiffStart, entry, little) {
            const type = view.getUint16(entry + 2, little);
            const count = view.getUint32(entry + 4, little);
            const unit = TYPE_SIZES[type];
            if (!unit || count === 0) return null;

            const totalBytes = unit * count;
            const offset = totalBytes <= 4
                ? entry + 8
                : tiffStart + view.getUint32(entry + 8, little);
            if (offset < 0 || offset + totalBytes > view.byteLength) return null;

            if (type === 2) { // ASCII string
                let s = '';
                for (let i = 0; i < count; i++) {
                    const c = view.getUint8(offset + i);
                    if (c === 0) break;
                    s += String.fromCharCode(c);
                }
                return s.trim();
            }

            if ((type === 1 || type === 7) && count > 128) {
                return 'Binary data (' + count + ' bytes)';
            }
            if (count > 256) {
                return 'List of ' + count + ' values';
            }

            function readOne(o) {
                switch (type) {
                    case 1: case 7: return view.getUint8(o);
                    case 3: return view.getUint16(o, little);
                    case 4: return view.getUint32(o, little);
                    case 5: {
                        const n = view.getUint32(o, little), d = view.getUint32(o + 4, little);
                        return d ? n / d : 0;
                    }
                    case 6: return view.getInt8(o);
                    case 8: return view.getInt16(o, little);
                    case 9: return view.getInt32(o, little);
                    case 10: {
                        const n = view.getInt32(o, little), d = view.getInt32(o + 4, little);
                        return d ? n / d : 0;
                    }
                    case 11: return view.getFloat32(o, little);
                    case 12: return view.getFloat64(o, little);
                }
                return null;
            }

            if (count === 1) return readOne(offset);
            const vals = [];
            for (let i = 0; i < count; i++) vals.push(readOne(offset + i * unit));
            return vals;
        }

        function readIfd(view, tiffStart, dirStart, dict, little, out) {
            if (dirStart < tiffStart + 8 || dirStart + 2 > view.byteLength) return;
            const entries = view.getUint16(dirStart, little);
            if (entries > 512) return; // corrupt file guard
            for (let i = 0; i < entries; i++) {
                const entry = dirStart + 2 + i * 12;
                if (entry + 12 > view.byteLength) break;
                const tagId = view.getUint16(entry, little);
                const name = dict[tagId] || ('Tag 0x' + tagId.toString(16).toUpperCase().padStart(4, '0'));
                let value = null;
                try { value = readTagValue(view, tiffStart, entry, little); } catch (e) { value = null; }
                if (value !== null && value !== undefined && value !== '') out[name] = value;
            }
        }

        function readTiff(view, tiffStart) {
            const endian = view.getUint16(tiffStart);
            const little = endian === 0x4949;
            if (!little && endian !== 0x4D4D) return null;
            if (view.getUint16(tiffStart + 2, little) !== 0x002A) return null;
            const firstIfd = view.getUint32(tiffStart + 4, little);
            if (firstIfd < 8) return null;

            const tags = {};
            readIfd(view, tiffStart, tiffStart + firstIfd, TIFF_TAGS, little, tags);
            if (typeof tags.ExifIFDPointer === 'number') {
                readIfd(view, tiffStart, tiffStart + tags.ExifIFDPointer, EXIF_TAGS, little, tags);
            }
            if (typeof tags.GPSInfoIFDPointer === 'number') {
                readIfd(view, tiffStart, tiffStart + tags.GPSInfoIFDPointer, GPS_TAGS, little, tags);
            }
            delete tags.ExifIFDPointer;
            delete tags.GPSInfoIFDPointer;
            delete tags.InteroperabilityIFDPointer;
            return tags;
        }

        function extractExif(buffer) {
            try {
                const view = new DataView(buffer);
                if (view.byteLength < 12) return null;
                let tiffStart = -1;

                const head16 = view.getUint16(0);
                if (head16 === 0xFFD8) {
                    // JPEG: walk the segments looking for APP1 "Exif\0\0".
                    let offset = 2;
                    while (offset + 4 <= view.byteLength) {
                        if (view.getUint8(offset) !== 0xFF) break;
                        const marker = view.getUint8(offset + 1);
                        if (marker === 0xDA || marker === 0xD9) break; // image data / end
                        const size = view.getUint16(offset + 2);
                        if (size < 2) break;
                        if (marker === 0xE1 && offset + 10 <= view.byteLength &&
                            view.getUint32(offset + 4) === 0x45786966 && // 'Exif'
                            view.getUint16(offset + 8) === 0x0000) {
                            tiffStart = offset + 10;
                            break;
                        }
                        offset += 2 + size;
                    }
                } else if (head16 === 0x4949 || head16 === 0x4D4D) {
                    // TIFF: the whole file is a TIFF structure.
                    tiffStart = 0;
                } else if (view.getUint32(0) === 0x89504E47) {
                    // PNG: look for an eXIf chunk.
                    let offset = 8;
                    while (offset + 8 <= view.byteLength) {
                        const len = view.getUint32(offset);
                        if (len > view.byteLength) break;
                        if (view.getUint32(offset + 4) === 0x65584966) { // 'eXIf'
                            tiffStart = offset + 8;
                            break;
                        }
                        offset += 12 + len; // length + type + data + crc
                    }
                } else if (view.getUint32(0) === 0x52494646 && view.byteLength > 12 &&
                           view.getUint32(8) === 0x57454250) {
                    // WebP: RIFF container, look for an EXIF chunk.
                    let offset = 12;
                    while (offset + 8 <= view.byteLength) {
                        const fourcc = view.getUint32(offset);
                        const len = view.getUint32(offset + 4, true);
                        if (fourcc === 0x45584946) { // 'EXIF'
                            let p = offset + 8;
                            if (p + 6 <= view.byteLength &&
                                view.getUint32(p) === 0x45786966 && view.getUint16(p + 4) === 0x0000) {
                                p += 6; // skip optional 'Exif\0\0' prefix
                            }
                            tiffStart = p;
                            break;
                        }
                        offset += 8 + len + (len & 1);
                    }
                }

                if (tiffStart < 0 || tiffStart + 8 > view.byteLength) return null;
                return readTiff(view, tiffStart);
            } catch (e) {
                return null;
            }
        }

        /* ---------- display formatting ---------- */

        const KEY_LABELS = {
            FNumber: 'F-number',
            ISOSpeedRatings: 'ISO speed',
            FocalLengthIn35mmFilm: 'Focal length (35mm equiv.)',
            PixelXDimension: 'Pixel width',
            PixelYDimension: 'Pixel height',
            DateTimeOriginal: 'Date taken',
            DateTimeDigitized: 'Date digitized',
            DateTime: 'Date modified',
            ExposureBias: 'Exposure bias',
            DigitalZoomRation: 'Digital zoom ratio'
        };

        function formatKey(key) {
            if (KEY_LABELS[key]) return KEY_LABELS[key];
            if (key.indexOf(' ') !== -1) return key; // already readable
            return key
                .replace(/([a-z0-9])([A-Z])/g, '$1 $2')
                .replace(/([A-Z]+)([A-Z][a-z])/g, '$1 $2')
                .trim();
        }

        function roundNice(v) {
            return Math.round(v * 1000) / 1000;
        }

        function truncate(s) {
            return s.length > 120 ? s.slice(0, 120) + '…' : s;
        }

        function formatDisplayValue(key, value) {
            if (value === null || value === undefined) return 'N/A';

            const en = ENUM_STRINGS[key];
            if (en && (typeof value === 'number' || typeof value === 'string') && en[value] !== undefined) {
                return en[value];
            }

            if (typeof value === 'string') return truncate(value);

            if (Array.isArray(value)) {
                if (/^GPS(Dest)?(Latitude|Longitude)$/.test(key) && value.length === 3) {
                    return value[0] + '° ' + value[1] + '′ ' + roundNice(value[2]) + '″';
                }
                if (key === 'GPSTimeStamp' && value.length === 3) {
                    const two = (n) => String(Math.floor(n)).padStart(2, '0');
                    return two(value[0]) + ':' + two(value[1]) + ':' + two(Math.round(value[2])) + ' UTC';
                }
                if (key === 'GPSVersionID') return value.join('.');
                if (key === 'ExifVersion' || key === 'FlashpixVersion') {
                    const s = String.fromCharCode.apply(null, value);
                    const n = parseInt(s, 10);
                    return isNaN(n) ? s : (n / 100).toFixed(2);
                }
                if (key === 'ComponentsConfiguration') {
                    return value.map((v) => COMPONENTS[v] || '').join('') || '—';
                }
                if (key === 'UserComment' && value.length > 8) {
                    const head = String.fromCharCode.apply(null, value.slice(0, 5));
                    if (head === 'ASCII') {
                        const s = String.fromCharCode.apply(null, value.slice(8)).replace(/\0+$/, '').trim();
                        if (s) return truncate(s);
                    }
                }
                return truncate(value.map((v) => (typeof v === 'number' ? roundNice(v) : v)).join(', '));
            }

            if (typeof value === 'number') {
                switch (key) {
                    case 'ExposureTime':
                        return value > 0 && value < 1 ? '1/' + Math.round(1 / value) + ' s' : roundNice(value) + ' s';
                    case 'FNumber': return 'f/' + roundNice(value);
                    case 'FocalLength': return roundNice(value) + ' mm';
                    case 'FocalLengthIn35mmFilm': return value + ' mm';
                    case 'ExposureBias': return (value > 0 ? '+' : '') + roundNice(value) + ' EV';
                    case 'GPSAltitude': return roundNice(value) + ' m';
                    case 'GPSImgDirection': case 'GPSTrack': case 'GPSDestBearing':
                        return roundNice(value) + '°';
                }
                return String(roundNice(value));
            }

            return String(value);
        }

        function cleanFileName(originalName, originalType, blobType) {
            const base = originalName.replace(/\.[^/.]+$/, '') || 'photo';
            const originalExt = (originalName.split('.').pop() || '').toLowerCase();
            const extFromType = { 'image/jpeg': 'jpg', 'image/png': 'png', 'image/webp': 'webp' }[blobType];
            const ext = (blobType === originalType && originalExt) ? originalExt : (extFromType || originalExt || 'png');
            return base + '_cleaned.' + ext;
        }

        /* ---------- the app ---------- */

        createApp({
            data() {
                return {
                    image: null,        // { file, name, size, type, preview, width, height }
                    metadata: {},
                    exifFound: false,
                    processing: false,  // reading + parsing
                    cleaning: false,    // redrawing + re-encoding
                    drag: false,
                    thumbBroken: false,
                    showAll: false,
                    activeTab: 'All',
                    cleaned: null,      // { blob, name, originalSize, cleanedSize }
                    cleanError: '',
                    fileError: '',
                    announcement: ''
                };
            },

            computed: {
                fieldCount() {
                    return Object.keys(this.metadata).length;
                },

                hasGpsData() {
                    return Object.keys(this.metadata).some((key) =>
                        /gps|latitude|longitude|position/i.test(key)
                    );
                },

                hasPersonalData() {
                    return Object.keys(this.metadata).some((key) =>
                        /artist|copyright|creator|author|owner/i.test(key)
                    );
                },

                hasCameraInfo() {
                    return !!(this.metadata.Make || this.metadata.Model || this.metadata.LensModel);
                },

                hasSoftwareInfo() {
                    return !!this.metadata.Software;
                },

                gpsCoords() {
                    const lat = this.metadata.GPSLatitude;
                    const lon = this.metadata.GPSLongitude;
                    if (!Array.isArray(lat) || !Array.isArray(lon)) return '';
                    const toDec = (dms, ref) => {
                        const d = (dms[0] || 0) + (dms[1] || 0) / 60 + (dms[2] || 0) / 3600;
                        return (ref === 'S' || ref === 'W') ? -d : d;
                    };
                    const la = toDec(lat, this.metadata.GPSLatitudeRef);
                    const lo = toDec(lon, this.metadata.GPSLongitudeRef);
                    if (!isFinite(la) || !isFinite(lo)) return '';
                    return la.toFixed(5) + ', ' + lo.toFixed(5);
                },

                metadataCategories() {
                    const categories = ['All', 'Camera', 'Settings', 'DateTime', 'GPS', 'Software', 'Other'];
                    return categories.filter((cat) => {
                        if (cat === 'All') return Object.keys(this.metadata).length > 0;
                        return this.getMetadataByCategory(cat).length > 0;
                    });
                },

                filteredMetadata() {
                    const items = this.activeTab === 'All'
                        ? Object.entries(this.metadata)
                        : this.getMetadataByCategory(this.activeTab);
                    return items.map(([key, value]) => ({
                        k: key,
                        label: formatKey(key),
                        value: formatDisplayValue(key, value)
                    }));
                }
            },

            methods: {
                announce(msg) {
                    this.announcement = '';
                    this.$nextTick(() => { this.announcement = msg; });
                },

                catLabel(cat) {
                    const labels = {
                        All: 'All', Camera: 'Camera', Settings: 'Camera settings',
                        DateTime: 'Dates & times', GPS: 'Location', Software: 'Software', Other: 'Other'
                    };
                    return labels[cat] || cat;
                },

                /* Same category buckets as always. */
                getMetadataByCategory(category) {
                    const entries = Object.entries(this.metadata);
                    switch (category) {
                        case 'Camera':
                            return entries.filter(([key]) => /make|model|camera|lens/i.test(key));
                        case 'Settings':
                            return entries.filter(([key]) => /iso|aperture|shutter|focal|exposure|flash|white.*balance/i.test(key));
                        case 'DateTime':
                            return entries.filter(([key]) => /date|time/i.test(key));
                        case 'GPS':
                            return entries.filter(([key]) => /gps|latitude|longitude|altitude|position/i.test(key));
                        case 'Software':
                            return entries.filter(([key]) => /software|program|application|editor/i.test(key));
                        case 'Other':
                            return entries.filter(([key]) =>
                                !/make|model|camera|lens|iso|aperture|shutter|focal|exposure|flash|white.*balance|date|time|gps|latitude|longitude|altitude|position|software|program|application|editor/i.test(key)
                            );
                        default:
                            return entries;
                    }
                },

                onCatKey(e) {
                    const order = this.metadataCategories;
                    const i = order.indexOf(this.activeTab);
                    let next = null;
                    if (e.key === 'ArrowRight') next = order[(i + 1) % order.length];
                    else if (e.key === 'ArrowLeft') next = order[(i + order.length - 1) % order.length];
                    else if (e.key === 'Home') next = order[0];
                    else if (e.key === 'End') next = order[order.length - 1];
                    if (next) {
                        e.preventDefault();
                        this.activeTab = next;
                        this.$nextTick(() => {
                            const el = document.getElementById('cat-tab-' + next);
                            if (el) el.focus();
                        });
                    }
                },

                /* ---------- file intake ---------- */
                onFileChange(event) {
                    const file = event.target.files && event.target.files[0];
                    if (file) this.processFile(file);
                },

                onDrop(event) {
                    this.drag = false;
                    const file = event.dataTransfer.files && event.dataTransfer.files[0];
                    if (file) this.processFile(file);
                },

                readFileAs(file, kind) {
                    return new Promise((resolve, reject) => {
                        const reader = new FileReader();
                        reader.onload = () => resolve(reader.result);
                        reader.onerror = () => reject(reader.error);
                        if (kind === 'dataURL') reader.readAsDataURL(file);
                        else reader.readAsArrayBuffer(file);
                    });
                },

                async processFile(file) {
                    if (!file) return;
                    if (!file.type || !file.type.startsWith('image/')) {
                        this.fileError = 'That doesn’t look like an image. Try a JPEG, PNG, WEBP, or TIFF file.';
                        this.announce(this.fileError);
                        return;
                    }

                    this.processing = true;
                    this.fileError = '';
                    this.cleanError = '';
                    this.cleaned = null;
                    this.showAll = false;
                    this.thumbBroken = false;

                    try {
                        const [preview, buffer] = await Promise.all([
                            this.readFileAs(file, 'dataURL'),
                            this.readFileAs(file, 'arrayBuffer')
                        ]);

                        const dims = await new Promise((resolve) => {
                            const probe = new Image();
                            probe.onload = () => resolve({ w: probe.naturalWidth, h: probe.naturalHeight });
                            probe.onerror = () => resolve(null);
                            probe.src = preview;
                        });

                        this.image = {
                            file: file,
                            name: file.name,
                            size: file.size,
                            type: file.type,
                            preview: preview,
                            width: dims ? dims.w : 0,
                            height: dims ? dims.h : 0
                        };

                        const tags = extractExif(buffer);
                        if (tags && Object.keys(tags).length > 0) {
                            this.metadata = tags;
                            this.exifFound = true;
                        } else {
                            // No EXIF: fall back to the basic file facts.
                            const basic = {
                                'File Name': file.name,
                                'File Size': this.formatFileSize(file.size),
                                'File Type': file.type || 'Unknown',
                                'Last Modified': new Date(file.lastModified).toLocaleString()
                            };
                            if (dims) {
                                basic['Image Width'] = dims.w + ' pixels';
                                basic['Image Height'] = dims.h + ' pixels';
                                if (dims.h > 0) basic['Aspect Ratio'] = (dims.w / dims.h).toFixed(2);
                            }
                            this.metadata = basic;
                            this.exifFound = false;
                        }

                        const cats = this.metadataCategories;
                        this.activeTab = cats.indexOf('Camera') !== -1 ? 'Camera' : (cats[0] || 'All');

                        this.announce(this.exifFound
                            ? 'Found ' + this.fieldCount + ' metadata details' + (this.hasGpsData ? ', including GPS location.' : '.')
                            : 'No hidden metadata found — only basic file details.');
                    } catch (error) {
                        console.error('Error processing file:', error);
                        this.fileError = 'We couldn’t read that file. Try a different photo.';
                        this.announce(this.fileError);
                    } finally {
                        this.processing = false;
                    }
                },

                /* ---------- clean & download (same canvas redraw as before) ---------- */
                async removeMetadata() {
                    if (!this.image || this.cleaning) return;
                    this.cleaning = true;
                    this.cleanError = '';

                    try {
                        const img = new Image();
                        await new Promise((resolve, reject) => {
                            img.onload = resolve;
                            img.onerror = reject;
                            img.src = this.image.preview;
                        });

                        const canvas = document.createElement('canvas');
                        canvas.width = img.naturalWidth;
                        canvas.height = img.naturalHeight;
                        canvas.getContext('2d').drawImage(img, 0, 0);

                        const blob = await new Promise((resolve) => {
                            canvas.toBlob(resolve, this.image.type, 0.95);
                        });
                        if (!blob) throw new Error('Could not encode the image');

                        this.cleaned = {
                            blob: blob,
                            name: cleanFileName(this.image.name, this.image.type, blob.type),
                            originalSize: this.image.size,
                            cleanedSize: blob.size
                        };
                        this.announce('Metadata removed. Your clean copy is ready to download.');
                    } catch (error) {
                        console.error('Error removing metadata:', error);
                        this.cleanError = 'We couldn’t redraw this photo — your browser may not support this file type. Try a JPEG or PNG.';
                        this.announce(this.cleanError);
                    } finally {
                        this.cleaning = false;
                    }
                },

                downloadClean() {
                    if (!this.cleaned) return;
                    const url = URL.createObjectURL(this.cleaned.blob);
                    const a = document.createElement('a');
                    a.href = url;
                    a.download = this.cleaned.name;
                    document.body.appendChild(a);
                    a.click();
                    document.body.removeChild(a);
                    URL.revokeObjectURL(url);
                    this.announce('Clean copy downloaded.');
                },

                startOver() {
                    this.image = null;
                    this.metadata = {};
                    this.exifFound = false;
                    this.cleaned = null;
                    this.cleanError = '';
                    this.fileError = '';
                    this.showAll = false;
                    this.thumbBroken = false;
                    this.activeTab = 'All';
                    if (this.$refs.fileInput) this.$refs.fileInput.value = '';
                    this.announce('Cleared. Choose another photo.');
                },

                formatFileSize(bytes) {
                    if (bytes === 0) return '0 Bytes';
                    const k = 1024;
                    const sizes = ['Bytes', 'KB', 'MB', 'GB'];
                    const i = Math.floor(Math.log(bytes) / Math.log(k));
                    return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
                }
            }
        }).mount('#app');
    </script>
</body>
</html>
