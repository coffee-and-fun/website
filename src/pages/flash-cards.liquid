<!DOCTYPE html>
<html class="brand-color-background scroll-smooth antialiased" lang="en" data-theme="light" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    
    <!-- Primary Meta Tags -->
    <title>Instant Flash Cards - Turn Any Website Into Study Material | Coffee & Fun</title>
    <meta name="title" content="Instant Flash Cards - Turn Any Website Into Study Material" />
    <meta name="description" content="Convert any website content into flashcards instantly. Enhance learning, improve retention, and study smarter. Available on Chrome, Edge, Safari & Firefox." />
    <meta name="keywords" content="flashcards, study tools, learning app, browser extension, educational tools, memory improvement, exam prep, Coffee and Fun" />
    <meta name="author" content="Coffee & Fun LLC" />
    <meta name="publisher" content="Coffee & Fun LLC" />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="rating" content="general" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://www.coffeeandfun.com/flash-cards/" />
    <meta property="og:title" content="Instant Flash Cards - Turn Any Website Into Study Material" />
    <meta property="og:description" content="Convert any website content into flashcards instantly. Enhance learning, improve retention, and study smarter with one click." />
    <meta property="og:image" content="/assets/images/social/pages/flash-cards.png" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Instant Flash Cards browser extension preview" />
    <meta property="og:site_name" content="Coffee & Fun" />
    <meta property="og:locale" content="en_US" />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content="/flash-cards/" />
    <meta name="twitter:title" content="Instant Flash Cards - Turn Any Website Into Study Material" />
    <meta name="twitter:description" content="Convert any website content into flashcards instantly. Study smarter with one click. Available on all major browsers." />
    <meta name="twitter:image" content="/assets/images/social/pages/flash-cards.png" />
    <meta name="twitter:image:alt" content="Instant Flash Cards browser extension" />
    <meta name="twitter:site" content="@bycoffeeandfun" />
    <meta name="twitter:creator" content="@bycoffeeandfun" />
    
    <!-- Canonical URL -->
    <link rel="canonical" href="https://www.coffeeandfun.com/flash-cards/" />
    
    <!-- Favicon & Icons -->
    <link rel="icon" href="/assets/images/favicon.png" type="image/png" />
    <link rel="apple-touch-icon" href="/assets/images/social/192.png" />
    <link rel="icon" href="/assets/images/social/192.png" sizes="192x192" type="image/png" />
    
    <!-- PWA & Mobile -->
    <link rel="manifest" href="/assets/images/social/site.webmanifest" />
    <meta name="theme-color" content="#fef5ec" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Flash Cards" />
    
    <!-- Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "SoftwareApplication",
        "name": "Instant Flash Cards",
        "description": "Browser extension that converts any website content into flashcards for effective studying",
        "url": "https://www.coffeeandfun.com/flash-cards/",
        "applicationCategory": "EducationalApplication",
        "operatingSystem": "Chrome, Firefox, Safari, Edge",
        "offers": {
            "@type": "Offer",
            "price": "15.00",
            "priceCurrency": "USD",
            "priceValidUntil": "2026-12-31"
        },
        "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.8",
            "ratingCount": "245"
        },
        "creator": {
            "@type": "Organization",
            "name": "Coffee & Fun LLC",
            "url": "https://www.coffeeandfun.com",
            "sameAs": ["https://x.com/bycoffeeandfun"]
        }
    }
    </script>

    <!-- FAQ Structured Data -->
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "mainEntity": [
            {
                "@type": "Question",
                "name": "Why does Instant Flash Cards cost $15 per year?",
                "acceptedAnswer": { "@type": "Answer", "text": "The $15 annual fee covers the costs of keeping the app running smoothly. It supports ongoing improvements, bug fixes, and the development of new features." }
            },
            {
                "@type": "Question",
                "name": "How does Instant Flash Cards handle my data?",
                "acceptedAnswer": { "@type": "Answer", "text": "We only collect the text you've selected when creating flashcards. Text is processed using ChatGPT with custom commands to generate flashcards, then immediately discarded. All data transmission is encrypted, and we never store your content after flashcard creation." }
            },
            {
                "@type": "Question",
                "name": "What is the refund policy?",
                "acceptedAnswer": { "@type": "Answer", "text": "We offer a no-questions-asked refund policy for 3 days following your purchase. Email hello@coffeeandfun.com and we'll process your refund promptly." }
            },
            {
                "@type": "Question",
                "name": "How do I cancel my subscription?",
                "acceptedAnswer": { "@type": "Answer", "text": "Open the Instant Flash Cards extension, click Settings, select Manage in the modal window, then click Cancel Subscription. You're always welcome back!" }
            }
        ]
    }
    </script>
    
    {% bundledCss %}
    
    <!-- Service Worker -->
    <script>
        if ('serviceWorker' in navigator) {
            navigator.serviceWorker.getRegistrations().then((registrations) => {
                for (const registration of registrations) {
                    registration.unregister().then(() => {
                        console.log('🧹 Old service worker unregistered');
                    });
                }
                
                navigator.serviceWorker.register('/service-worker.js')
                    .then(() => console.log('✅ New service worker registered'))
                    .catch((err) => console.log('Service worker error:', err));
            });
        }
    </script>
    
    {% include scripts.html %}
    {% include sketch-styles.liquid %}
</head>

<body>
                    {% assign showFun = true %} 
    {% assign showMiddleBadgeWithText = true %} 
    {% include header.liquid %}
    
