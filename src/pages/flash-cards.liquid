                            <h1 class="brand-heading text-4xl sm:text-5xl md:text-6xl leading-[1.3] sm:leading-[1.3] md:leading-[1.3]" style="color: var(--color-cocoa); text-shadow: 2px 3.5px 0px rgba(254, 245, 236, 0.6);">
