          "url": "https://www.coffeeandfun.com/vibe-check/",
          "image": "https://www.coffeeandfun.com/assets/images/social/pages/vibe-check.png",
          "applicationCategory": "GameApplication",
          "operatingSystem": "Any",
          "browserRequirements": "Requires JavaScript. Requires HTML5.",
          "softwareVersion": "1.0",
