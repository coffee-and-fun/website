{
	"name": "Website",
	"version": "2.0.3",
	"description": "It's (j)ust (e)leventy and (t)ailwind … OK, and a few other things; it's still *really* small though.",
	"type": "module",
	"scripts": {
		"clean": "rimraf docs",
		"dev": "webpack && eleventy --serve",
		"start": "eleventy --serve",
		"format": "prettier --write .",
		"scrape": "node news-scraper.js",
		"build": "node news-scraper.js && NODE_ENV=production webpack --mode production && ELEVENTY_ENV=production eleventy"
	},
	"repository": {
		"type": "git",
		"url": "git+https://marcamos@github.com/marcamos/jet.git"
	},
	"keywords": [
		"eleventy",
		"11ty",
		"tailwind",
		"tailwindcss"
	],
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/marcamos/jet/issues"
	},
	"homepage": "https://github.com/marcamos/jet#readme",
	"devDependencies": {
		"@11ty/eleventy": "^3.0.0",
		"@babel/core": "^7.21.0",
		"@babel/preset-env": "^7.20.2",
		"@tailwindcss/postcss": "^4.1.4",
		"babel-loader": "^8.3.0",
		"cssnano": "^5.1.15",
		"daisyui": "^5.0.27",
		"date-fns": "^2.30.0",
		"eslint": "^9.0.0",
		"eslint-config-prettier": "^9.0.0",
		"eslint-plugin-prettier": "^5.0.0",
		"eslint-plugin-vue": "^9.9.0",
		"eslint-plugin-vuejs-accessibility": "^0.5.1",
		"gulp": "^4.0.2",
		"gulp-image": "^6.2.1",
		"postcss": "^8.5.3",
		"prettier": "^3.0.0",
		"prettier-plugin-tailwindcss": "^0.6.0",
		"rimraf": "^5.0.0",
		"tailwindcss": "^4.1.4",
		"webpack": "^5.79.0",
		"webpack-cli": "^4.10.0"
	},
	"eslintConfig": {
		"root": true,
		"extends": [
			"plugin:vue/essential",
			"plugin:prettier/recommended",
			"eslint:recommended"
		],
		"env": {
			"browser": true,
			"jest": true,
			"node": true
		},
		"globals": {
			"chrome": true
		},
		"rules": {
			"eol-last": 0,
			"quotes": [
				2,
				"single"
			]
		}
	},
	"dependencies": {
		"@11ty/eleventy-plugin-vue": "^1.0.0-canary.8",
		"@tailwindcss/typography": "^0.5.16",
		"@toycode/markdown-it-class": "^1.2.4",
		"canvas": "^2.11.2",
		"eleventy-plugin-svg-contents": "^0.7.0",
		"html-minifier": "^4.0.0",
		"markdown-it": "^12.2.0",
		"markdown-it-anchor": "^9.2.0",
		"node-fetch": "^3.3.2",
		"vue": "^2.7.14"
	}
}
